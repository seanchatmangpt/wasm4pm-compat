# ============================================================================
# AUDIT SPECIFICATIONS FOR CORE RECEIPT MACHINERY
# ============================================================================

audit:ReceiptConsistencySpec
    a audit:AuditSpec ;
    rdfs:label "ReceiptConsistencySpec" ;
    audit:specName "receipt-consistency-audit" ;
    audit:lawName "ReceiptConsistency" ;
    audit:auditScope "crate" ;
    audit:scopeTarget "wasm4pm-compat" ;
    audit:carrierType "Receipt" ;
    audit:verdictType "enum" ;
    audit:applicableTemplate audit:OcelConformanceTemplate ;
    rdfs:comment "Audit: All Receipt instances carry consistent provenance. A receipt's witness marker must match the evidence's witness. Timestamps must be monotonically increasing in the commit history. Commit hashes must be valid and reachable." .

audit:EvidenceLifecycleSoundnessSpec
    a audit:AuditSpec ;
    rdfs:label "EvidenceLifecycleSoundnessSpec" ;
    audit:specName "evidence-lifecycle-soundness" ;
    audit:lawName "EvidenceLifecycleSoundness" ;
    audit:auditScope "crate" ;
    audit:scopeTarget "wasm4pm-compat" ;
    audit:carrierType "Evidence<T, State, W>" ;
    audit:verdictType "boolean" ;
    audit:applicableTemplate audit:OcelConformanceTemplate ;
    rdfs:comment "Audit: Every evidence instance follows the one-way-door state machine. No backwards transitions. No illegal state skips (e.g., Raw directly to Receipted). OCEL replay validates state sequence lawfulness." .

audit:LossReportCompletenessSpec
    a audit:AuditSpec ;
    rdfs:label "LossReportCompletenessSpec" ;
    audit:specName "loss-report-completeness" ;
    audit:lawName "LossReportCompleteness" ;
    audit:auditScope "module" ;
    audit:scopeTarget "src/loss.rs" ;
    audit:carrierType "LossReport<From, To, Items>" ;
    audit:verdictType "boolean" ;
    audit:applicableTemplate audit:RuntimeLossAuditTemplate ;
    rdfs:comment "Audit: Every LossReport must specify: (1) FromType (original form), (2) ToType (projected form), (3) Items lost (by name and count). Missing fields indicate incomplete loss accounting." .

# ============================================================================
# PROV INTEGRATION (W3C Provenance Vocabulary)
# ============================================================================

audit:CommitEvidence
    prov:hadRole prov:Role ;
    rdfs:comment "CommitEvidence instances carry provenance triples linking commits to Evidence carriers, authors to receipt timestamps, and parent commits to closure claims." .

audit:ClosureClaim
    prov:wasInformedBy audit:CommitEvidence ;
    rdfs:comment "ClosureClaim instances use prov:wasInformedBy to link to the CommitEvidence that enacts the closure." .

