# ============================================================================
# EVIDENCE STATE INSTANCES (from src/state.rs — 7 canonical stages)
# ============================================================================

compat:Raw
    a compat:EvidenceState ;
    rdfs:label "Raw" ;
    compat:rustType "Raw" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal false ;
    compat:isProjectible false ;
    compat:successorState compat:Parsed, compat:Refused ;
    compat:description "Untrusted input as it arrives from the outside world. Entry stage: bytes/values parsed off an external format, not yet judged against any Witness. Must never be exported as if admitted." .

compat:Parsed
    a compat:EvidenceState ;
    rdfs:label "Parsed" ;
    compat:rustType "Parsed" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal false ;
    compat:isProjectible false ;
    compat:successorState compat:Admitted, compat:Refused ;
    compat:description "Structurally parsed but not yet judged at the boundary. Well-formed shape accepted by the format decoder but not yet put through admission against a named authority." .

compat:Admitted
    a compat:EvidenceState ;
    rdfs:label "Admitted" ;
    compat:rustType "Admitted" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal false ;
    compat:isProjectible true ;
    compat:successorState compat:Projected, compat:Exportable, compat:Receipted ;
    compat:description "Admitted across the boundary against a named Witness. Reaching Admitted means an Admit impl returned Admission rather than Refusal. Only Admitted evidence is eligible to be projected, exported, or receipted." .

compat:Refused
    a compat:EvidenceState ;
    rdfs:label "Refused" ;
    compat:rustType "Refused" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal true ;
    compat:isProjectible false ;
    compat:description "Terminal refusal: a specific named law was broken at the boundary. Carries the named reason (e.g. DanglingEventObjectLink, FlatteningLoss). Cannot be coerced back to Admitted." .

compat:Projected
    a compat:EvidenceState ;
    rdfs:label "Projected" ;
    compat:rustType "Projected" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal false ;
    compat:isProjectible true ;
    compat:successorState compat:Exportable, compat:Receipted ;
    compat:description "Result of a named, accounted lossy projection produced by a Project impl under an explicit LossPolicy, accompanied by a LossReport. The projection is on the record." .

compat:Exportable
    a compat:EvidenceState ;
    rdfs:label "Exportable" ;
    compat:rustType "Exportable" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal false ;
    compat:isProjectible false ;
    compat:successorState compat:Receipted ;
    compat:description "Cleared to leave the crate as an external/wasm4pm value. Marks evidence that has been admitted (and possibly projected) and is now allowed to cross back out through an export contract." .

compat:Receipted
    a compat:EvidenceState ;
    rdfs:label "Receipted" ;
    compat:rustType "Receipted" ;
    compat:sourceFile "src/state.rs" ;
    compat:isTerminal true ;
    compat:isProjectible false ;
    compat:description "Sealed inside a provenance-bearing receipt shape. Records provenance and the witness it answered to. Strongest structural stage — the natural hand-off point when graduating to a wasm4pm engine that will verify the receipt." .

