# ============================================================================
# AUDIT SPECIFICATIONS FOR CORE RECEIPT MACHINERY
# ============================================================================

audit:ReceiptConsistencySpec
    a audit:AuditSpec ;
    rdfs:label "ReceiptConsistencySpec" ;
    audit:specName "receipt-consistency-audit" ;
    audit:lawName "ReceiptConsistency" ;
    audit:auditScope "crate" ;
    audit:scopeTarget "wasm4pm-compat" ;
    audit:carrierType "Receipt" ;
    audit:verdictType "enum" ;
    audit:applicableTemplate audit:OcelConformanceTemplate ;
    rdfs:comment "Audit: All Receipt instances carry consistent provenance. A receipt's witness marker must match the evidence's witness. Timestamps must be monotonically increasing in the commit history. Commit hashes must be valid and reachable." .

audit:EvidenceLifecycleSoundnessSpec
    a audit:AuditSpec ;
    rdfs:label "EvidenceLifecycleSoundnessSpec" ;
    audit:specName "evidence-lifecycle-soundness" ;
    audit:lawName "EvidenceLifecycleSoundness" ;
    audit:auditScope "crate" ;
    audit:scopeTarget "wasm4pm-compat" ;
    audit:carrierType "Evidence<T, State, W>" ;
    audit:verdictType "boolean" ;
    audit:applicableTemplate audit:OcelConformanceTemplate ;
    rdfs:comment "Audit: Every evidence instance follows the one-way-door state machine. No backwards transitions. No illegal state skips (e.g., Raw directly to Receipted). OCEL replay validates state sequence lawfulness." .

audit:LossReportCompletenessSpec
    a audit:AuditSpec ;
    rdfs:label "LossReportCompletenessSpec" ;
    audit:specName "loss-report-completeness" ;
    audit:lawName "LossReportCompleteness" ;
    audit:auditScope "module" ;
    audit:scopeTarget "src/loss.rs" ;
    audit:carrierType "LossReport<From, To, Items>" ;
    audit:verdictType "boolean" ;
    audit:applicableTemplate audit:RuntimeLossAuditTemplate ;
    rdfs:comment "Audit: Every LossReport must specify: (1) FromType (original form), (2) ToType (projected form), (3) Items lost (by name and count). Missing fields indicate incomplete loss accounting." .

# ============================================================================
# PROV INTEGRATION (W3C Provenance Vocabulary)
# ============================================================================

audit:CommitEvidence
    prov:hadRole prov:Role ;
    rdfs:comment "CommitEvidence instances carry provenance triples linking commits to Evidence carriers, authors to receipt timestamps, and parent commits to closure claims." .

audit:ClosureClaim
    prov:wasInformedBy audit:CommitEvidence ;
    rdfs:comment "ClosureClaim instances use prov:wasInformedBy to link to the CommitEvidence that enacts the closure." .

# ============================================================================
# END OF AUDIT MACHINERY ONTOLOGY
# ============================================================================
# Domain Ontology: Evidence Structure
# Defines types, properties, and classes for evidence carriers, witnesses, lifecycle stages,
# and admission/refusal boundaries.
#
# Companion to wasm4pm-compat-integrated.ttl

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix domain: <https://wasm4pm-compat.rs/domain#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .

<https://wasm4pm-compat.rs/domain/evidence-structure>
    a owl:Ontology ;
    rdfs:label "Evidence Structure Domain Ontology" ;
    rdfs:comment "Domain-specific definitions for evidence types, witness markers, lifecycle stages, and admission/refusal boundaries." ;
    owl:versionInfo "1.0.0" .

# ============================================================================
# EVIDENCE CARRIER CLASSES
# ============================================================================

domain:EvidenceCarrier
    a rdfs:Class ;
    rdfs:label "Evidence Carrier" ;
    rdfs:comment "The universal Evidence<T, State, W> type bundle. A value T tagged with a lifecycle State and a Witness W via PhantomData — zero runtime cost." ;
    owl:equivalentClass compat:Evidence .

domain:RawEvidence
    a rdfs:Class ;
    rdfs:label "Raw Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Raw, W> — untrusted input as it arrives from the outside world. Not yet parsed or judged against any witness." .

domain:ParsedEvidence
    a rdfs:Class ;
    rdfs:label "Parsed Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Parsed, W> — structurally parsed but not yet judged at the boundary. Well-formed shape accepted by the format decoder." .

domain:AdmittedEvidence
    a rdfs:Class ;
    rdfs:label "Admitted Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Admitted, W> — admitted across the boundary against a named Witness. Only admitted evidence is eligible for projection, export, or receipt." .

domain:RefusedEvidence
    a rdfs:Class ;
    rdfs:label "Refused Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Refused, W> — terminal refusal carrying a specific named law reason. Cannot be coerced back to Admitted." .

domain:ProjectedEvidence
    a rdfs:Class ;
    rdfs:label "Projected Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Projected, W> — result of a named, accounted lossy projection under an explicit LossPolicy with a LossReport." .

domain:ExportableEvidence
    a rdfs:Class ;
    rdfs:label "Exportable Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Exportable, W> — cleared to leave the crate as an external/wasm4pm value. Admitted (and possibly projected) and now allowed to cross the export boundary." .

domain:ReceiptedEvidence
    a rdfs:Class ;
    rdfs:label "Receipted Evidence" ;
    rdfs:subClassOf domain:EvidenceCarrier ;
    rdfs:comment "Evidence<T, Receipted, W> — sealed inside a provenance-bearing receipt. Records provenance and the witness it answered to. Strongest structural stage." .

# ============================================================================
# WITNESS MARKER CLASSES
# ============================================================================

domain:StandardWitness
    a rdfs:Class ;
    rdfs:label "Standard Witness" ;
    rdfs:subClassOf domain:WitnessMarker ;
    rdfs:comment "A witness marker naming a published interchange/data standard (e.g. OCEL 2.0, XES 1849-2016). Evidence tagged with a Standard witness must conform to that standard's schema." .

domain:PaperWitness
    a rdfs:Class ;
    rdfs:label "Paper Witness" ;
    rdfs:subClassOf domain:WitnessMarker ;
    rdfs:comment "A witness marker naming an academic paper defining a model or model family (e.g. POWL, WF-net soundness, OC-Petri-nets, OCPQ)." .

domain:ApiGrammarWitness
    a rdfs:Class ;
    rdfs:label "API Grammar Witness" ;
    rdfs:subClassOf domain:WitnessMarker ;
    rdfs:comment "A witness marker naming an API grammar a consumer must speak to interoperate (e.g. pm4py call shape, pmax consumer grammar)." .

domain:RustLawWitness
    a rdfs:Class ;
    rdfs:label "Rust Law Witness" ;
    rdfs:subClassOf domain:WitnessMarker ;
    rdfs:comment "A witness marker naming a Rust-language law this crate enforces structurally (e.g. typestate admission, forbid(unsafe_code))." .

domain:InternalBridgeWitness
    a rdfs:Class ;
    rdfs:label "Internal Bridge Witness" ;
    rdfs:subClassOf domain:WitnessMarker ;
    rdfs:comment "A witness marker naming an internal bridge toward graduation (e.g. the wasm4pm engine bridge). Marks the boundary where compat ends and wasm4pm begins." .

# ============================================================================
# WITNESS MARKER INSTANCES (key process-mining witnesses)
# ============================================================================

domain:OcelStandardWitness
    a domain:StandardWitness ;
    rdfs:label "OCEL 2.0 Standard Witness" ;
    compat:rustType "Ocel20" ;
    compat:witnessKey "ocel-2.0" ;
    compat:witnessTitle "OCEL 2.0" ;
    compat:witnessYear 2023 ;
    skos:definition "The object-centric event log standard (OCEL 2.0). Evidence tagged with this witness conforms to https://ocel-standard.org/." ;
    prov:wasAttributedTo <https://ocel-standard.org/> .

domain:XesStandardWitness
    a domain:StandardWitness ;
    rdfs:label "XES Standard Witness" ;
    compat:rustType "Xes1849" ;
    compat:witnessKey "xes-1849-2016" ;
    compat:witnessTitle "XES (IEEE 1849-2016)" ;
    compat:witnessYear 2016 ;
    skos:definition "The eXtensible Event Stream interchange standard (IEEE 1849-2016). Evidence conforms to the XES XML schema." ;
    prov:wasAttributedTo <http://www.xes-standard.org/> .

domain:BpmnStandardWitness
    a domain:StandardWitness ;
    rdfs:label "BPMN 2.0 Standard Witness" ;
    compat:rustType "Bpmn20" ;
    compat:witnessTitle "BPMN 2.0" ;
    compat:witnessYear 2011 ;
    skos:definition "Business Process Model and Notation 2.0. Evidence models conform to the BPMN 2.0 metamodel (https://www.omg.org/spec/BPMN/2.0/)." ;
    prov:wasAttributedTo <https://www.omg.org/spec/BPMN/> .

domain:PowlPaperWitness
    a domain:PaperWitness ;
    rdfs:label "POWL Paper Witness" ;
    compat:rustType "PowlPaper" ;
    compat:witnessKey "powl-paper" ;
    compat:witnessTitle "POWL: Partially Ordered Workflow Language" ;
    compat:witnessYear 2023 ;
    skos:definition "Partially Ordered Workflow Language (Kourani and van Zelst, 2023). Extends classical block structures with explicit partial ordering." .

domain:WfNetSoundnessPaperWitness
    a domain:PaperWitness ;
    rdfs:label "WF-Net Soundness Paper Witness" ;
    compat:rustType "WfNetSoundnessPaper" ;
    compat:witnessKey "wfnet-soundness-paper" ;
    compat:witnessTitle "The Application of Petri Nets to Workflow Management" ;
    compat:witnessYear 1998 ;
    skos:definition "WF-net soundness criterion (van der Aalst, 1998). A WF-net is sound iff it has proper termination, option to complete, and no dead transitions." .

domain:Wasm4pmBridgeWitness
    a domain:InternalBridgeWitness ;
    rdfs:label "wasm4pm Bridge Witness" ;
    compat:rustType "Wasm4pmBridge" ;
    compat:witnessKey "wasm4pm-bridge" ;
    compat:witnessTitle "wasm4pm Graduation Bridge" ;
    skos:definition "The internal bridge toward the wasm4pm execution engine. Evidence tagged with this witness is ready to cross the graduation boundary for engine-side processing." .

# ============================================================================
# LIFECYCLE STAGE CLASSES
# ============================================================================

domain:LifecycleStageClass
    a rdfs:Class ;
    rdfs:label "Lifecycle Stage" ;
    rdfs:comment "One of the seven canonical evidence lifecycle stages. Implements the sealed EvidenceState trait." .

domain:RawStage
    a domain:LifecycleStageClass ;
    rdfs:label "Raw" ;
    compat:rustType "Raw" ;
    skos:definition "Untrusted input as it arrives from the outside world. Entry stage. Must never be exported as if admitted." ;
    compat:successorState domain:ParsedStage, domain:RefusedStage .

domain:ParsedStage
    a domain:LifecycleStageClass ;
    rdfs:label "Parsed" ;
    compat:rustType "Parsed" ;
    skos:definition "Structurally parsed but not yet judged at the boundary. Well-formed shape accepted but not yet put through admission." ;
    compat:successorState domain:AdmittedStage, domain:RefusedStage .

domain:AdmittedStage
    a domain:LifecycleStageClass ;
    rdfs:label "Admitted" ;
    compat:rustType "Admitted" ;
    skos:definition "Admitted across the boundary against a named Witness. Only admitted evidence is eligible for projection, export, or receipt." ;
    compat:successorState domain:ProjectedStage, domain:ExportableStage, domain:ReceiptedStage .

domain:RefusedStage
    a domain:LifecycleStageClass ;
    rdfs:label "Refused" ;
    compat:rustType "Refused" ;
    skos:definition "Terminal refusal: a specific named law was broken at the boundary. Cannot be coerced back to Admitted." ;
    owl:disjointWith domain:AdmittedStage, domain:ProjectedStage, domain:ExportableStage, domain:ReceiptedStage .

domain:ProjectedStage
    a domain:LifecycleStageClass ;
    rdfs:label "Projected" ;
    compat:rustType "Projected" ;
    skos:definition "Result of a named, accounted lossy projection under a LossPolicy with a LossReport." ;
    compat:successorState domain:ExportableStage, domain:ReceiptedStage .

domain:ExportableStage
    a domain:LifecycleStageClass ;
    rdfs:label "Exportable" ;
    compat:rustType "Exportable" ;
    skos:definition "Cleared to leave the crate as an external/wasm4pm value. Admitted (and possibly projected)." ;
    compat:successorState domain:ReceiptedStage .

domain:ReceiptedStage
    a domain:LifecycleStageClass ;
    rdfs:label "Receipted" ;
    compat:rustType "Receipted" ;
    skos:definition "Sealed inside a provenance-bearing receipt. Strongest structural stage — the natural hand-off for wasm4pm graduation." ;
    owl:disjointWith domain:RawStage, domain:ParsedStage .

# ============================================================================
# ADMISSION AND REFUSAL VERDICT CLASSES
# ============================================================================

domain:AdmissionVerdict
    a rdfs:Class ;
    rdfs:label "Admission Verdict" ;
    rdfs:comment "Admission<T, W> — proves at the type level that an Admit impl accepted a value against witness W. Only sanctioned Raw → Admitted path." ;
    owl:equivalentClass compat:Admission ;
    rdfs:subClassOf rdf:Statement .

domain:RefusalVerdict
    a rdfs:Class ;
    rdfs:label "Refusal Verdict" ;
    rdfs:comment "Refusal<R, W> — carries a specific named reason R and witness W. Bare InvalidInput is forbidden. Each reason is a named law." ;
    owl:equivalentClass compat:Refusal ;
    rdfs:subClassOf rdf:Statement .

domain:AdmissionBoundary
    a rdfs:Class ;
    rdfs:label "Admission Boundary" ;
    rdfs:comment "The structural boundary where Raw evidence is judged against a witness and either admitted or refused. Only sanctioned point for verdict issuance." .

# ============================================================================
# PROPERTIES FOR EVIDENCE LIFECYCLE
# ============================================================================

domain:carriedValue
    a rdf:Property ;
    rdfs:label "carried value" ;
    rdfs:comment "The actual data value T carried inside an Evidence<T, State, W> envelope. Type T is application-specific (EventLog, PetriNet, etc.)." ;
    rdfs:domain domain:EvidenceCarrier ;
    rdfs:range owl:Thing .

domain:evidenceState
    a rdf:Property ;
    rdfs:label "evidence state" ;
    rdfs:comment "The lifecycle stage (Raw, Parsed, Admitted, Refused, Projected, Exportable, Receipted) of this evidence as a PhantomData tag." ;
    rdfs:domain domain:EvidenceCarrier ;
    rdfs:range domain:LifecycleStageClass .

domain:evidenceWitness
    a rdf:Property ;
    rdfs:label "evidence witness" ;
    rdfs:comment "The witness marker (W parameter in Evidence<T, State, W>) this evidence answers to. Discriminates Ocel20 from Xes1849, etc." ;
    rdfs:domain domain:EvidenceCarrier ;
    rdfs:range domain:WitnessMarker .

domain:admissionVerdictOf
    a rdf:Property ;
    rdfs:label "admission verdict of" ;
    rdfs:comment "Relates an Admission verdict to the evidence that triggered it." ;
    rdfs:domain domain:AdmissionVerdict ;
    rdfs:range domain:EvidenceCarrier .

domain:refusalReasonType
    a rdf:Property ;
    rdfs:label "refusal reason type" ;
    rdfs:comment "The specific named law reason R of a Refusal<R, W>. Examples: DanglingEventObjectLink, MissingFinalMarking, WitnessDiscrimination." ;
    rdfs:domain domain:RefusalVerdict ;
    rdfs:range xsd:string .

domain:refusalVerdictOf
    a rdf:Property ;
    rdfs:label "refusal verdict of" ;
    rdfs:comment "Relates a Refusal verdict to the evidence that triggered it." ;
    rdfs:domain domain:RefusalVerdict ;
    rdfs:range domain:EvidenceCarrier .

# ============================================================================
# LOSS ACCOUNTING CLASSES AND PROPERTIES
# ============================================================================

domain:LossReport
    a rdfs:Class ;
    rdfs:label "Loss Report" ;
    rdfs:comment "LossReport<From, To, Items> — accounting for lossy projections. Every non-refusing projection emits a named LossReport." .

domain:ProjectionName
    a rdfs:Class ;
    rdfs:label "Projection Name" ;
    rdfs:comment "A &'static str newtype identifying a specific lossy transformation. Examples: 'OCEL2XES', 'Flatten', 'AbstractTraces'." .

domain:LossPolicy
    a rdfs:Class ;
    rdfs:label "Loss Policy" ;
    rdfs:comment "Decision on how to handle loss in a projection: RefuseLoss, AllowNamedProjection, or AllowLossWithReport." .

domain:projectionNameValue
    a rdf:Property ;
    rdfs:label "projection name value" ;
    rdfs:comment "The string identifier of a ProjectionName (e.g., 'OCEL2XES')." ;
    rdfs:domain domain:ProjectionName ;
    rdfs:range xsd:string .

domain:lossFromType
    a rdf:Property ;
    rdfs:label "loss from type" ;
    rdfs:comment "The source type in a LossReport<From, To, Items>." ;
    rdfs:domain domain:LossReport ;
    rdfs:range xsd:string .

domain:lossToType
    a rdf:Property ;
    rdfs:label "loss to type" ;
    rdfs:comment "The target type in a LossReport<From, To, Items>." ;
    rdfs:domain domain:LossReport ;
    rdfs:range xsd:string .

domain:lossItemCount
    a rdf:Property ;
    rdfs:label "loss item count" ;
    rdfs:comment "The number of items lost in a projection (cardinality of the Items set in LossReport<From, To, Items>)." ;
    rdfs:domain domain:LossReport ;
    rdfs:range xsd:integer .

domain:lossPolicy
    a rdf:Property ;
    rdfs:label "loss policy" ;
    rdfs:comment "The LossPolicy that governed this projection." ;
    rdfs:domain domain:LossReport ;
    rdfs:range domain:LossPolicy .

# ============================================================================
# CLOSED-WORLD STATEMENT
# ============================================================================

<https://wasm4pm-compat.rs/domain/evidence-structure>
    skos:note "All evidence classes and witness markers declared here are exhaustive. The seven lifecycle stages and their transitions form a complete state machine. No evidence state or witness type exists outside this ontology that is valid in wasm4pm-compat." .

# ============================================================================
# END OF DOMAIN ONTOLOGY: EVIDENCE STRUCTURE
# ============================================================================
# Domain Ontology: Graduation Boundaries
# Defines the boundaries where wasm4pm-compat structure ends and the wasm4pm execution
# engine begins. Includes graduation surfaces, authorities, and the graduation bridge trait.
#
# Companion to wasm4pm-compat-integrated.ttl

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix domain: <https://wasm4pm-compat.rs/domain#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://wasm4pm-compat.rs/domain/graduation-boundaries>
    a owl:Ontology ;
    rdfs:label "Graduation Boundaries Domain Ontology" ;
    rdfs:comment "Domain-specific definitions for graduation boundaries and surfaces where wasm4pm-compat graduates process-mining logic to the wasm4pm execution engine." ;
    owl:versionInfo "1.0.0" .

# ============================================================================
# GRADUATION BOUNDARY CLASSES
# ============================================================================

domain:GraduationBoundary
    a rdfs:Class ;
    rdfs:label "Graduation Boundary" ;
    rdfs:comment "A named boundary where wasm4pm-compat structure ends and the wasm4pm engine begins. Corresponds to GraduationReason enum variants in src/graduation.rs." ;
    owl:equivalentClass compat:GraduationBoundary .

# ============================================================================
# GRADUATION REASON INSTANCES
# ============================================================================

domain:NeedsDiscovery
    a domain:GraduationBoundary ;
    rdfs:label "Needs Discovery" ;
    compat:rustType "GraduationReason::NeedsDiscovery" ;
    skos:definition "Surface hits a wall requiring process discovery execution (Alpha Miner, Inductive Miner, Heuristics Miner, DFG mining). Graduate to wasm4pm." ;
    rdfs:comment "Process discovery algorithms that extract a process model from an event log. Graduation reason indicates the surface has defined the shape but cannot execute discovery." ;
    domain:graduatesToWasm4pmAuthority domain:MiningAuthority ;
    domain:applicableProcessForms
        compat:ProcessTree,
        compat:PowlNode,
        compat:DirectlyFollowsGraph,
        compat:CausalNet .

domain:NeedsConformanceExecution
    a domain:GraduationBoundary ;
    rdfs:label "Needs Conformance Execution" ;
    compat:rustType "GraduationReason::NeedsConformanceExecution" ;
    skos:definition "Surface requires token-replay, alignment, or conformance scoring execution. Graduate to wasm4pm." ;
    rdfs:comment "Conformance checking and model-to-log alignment computation. Graduation reason indicates metrics/verdicts are structured but cannot be computed." ;
    domain:graduatesToWasm4pmAuthority domain:ConformanceAuthority ;
    domain:applicableProcessForms
        compat:PetriNet,
        compat:WfNetConst,
        compat:DeclareModel,
        compat:ConformanceVerdict,
        compat:ProcessCube,
        compat:TemporalConstraint,
        compat:MultiPerspective,
        compat:CausalityGraph,
        compat:OcpqQuery .

domain:NeedsReplay
    a domain:GraduationBoundary ;
    rdfs:label "Needs Replay" ;
    compat:rustType "GraduationReason::NeedsReplay" ;
    skos:definition "Surface requires a token-replay or language-inclusion check. Graduate to wasm4pm." ;
    rdfs:comment "Token-based simulation and replay. Graduation reason indicates replayability structures are defined but replay cannot be executed." ;
    domain:graduatesToWasm4pmAuthority domain:ReplayAuthority ;
    domain:applicableProcessForms
        compat:PetriNet,
        compat:WfNetConst,
        compat:ObjectCentricPetriNet .

domain:NeedsBenchmarkGating
    a domain:GraduationBoundary ;
    rdfs:label "Needs Benchmark Gating" ;
    compat:rustType "GraduationReason::NeedsBenchmarkGating" ;
    skos:definition "Surface requires a benchmark gate (throughput, latency, scalability measurement). Graduate to wasm4pm." ;
    rdfs:comment "Performance measurement and benchmark orchestration. Graduation reason indicates performance gates are declared but cannot be measured." ;
    domain:graduatesToWasm4pmAuthority domain:PerformanceAuthority .

domain:NeedsObjectCentricQuery
    a domain:GraduationBoundary ;
    rdfs:label "Needs Object-Centric Query" ;
    compat:rustType "GraduationReason::NeedsObjectCentricQuery" ;
    skos:definition "Surface requires OCPQ query execution over an OCEL log. Graduate to wasm4pm." ;
    rdfs:comment "Object-centric process querying (OCPQ). Graduation reason indicates queries are structured but cannot be executed." ;
    domain:graduatesToWasm4pmAuthority domain:QueryAuthority ;
    domain:applicableProcessForms compat:OcpqQuery, compat:OcelLog .

domain:RebuildingProcessMiningLocally
    a domain:GraduationBoundary ;
    rdfs:label "Rebuilding Process Mining Locally" ;
    compat:rustType "GraduationReason::RebuildingProcessMiningLocally" ;
    skos:definition "Consumer is rebuilding process mining logic inside the compat layer — the clearest signal to graduate the entire surface to wasm4pm." ;
    rdfs:comment "The consumer has begun implementing process-mining logic that belongs in wasm4pm. This is a signal to graduate the entire surface and its dependencies." ;
    domain:graduatesToWasm4pmAuthority domain:MultipleAuthorities ;
    domain:severity "CRITICAL" .

# ============================================================================
# GRADUATION SURFACES (wasm4pm Authorities)
# ============================================================================

domain:GraduationSurface
    a rdfs:Class ;
    rdfs:label "Graduation Surface" ;
    rdfs:comment "A named wasm4pm module surface where compat structure graduates to engine logic. Renders Evidence carriers and witness markers." ;
    owl:equivalentClass compat:GraduationSurface .

domain:MiningAuthority
    a domain:GraduationSurface ;
    rdfs:label "Mining Authority" ;
    compat:rustType "MiningAuthority" ;
    compat:graduatesTo "wasm4pm::mining" ;
    compat:requiresWitness compat:MiningWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, MiningWitness>" ;
    skos:definition "Process discovery graduation surface. Handles inductive mining, heuristic mining, alpha mining, variant analysis, and trace abstraction." ;
    rdfs:comment "The wasm4pm mining module where discovery algorithms extract process models from event logs." ;
    domain:discoveryAlgorithms
        "Alpha Algorithm (van der Aalst et al., 2004)",
        "Inductive Miner (Leemans et al., 2013)",
        "Heuristics Miner (Weijters and Aalst, 2001)",
        "DFG Mining",
        "Variant Analysis",
        "Trace Abstraction" ;
    domain:inputForms compat:EventLog, compat:OcelLog, compat:StreamingLog ;
    domain:outputForms compat:ProcessTree, compat:PowlNode, compat:DirectlyFollowsGraph, compat:CausalNet, compat:PetriNet .

domain:ConformanceAuthority
    a domain:GraduationSurface ;
    rdfs:label "Conformance Authority" ;
    compat:rustType "ConformanceAuthority" ;
    compat:graduatesTo "wasm4pm::conformance" ;
    compat:requiresWitness compat:ConformanceWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, ConformanceWitness>" ;
    skos:definition "Conformance checking graduation surface. Handles model-to-log alignment, fitness calculation, precision/recall/generalization metrics, and declarative constraint checking." ;
    rdfs:comment "The wasm4pm conformance module where model-to-log alignment and conformance metrics are computed." ;
    domain:conformanceMetrics
        "Fitness (fraction of log traces replayed)",
        "Precision (fraction of model traces in log)",
        "Generalization",
        "F1 Score",
        "Alignment Cost",
        "Edit Distance" ;
    domain:inputForms compat:EventLog, compat:OcelLog, compat:PetriNet, compat:ProcessTree, compat:DeclareModel ;
    domain:outputForms compat:ConformanceVerdict ;
    domain:associatedConstraintWitnesses
        domain:ControlFlowPerspectiveWitness,
        domain:DataPerspectiveWitness,
        domain:ResourcePerspectiveWitness,
        domain:TimePerspectiveWitness .

domain:ReplayAuthority
    a domain:GraduationSurface ;
    rdfs:label "Replay Authority" ;
    compat:rustType "ReplayAuthority" ;
    compat:graduatesTo "wasm4pm::replay" ;
    compat:requiresWitness compat:ReplayWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, ReplayWitness>" ;
    skos:definition "Token replay and simulation graduation surface. Handles token-based replay, parallel path execution, path finding, and execution profiling." ;
    rdfs:comment "The wasm4pm replay module where Petri nets are step-wise executed against event traces." ;
    domain:replayStrategies
        "Token-based step-wise replay",
        "Parallel path execution",
        "A* path finding for missing moves",
        "Execution profiling and bottleneck analysis" ;
    domain:inputForms compat:PetriNet, compat:WfNetConst, compat:ObjectCentricPetriNet ;
    domain:outputForms compat:ConformanceVerdict .

domain:LifecycleAuthority
    a domain:GraduationSurface ;
    rdfs:label "Lifecycle Authority" ;
    compat:rustType "LifecycleAuthority" ;
    compat:graduatesTo "wasm4pm::lifecycle" ;
    compat:requiresWitness compat:LifecycleWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, LifecycleWitness>" ;
    skos:definition "Object-centric lifecycle graduation surface. Handles OCEL object tracking, state machine execution, artifact provenance, and object lifecycle states." ;
    rdfs:comment "The wasm4pm lifecycle module where object-centric process execution and state tracking occurs." ;
    domain:lifecycleCapabilities
        "Object lifecycle state tracking",
        "Multi-object process orchestration",
        "Artifact provenance and causality",
        "Cross-object correlation and causal ordering",
        "Object-centric conformance checking" ;
    domain:inputForms compat:OcelLog, compat:ObjectCentricPetriNet, compat:CorrelationSchema ;
    domain:outputForms compat:ObjectLifecycle, compat:CausalityGraph .

domain:QueryAuthority
    a domain:GraduationSurface ;
    rdfs:label "Query Authority" ;
    compat:rustType "QueryAuthority" ;
    compat:graduatesTo "wasm4pm::query" ;
    compat:requiresWitness compat:QueryWitness ;
    compat:evidenceCarrier "Evidence<OcpqQuery, Admitted|Projected, QueryWitness>" ;
    skos:definition "Object-centric process querying graduation surface. Executes OCPQ queries over OCEL logs." ;
    rdfs:comment "The wasm4pm query module where OCPQ queries are compiled and executed." ;
    domain:queryCapabilities
        "Event predicate evaluation",
        "Object predicate evaluation",
        "Relation predicate evaluation",
        "Temporal predicate evaluation",
        "Cardinality predicate evaluation",
        "Nested query execution" ;
    domain:inputForms compat:OcelLog, compat:OcpqQuery ;
    domain:outputForms compat:OcpqQuery .

domain:PerformanceAuthority
    a domain:GraduationSurface ;
    rdfs:label "Performance Authority" ;
    compat:rustType "PerformanceAuthority" ;
    compat:graduatesTo "wasm4pm::performance" ;
    rdfs:comment "The wasm4pm performance module where benchmark gates and scalability measurements are executed." ;
    domain:performanceMetrics
        "Throughput (events/sec)",
        "Latency (p50, p95, p99 response time)",
        "Memory usage (peak, average)",
        "CPU utilization",
        "Scalability (strong/weak scaling)" .

domain:MultipleAuthorities
    a domain:GraduationSurface ;
    rdfs:label "Multiple Authorities" ;
    rdfs:comment "Graduation to multiple wasm4pm authorities simultaneously. Used when a surface touches discovery, conformance, replay, and lifecycle logic." .

# ============================================================================
# GRADUATION BRIDGE TRAIT AND CANDIDATES
# ============================================================================

domain:GraduationBridgeTrait
    a rdfs:Class ;
    rdfs:label "GraduateToWasm4pm Trait" ;
    rdfs:comment "The Rust trait that enables a type to declare itself as a graduation candidate. Implementing this trait signals readiness to hand off to wasm4pm." ;
    skos:definition "GraduateToWasm4pm trait implementation signals readiness for graduation." ;
    domain:featureFlag "wasm4pm" .

domain:GraduationCandidate
    a rdfs:Class ;
    rdfs:label "Graduation Candidate" ;
    rdfs:comment "A type that implements GraduateToWasm4pm and declares one or more GraduationReason variants. Ready for handoff." ;
    owl:equivalentClass compat:GraduationCandidate ;
    domain:hasGraduationReasons compat:GraduationReason ;
    domain:isGrounded "true|false" .

domain:GroundedCandidate
    a rdfs:Class ;
    rdfs:label "Grounded Graduation Candidate" ;
    rdfs:subClassOf domain:GraduationCandidate ;
    rdfs:comment "A graduation candidate with a concrete wasm4pm module surface to hand off to." ;
    domain:isGrounded "true" .

domain:UngroundedCandidate
    a rdfs:Class ;
    rdfs:label "Ungrounded Graduation Candidate" ;
    rdfs:subClassOf domain:GraduationCandidate ;
    rdfs:comment "A graduation candidate with a GraduationReason but no concrete wasm4pm surface yet. Signals a TODO/gap." ;
    domain:isGrounded "false" .

# ============================================================================
# GRADUATION PROPERTIES
# ============================================================================

domain:graduatesToWasm4pmAuthority
    a rdf:Property ;
    rdfs:label "graduates to wasm4pm authority" ;
    rdfs:comment "The specific wasm4pm authority surface that this graduation reason routes to." ;
    rdfs:domain domain:GraduationBoundary ;
    rdfs:range domain:GraduationSurface .

domain:applicableProcessForms
    a rdf:Property ;
    rdfs:label "applicable process forms" ;
    rdfs:comment "The process forms that trigger this graduation reason." ;
    rdfs:domain domain:GraduationBoundary ;
    rdfs:range [ owl:unionOf ( compat:ProcessForm ) ] .

domain:inputForms
    a rdf:Property ;
    rdfs:label "input forms" ;
    rdfs:comment "The process forms that a graduation surface accepts as input." ;
    rdfs:domain domain:GraduationSurface ;
    rdfs:range [ owl:unionOf ( compat:ProcessForm ) ] .

domain:outputForms
    a rdf:Property ;
    rdfs:label "output forms" ;
    rdfs:comment "The process forms that a graduation surface produces as output." ;
    rdfs:domain domain:GraduationSurface ;
    rdfs:range [ owl:unionOf ( compat:ProcessForm ) ] .

domain:conformanceMetrics
    a rdf:Property ;
    rdfs:label "conformance metrics" ;
    rdfs:comment "Named conformance metrics handled by this authority." ;
    rdfs:domain domain:ConformanceAuthority ;
    rdfs:range xsd:string .

domain:discoveryAlgorithms
    a rdf:Property ;
    rdfs:label "discovery algorithms" ;
    rdfs:comment "Named process discovery algorithms handled by this authority." ;
    rdfs:domain domain:MiningAuthority ;
    rdfs:range xsd:string .

domain:replayStrategies
    a rdf:Property ;
    rdfs:label "replay strategies" ;
    rdfs:comment "Named token-replay strategies handled by this authority." ;
    rdfs:domain domain:ReplayAuthority ;
    rdfs:range xsd:string .

domain:lifecycleCapabilities
    a rdf:Property ;
    rdfs:label "lifecycle capabilities" ;
    rdfs:comment "Named object-centric lifecycle capabilities handled by this authority." ;
    rdfs:domain domain:LifecycleAuthority ;
    rdfs:range xsd:string .

domain:queryCapabilities
    a rdf:Property ;
    rdfs:label "query capabilities" ;
    rdfs:comment "Named OCPQ query capabilities handled by this authority." ;
    rdfs:domain domain:QueryAuthority ;
    rdfs:range xsd:string .

domain:performanceMetrics
    a rdf:Property ;
    rdfs:label "performance metrics" ;
    rdfs:comment "Named performance metrics measured by this authority." ;
    rdfs:domain domain:PerformanceAuthority ;
    rdfs:range xsd:string .

domain:severity
    a rdf:Property ;
    rdfs:label "severity" ;
    rdfs:comment "The architectural severity of hitting this graduation boundary: LOW, MEDIUM, HIGH, CRITICAL." ;
    rdfs:domain domain:GraduationBoundary ;
    rdfs:range xsd:string .

domain:featureFlag
    a rdf:Property ;
    rdfs:label "feature flag" ;
    rdfs:comment "The Cargo feature flag (if any) required to enable this graduation bridge or authority." ;
    rdfs:domain [ owl:unionOf ( domain:GraduationBridgeTrait domain:GraduationSurface ) ] ;
    rdfs:range xsd:string .

domain:associatedConstraintWitnesses
    a rdf:Property ;
    rdfs:label "associated constraint witnesses" ;
    rdfs:comment "Witness markers for constraint families this authority enforces." ;
    rdfs:domain domain:GraduationSurface ;
    rdfs:range domain:WitnessMarker .

# ============================================================================
# GRADUATION DOCUMENTATION PROPERTIES
# ============================================================================

domain:graduationGap
    a rdf:Property ;
    rdfs:label "graduation gap" ;
    rdfs:comment "An identified gap or TODO between wasm4pm-compat structure and wasm4pm engine implementation." ;
    rdfs:domain domain:UngroundedCandidate ;
    rdfs:range xsd:string .

domain:roadmapItem
    a rdf:Property ;
    rdfs:label "roadmap item" ;
    rdfs:comment "A planned graduation surface or authority to be implemented in a future wasm4pm release." ;
    rdfs:domain domain:GraduationSurface ;
    rdfs:range xsd:string .

# ============================================================================
# CLOSED-WORLD STATEMENT
# ============================================================================

<https://wasm4pm-compat.rs/domain/graduation-boundaries>
    skos:note "All graduation boundaries and surfaces enumerated here are exhaustive in the wasm4pm-compat / wasm4pm interface. The six primary graduation reasons (NeedsDiscovery, NeedsConformanceExecution, NeedsReplay, NeedsBenchmarkGating, NeedsObjectCentricQuery, RebuildingProcessMiningLocally) cover the full spectrum of process-mining execution needs. Each graduates to one or more wasm4pm authorities. No graduation boundary exists outside this ontology." .

# ============================================================================
# END OF DOMAIN ONTOLOGY: GRADUATION BOUNDARIES
# ============================================================================
# Domain Ontology: Process Forms
# Defines all process form classes (EventLog, PetriNet, ProcessTree, DFG, OCEL, Declare, etc.)
# and their relationships to standard ontologies (OCEL, XES, BPMN, PM).
#
# Companion to wasm4pm-compat-integrated.ttl

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix domain: <https://wasm4pm-compat.rs/domain#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

# Standard process-mining ontologies
@prefix pm:     <http://www.purl.org/pm/ontology/2023/05#> .
@prefix ocel:   <https://ocel-standard.org/ontology#> .
@prefix xes:    <http://www.xes-standard.org/ontology#> .
@prefix bpmn:   <https://www.omg.org/spec/BPMN/20100524/MODEL#> .

<https://wasm4pm-compat.rs/domain/process-forms>
    a owl:Ontology ;
    rdfs:label "Process Forms Domain Ontology" ;
    rdfs:comment "Domain-specific definitions for all process forms: event logs, Petri nets, process trees, DFGs, OCEL, Declare, BPMN, OCPQ, and object-centric structures. Bridges Rust types to standard process-mining ontologies." ;
    owl:versionInfo "1.0.0" ;
    owl:imports <http://www.purl.org/pm/ontology/2023/05> ;
    owl:imports <https://ocel-standard.org/ontology> ;
    owl:imports <http://www.xes-standard.org/ontology> .

# ============================================================================
# TOP-LEVEL PROCESS FORM CLASS
# ============================================================================

domain:ProcessForm
    a rdfs:Class ;
    rdfs:label "Process Form" ;
    rdfs:comment "A primary process-evidence shape defined in a wasm4pm-compat module. All process forms are structure-only carriers — they hold data shapes and never execute discovery, conformance, or replay. Engine logic graduates to wasm4pm." ;
    owl:equivalentClass compat:ProcessForm .

# ============================================================================
# EVENT LOG PROCESS FORMS
# ============================================================================

domain:EventLog
    a rdfs:Class ;
    rdfs:label "Event Log" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Classic flat event log shape: EventLog, Trace, Event. Builder API: Event::new().at_ns().by().with_lifecycle(). Structure only." ;
    owl:equivalentClass compat:EventLog ;
    skos:exactMatch xes:Log ;
    skos:related ocel:OcelLog ;
    rdfs:comment "A flat sequence of event traces, each trace a sequence of events with attributes and lifecycle states." .

domain:Trace
    a rdfs:Class ;
    rdfs:label "Trace" ;
    rdfs:subClassOf rdf:Seq ;
    rdfs:comment "A sequence of events forming a single process execution instance or case." .

domain:Event
    a rdfs:Class ;
    rdfs:label "Event" ;
    rdfs:comment "An atomic activity occurrence with timestamp, attributes, and optional lifecycle state." ;
    skos:exactMatch xes:Event ;
    skos:related ocel:Event .

domain:OcelLog
    a rdfs:Class ;
    rdfs:label "Object-Centric Event Log" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "OCEL 2.0 object-centric event log shape: OcelLog, OcelEvent, EventObjectLink, ObjectObjectLink, ObjectChange. Builder chains on all link/change types. Structure only." ;
    owl:equivalentClass compat:OcelLog ;
    owl:sameAs ocel:OcelLog ;
    rdfs:comment "Object-centric log with explicit event-to-object and object-to-object relationships, enabling multi-object process analysis." .

domain:OcelEvent
    a rdfs:Class ;
    rdfs:label "OCEL Event" ;
    rdfs:subClassOf domain:Event ;
    owl:sameAs ocel:Event ;
    rdfs:comment "An event in an OCEL log, explicitly linked to one or more business objects." .

domain:EventObjectLink
    a rdfs:Class ;
    rdfs:label "Event-Object Link" ;
    rdfs:comment "Explicit relationship between an event and a business object (many-to-many). Records the type of relationship (e.g., created, updated, consumed)." ;
    owl:sameAs ocel:EventObjectLink .

domain:ObjectObjectLink
    a rdfs:Class ;
    rdfs:label "Object-Object Link" ;
    rdfs:comment "Explicit relationship between two business objects (e.g., parent-child, derived-from, correlated-with)." ;
    owl:sameAs ocel:ObjectObjectLink .

domain:ObjectChange
    a rdfs:Class ;
    rdfs:label "Object Change" ;
    rdfs:comment "A state change to a business object (attribute update, lifecycle transition)." ;
    owl:sameAs ocel:ObjectChange .

domain:XesLog
    a rdfs:Class ;
    rdfs:label "XES Event Log" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "XES (IEEE 1849-2016) event log shape. Import/export contracts, round-trip claims, loss surfaces. Feature: formats." ;
    owl:equivalentClass compat:XesLog ;
    owl:sameAs xes:Log ;
    rdfs:comment "Extensible Event Stream (IEEE 1849-2016) log with extensions for concepts, organization, resources, and lifecycle states." .

domain:StreamingLog
    a rdfs:Class ;
    rdfs:label "Streaming Event Log" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "EventStream append-only buffer for streaming process evidence. Online monitoring and windowed conformance checking graduate to wasm4pm." ;
    owl:equivalentClass compat:StreamingLog ;
    rdfs:comment "A forward-only event stream for online/real-time process monitoring. Events are appended but never modified or deleted." .

# ============================================================================
# PETRI NET AND WORKFLOW NET PROCESS FORMS
# ============================================================================

domain:PetriNet
    a rdfs:Class ;
    rdfs:label "Petri Net" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Petri net shape: PetriNet, Place, Transition, Arc, Marking. Structural validate only. Soundness, reachability, and token-game replay graduate to wasm4pm." ;
    owl:equivalentClass compat:PetriNet ;
    owl:sameAs pm:PetriNet ;
    rdfs:comment "A directed bipartite graph with places (state containers) and transitions (activity occurrences), connected by arcs. Can represent concurrent and synchronization patterns." .

domain:Place
    a rdfs:Class ;
    rdfs:label "Place" ;
    rdfs:comment "A state container in a Petri net. Holds a non-negative integer marking (token count)." ;
    owl:sameAs pm:Place .

domain:Transition
    a rdfs:Class ;
    rdfs:label "Transition" ;
    rdfs:comment "An activity occurrence in a Petri net. Fires when input places have sufficient tokens." ;
    owl:sameAs pm:Transition .

domain:Arc
    a rdfs:Class ;
    rdfs:label "Arc" ;
    rdfs:comment "A directed connection in a Petri net, either place-to-transition or transition-to-place. May have a weight (cardinality)." ;
    owl:sameAs pm:Arc .

domain:Marking
    a rdfs:Class ;
    rdfs:label "Marking" ;
    rdfs:comment "An assignment of tokens to places in a Petri net. Defines the current state." .

domain:WfNet
    a rdfs:Class ;
    rdfs:label "Workflow Net" ;
    rdfs:subClassOf domain:PetriNet ;
    skos:definition "Typed workflow net with const-generic soundness token: SoundnessUnknown (default), SoundnessClaimed, SoundnessWitnessed. Non-forgeable witness path. Soundness verification graduates to wasm4pm." ;
    owl:equivalentClass compat:WfNetConst ;
    owl:sameAs pm:WorkflowNet ;
    rdfs:comment "A Petri net subclass with a unique source and unique sink place, designed to model single-case workflow processes." .

domain:SeparableWfNet
    a rdfs:Class ;
    rdfs:label "Separable Workflow Net" ;
    rdfs:subClassOf domain:WfNet ;
    skos:definition "The separable WF-net subclass (Kourani et al., 2026). Separability is a structural law; conversion to POWL 2.0 preserves language." ;
    owl:equivalentClass compat:SeparableWfNet ;
    rdfs:comment "A WF-net where process structure can be hierarchically decomposed along a process cube without losing soundness." .

domain:ObjectCentricPetriNet
    a rdfs:Class ;
    rdfs:label "Object-Centric Petri Net" ;
    rdfs:subClassOf domain:PetriNet ;
    skos:definition "OC-Petri net shape: typed arcs by object type, variable arcs. Structure only; discovery and replay graduate to wasm4pm." ;
    owl:equivalentClass compat:ObjectCentricPetriNet ;
    rdfs:comment "A Petri net extension where arcs are typed by object type and may be variable (binding multiple objects), enabling object-centric semantics." .

domain:WorkflowNet
    a rdfs:Class ;
    rdfs:label "Workflow Net" ;
    rdfs:subClassOf domain:PetriNet ;
    skos:definition "Workflow net shape. Structural only; YAWL-style routing constructs, multiple-instance tasks. Engine logic graduates to wasm4pm." ;
    owl:equivalentClass compat:WorkflowNet ;
    rdfs:comment "YAWL-style workflow net with cancellation regions and multiple-instance task handling." .

# ============================================================================
# PROCESS DISCOVERY FORMS
# ============================================================================

domain:ProcessTree
    a rdfs:Class ;
    rdfs:label "Process Tree" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Block-structured process tree shape: ProcessTree, ProcessTreeNode, ProcessTreeOperator (sequence, exclusive choice, parallel, loop, silent). TypedLoopNode<ARITY> with Require<{ARITY==2}>: IsTrue. Structure only." ;
    owl:equivalentClass compat:ProcessTree ;
    rdfs:comment "A hierarchical tree model where each non-leaf node represents a composition operator (sequence, choice, parallelism, or loop) and each leaf is an activity." .

domain:ProcessTreeNode
    a rdfs:Class ;
    rdfs:label "Process Tree Node" ;
    rdfs:comment "A node in a process tree, either a leaf (activity) or an internal node with an operator and children." .

domain:ProcessTreeOperator
    a rdfs:Class ;
    rdfs:label "Process Tree Operator" ;
    rdfs:comment "A composition operator at a tree node: sequence (→), exclusive choice (X), parallel (∧), loop (⟲), or silent (τ)." .

domain:PowlNode
    a rdfs:Class ;
    rdfs:label "POWL Node" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "POWL (Partially Ordered Workflow Language) shape: PowlNode, PowlNodeKind (StrictOrder, Loop, XorGateway, SilentTransition, ChoiceGraph). TreeProjectable sealed trait. Structure only." ;
    owl:equivalentClass compat:PowlNode ;
    rdfs:comment "Partially Ordered Workflow Language extending classical block structures with explicit partial ordering relations between activities." .

domain:PowlNodeKind
    a rdfs:Class ;
    rdfs:label "POWL Node Kind" ;
    rdfs:comment "The type of a POWL node: StrictOrder, Loop, XorGateway, SilentTransition, or ChoiceGraph." .

domain:DirectlyFollowsGraph
    a rdfs:Class ;
    rdfs:label "Directly-Follows Graph" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Directly-Follows Graph shape (including OC-DFG). Structure only; DFG mining and filtering graduate to wasm4pm." ;
    owl:equivalentClass compat:DfgShape ;
    owl:sameAs pm:DirectlyFollowsGraph ;
    rdfs:comment "A graph representation where nodes are activities and directed edges represent immediate precedence relationships (one activity directly follows another)." .

domain:CausalNet
    a rdfs:Class ;
    rdfs:label "Causal Net" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Causal net shape. Structure only; Heuristics Miner-style discovery and causal dependency computation graduate to wasm4pm." ;
    owl:equivalentClass compat:CausalNet ;
    rdfs:comment "A process model from Heuristics Miner consisting of nodes (activities) and causal dependencies with frequency and confidence annotations." .

# ============================================================================
# DECLARATIVE AND CONSTRAINT-BASED PROCESS FORMS
# ============================================================================

domain:DeclareModel
    a rdfs:Class ;
    rdfs:label "Declare Model" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Declare constraint model shape: named constraint templates (Response, Precedence, ChainSuccession, etc.) with LTL semantics. Structure only; LTL checking graduates to wasm4pm." ;
    owl:equivalentClass compat:DeclareModel ;
    owl:sameAs pm:DeclareModel ;
    rdfs:comment "A declarative process model using LTL constraint templates. Unlike procedural models, Declare specifies what must/may not happen without explicitly defining control flow." .

domain:OcpqQuery
    a rdfs:Class ;
    rdfs:label "OCPQ Query" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "OCPQ query and result shape: OcpqQuery, OcpqResult, predicate witness markers (EventPredicate, ObjectPredicate, RelationPredicate, TemporalPredicate, CardinalityPredicate, NestedQuery, Constraint), OcpqRefusal. Query execution graduates to wasm4pm." ;
    owl:equivalentClass compat:OcpqQuery ;
    rdfs:comment "Object-Centric Process Querying language for extracting and filtering object-centric process data. Supports rich predicates on events, objects, and relationships." .

# ============================================================================
# BPMN PROCESS FORMS
# ============================================================================

domain:BpmnModel
    a rdfs:Class ;
    rdfs:label "BPMN Model" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "BPMN 2.0 shape: task, gateway (XOR/AND/OR), event, pool, lane, subprocess, message flow. Gateway type as PhantomData witness. Structure only." ;
    owl:equivalentClass compat:BpmnModel ;
    owl:sameAs bpmn:Process ;
    rdfs:comment "Business Process Model and Notation 2.0 model with tasks, gateways, events, and flows organized into pools and lanes." .

domain:BpmnTask
    a rdfs:Class ;
    rdfs:label "BPMN Task" ;
    rdfs:subClassOf owl:Thing ;
    owl:sameAs bpmn:Task ;
    rdfs:comment "An atomic activity in BPMN: user task, service task, script task, business rule task, send task, or receive task." .

domain:BpmnGateway
    a rdfs:Class ;
    rdfs:label "BPMN Gateway" ;
    rdfs:subClassOf owl:Thing ;
    owl:sameAs bpmn:Gateway ;
    rdfs:comment "A control-flow merge/split point: exclusive (XOR), parallel (AND), or inclusive (OR) gateway." .

domain:BpmnEvent
    a rdfs:Class ;
    rdfs:label "BPMN Event" ;
    rdfs:subClassOf owl:Thing ;
    owl:sameAs bpmn:Event ;
    rdfs:comment "A point in a process where something happens: start, intermediate, or end event (message, timer, error, etc.)." .

# ============================================================================
# CONFORMANCE AND ANALYSIS FORMS
# ============================================================================

domain:ConformanceVerdict
    a rdfs:Class ;
    rdfs:label "Conformance Verdict" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Conformance verdict carrier shape: Fitness, Precision, F1 (bounded [0,1] newtypes), Deviation, SyncMove, LogOnlyMove, ModelOnlyMove, ConformanceRefusal. Values computed by wasm4pm engine; this crate holds the shape." ;
    owl:equivalentClass compat:ConformanceVerdict ;
    rdfs:comment "A structured report of conformance metrics (fitness, precision, F1 score) and alignment details (sync moves, model-only, log-only)." .

domain:PredictionTarget
    a rdfs:Class ;
    rdfs:label "Prediction Target" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Predictive process monitoring shape: PredictionTarget structure. Prediction execution and compliance-constraint binding graduate to wasm4pm." ;
    owl:equivalentClass compat:PredictionTarget ;
    rdfs:comment "A structure encoding what to predict in a process instance (next activity, outcome, duration) and how to verify predictions." .

domain:ProcessCube
    a rdfs:Class ;
    rdfs:label "Process Cube" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Process cube framework shape: ProcessCube, CubeDimension, CubeSlice, CubeCell, CubeProjectionWitness, CellComparison. Cube computation graduates to wasm4pm." ;
    owl:equivalentClass compat:ProcessCube ;
    rdfs:comment "A multi-dimensional data structure for process analysis. Dimensions slice event data by case, activity, resource, or time; cells hold process models or metrics." .

domain:TemporalConstraint
    a rdfs:Class ;
    rdfs:label "Temporal Constraint" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Temporal constraint shape for temporal profile conformance checking. Structure only; zeta-value computation graduates to wasm4pm." ;
    owl:equivalentClass compat:TemporalConstraint ;
    rdfs:comment "A constraint on the temporal distance between activity pairs (min/max durations, average duration, statistical distribution)." .

domain:ObjectLifecycle
    a rdfs:Class ;
    rdfs:label "Object Lifecycle" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Object lifecycle shape for object-centric process analysis. Structure only." ;
    owl:equivalentClass compat:ObjectLifecycle ;
    rdfs:comment "The lifecycle of a single business object: creation, state transitions, attributes, relationships to other objects, termination." .

domain:CausalityGraph
    a rdfs:Class ;
    rdfs:label "Causality Graph" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Causality graph shape for cross-object causal ordering. Cycle detection and consistency checking graduate to wasm4pm." ;
    owl:equivalentClass compat:CausalityGraph ;
    rdfs:comment "A directed acyclic graph representing causal dependencies between events across multiple objects, enforcing happens-before consistency." .

# ============================================================================
# MULTI-PERSPECTIVE AND INTEROP FORMS
# ============================================================================

domain:MultiPerspectiveLog
    a rdfs:Class ;
    rdfs:label "Multi-Perspective Process Log" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Multi-perspective process log shape (Mannhardt et al., 2016): control-flow, data, resource, time perspectives. Structure only; alignment cost computation graduates to wasm4pm." ;
    owl:equivalentClass compat:MultiPerspective ;
    rdfs:comment "An event log with multiple orthogonal perspectives: control-flow (activities), data (object attributes), resource (who did it), time (when and how long)." .

domain:CorrelationSchema
    a rdfs:Class ;
    rdfs:label "Correlation Schema" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Cross-log correlation schema shape. Multi-log merging and join execution graduate to wasm4pm." ;
    owl:equivalentClass compat:CorrelationSchema ;
    rdfs:comment "A schema for correlating events across multiple event logs using matching criteria (e.g., case ID, timestamp ranges, attribute values)." .

domain:Receipt
    a rdfs:Class ;
    rdfs:label "Receipt" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Provenance-bearing receipt envelope. Records provenance and the witness a value answered to. Structure only — the natural hand-off shape for graduation." ;
    owl:equivalentClass compat:Receipt ;
    rdfs:comment "An opaque provenance-bearing envelope that records what value was admitted, which witness it satisfied, and the lifecycle state. Natural hand-off to wasm4pm." .

domain:InteropBridge
    a rdfs:Class ;
    rdfs:label "Interop Bridge" ;
    rdfs:subClassOf domain:ProcessForm ;
    skos:definition "Format interop bridge: bridges OCEL, XES, BPMN shapes via named loss surfaces. No route from external format directly to another — must go through admitted compat." ;
    owl:equivalentClass compat:InteropBridge ;
    rdfs:comment "Named projection surfaces between different process data formats, tracking and accounting for all information loss." .

# ============================================================================
# PROCESS FORM LIFECYCLE PROPERTIES
# ============================================================================

domain:formType
    a rdf:Property ;
    rdfs:label "form type" ;
    rdfs:comment "The Rust type name of this process form (e.g., 'EventLog', 'PetriNet', 'ProcessTree')." ;
    rdfs:domain domain:ProcessForm ;
    rdfs:range xsd:string .

domain:graduatesToWasm4pm
    a rdf:Property ;
    rdfs:label "graduates to wasm4pm" ;
    rdfs:comment "Whether engine logic for this process form graduates to the wasm4pm execution engine (true) or is fully expressible as structure-only (false)." ;
    rdfs:domain domain:ProcessForm ;
    rdfs:range xsd:boolean .

domain:graduationReason
    a rdf:Property ;
    rdfs:label "graduation reason" ;
    rdfs:comment "If graduating to wasm4pm, the named reason: NeedsDiscovery, NeedsConformanceExecution, NeedsReplay, etc." ;
    rdfs:domain domain:ProcessForm ;
    rdfs:range xsd:string .

domain:equivalentStandardForm
    a rdf:Property ;
    rdfs:label "equivalent standard form" ;
    rdfs:comment "Links to the equivalent class in a standard ontology (OCEL, XES, BPMN, PM)." ;
    rdfs:domain domain:ProcessForm ;
    rdfs:range owl:Class .

# ============================================================================
# CLOSED-WORLD STATEMENT
# ============================================================================

<https://wasm4pm-compat.rs/domain/process-forms>
    skos:note "All process forms enumerated here are exhaustive in wasm4pm-compat. No process form class exists outside this ontology that is valid. Each form bridges to zero or more standard process-mining ontologies; if a bridge is missing, that interop surface has not been implemented." .

# ============================================================================
# END OF DOMAIN ONTOLOGY: PROCESS FORMS
# ============================================================================
# Domain Ontology: Type Constraints
# Defines compile-time type laws, unbreakable constraints, and nightly Rust feature laws.
# Includes constraint families (Between01, ConditionCell, WorkflowPattern, etc.) and
# compile-fail/compile-pass fixtures that serve as proof gates (ALIVE gates).
#
# Companion to wasm4pm-compat-integrated.ttl

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix domain: <https://wasm4pm-compat.rs/domain#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://wasm4pm-compat.rs/domain/type-constraints>
    a owl:Ontology ;
    rdfs:label "Type Constraints Domain Ontology" ;
    rdfs:comment "Domain-specific definitions for compile-time type constraints, unbreakable laws, and the nightly Rust feature law kernel. Includes constraint families and fixture-backed proof gates." ;
    owl:versionInfo "1.0.0" .

# ============================================================================
# TYPE CONSTRAINT CLASSES
# ============================================================================

domain:TypeConstraint
    a rdfs:Class ;
    rdfs:label "Type Constraint" ;
    rdfs:comment "A compile-time type-level invariant enforced by the nightly law kernel (src/law.rs) or through generic_const_exprs bounds." ;
    owl:equivalentClass compat:TypeConstraint .

domain:CompileTimeConstant
    a rdfs:Class ;
    rdfs:label "Compile-Time Constant" ;
    rdfs:subClassOf domain:TypeConstraint ;
    rdfs:comment "A constraint enforced via Rust const generics and const_expr evaluation at compile time." .

domain:UnbreakableLaw
    a rdfs:Class ;
    rdfs:label "Unbreakable Law" ;
    rdfs:subClassOf domain:TypeConstraint ;
    rdfs:comment "A law that is mathematically or structurally impossible to violate within the type system. Backed by compile-fail fixtures (proof gates)." .

# ============================================================================
# CONSTRAINT FAMILY: Between01
# ============================================================================

domain:Between01Constraint
    a domain:CompileTimeConstant ;
    rdfs:label "Between01<NUM, DEN>" ;
    compat:rustType "Between01<NUM, DEN>" ;
    compat:sourceFile "src/law.rs" ;
    skos:definition "Metrics provably in [0, 1] at the type level. NUM <= DEN must hold at compile time. Between01<2, 1> does not compile." ;
    rdfs:comment "A newtype wrapper for a rational number with a compile-time proof that the value lies in [0, 1]. Used for Fitness, Precision, F1 scores in conformance verdicts." ;
    domain:hasCompileFailLaw domain:Between01ViolationLaw .

domain:FitnessMetric
    a rdfs:Class ;
    rdfs:label "Fitness Metric" ;
    rdfs:subClassOf domain:Between01Constraint ;
    rdfs:comment "Conformance fitness score bounded to [0, 1]. Records the fraction of log traces that can be replayed by the model." .

domain:PrecisionMetric
    a rdfs:Class ;
    rdfs:label "Precision Metric" ;
    rdfs:subClassOf domain:Between01Constraint ;
    rdfs:comment "Conformance precision score bounded to [0, 1]. Records the fraction of model traces that occur in the log." .

domain:F1Metric
    a rdfs:Class ;
    rdfs:label "F1 Metric" ;
    rdfs:subClassOf domain:Between01Constraint ;
    rdfs:comment "Harmonic mean of fitness and precision, bounded to [0, 1]. Balances false positives and false negatives." .

domain:Between01ViolationLaw
    a compat:CompileFailLaw ;
    rdfs:label "Between01 Violation Law" ;
    compat:lawName "Between01Violation" ;
    compat:errorCode "E0080" ;
    skos:definition "Between01<2, 1> does not compile — a metric greater than 1 is inadmissible at the type level." ;
    compat:fixtureFile "tests/ui/compile_fail/between01_violation.rs" ;
    compat:stderrFile "tests/ui/compile_fail/between01_violation.stderr" ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Enforces the mathematical law that a metric value cannot exceed 1 (when expressed as NUM <= DEN)." .

# ============================================================================
# CONSTRAINT FAMILY: ConditionCell<BITS>
# ============================================================================

domain:ConditionCellConstraint
    a domain:CompileTimeConstant ;
    rdfs:label "ConditionCell<BITS>" ;
    compat:rustType "ConditionCell<BITS>" ;
    compat:sourceFile "src/law.rs" ;
    skos:definition "The Need9-means-split law: at most 8 primary condition bits. ConditionCell<9> does not compile. Enforces the Blue River Dam covenant." ;
    rdfs:comment "A constraint-bit container with a maximum of 8 condition bits. Exceeding this limit forces architectural refactoring (the 'Blue River Dam' decision point)." ;
    domain:hasCompileFailLaw domain:ConditionCellOverflowLaw ;
    domain:citesLaw "Blue River Dam covenant" ;
    domain:architecturalImpact "HIGH" .

domain:ConditionCellOverflowLaw
    a compat:CompileFailLaw ;
    rdfs:label "ConditionCell Overflow Law" ;
    compat:lawName "ConditionCellOverflow" ;
    compat:errorCode "E0080" ;
    skos:definition "ConditionCell<9> does not compile — the Need9-means-split law enforced at the type level via generic_const_exprs." ;
    compat:fixtureFile "tests/ui/compile_fail/condition_cell_overflow.rs" ;
    compat:stderrFile "tests/ui/compile_fail/condition_cell_overflow.stderr" ;
    domain:proofGateType "ALIVE" ;
    domain:citedBy domain:ConditionCellConstraint ;
    rdfs:comment "Enforces the architectural decision that more than 8 condition dimensions triggers a process cube split." .

# ============================================================================
# CONSTRAINT FAMILY: Require<{EXPR}>: IsTrue
# ============================================================================

domain:RequireIsTrueConstraint
    a domain:CompileTimeConstant ;
    rdfs:label "Require<{EXPR}>: IsTrue" ;
    compat:rustType "Require<{ EXPR }>" ;
    compat:sourceFile "src/law.rs" ;
    skos:definition "Compile-time must-be-true gate. Any where-bound Require<{EXPR}>: IsTrue becomes a compile error when EXPR evaluates to false. Requires generic_const_exprs." ;
    rdfs:comment "A universal constraint mechanism for encoding compile-time assertions via the generic_const_exprs nightly feature." ;
    domain:requiresNightlyFeature "generic_const_exprs" .

domain:TypedLoopNodeArityConstraint
    a domain:RequireIsTrueConstraint ;
    rdfs:label "TypedLoopNode<ARITY>" ;
    compat:rustType "TypedLoopNode<ARITY>" ;
    compat:sourceFile "src/process_tree.rs" ;
    skos:definition "Loop node in process tree with Require<{ARITY == 2}>: IsTrue constraint. A TypedLoopNode<3> does not compile." ;
    rdfs:comment "Process tree loop nodes must have exactly 2 children (redo body and exit condition). TypedLoopNode<ARITY ≠ 2> is a compile error." .

# ============================================================================
# CONSTRAINT FAMILY: WorkflowPattern (ConstParamTy Enum)
# ============================================================================

domain:WorkflowPatternConstraint
    a domain:CompileTimeConstant ;
    rdfs:label "WorkflowPattern" ;
    compat:rustType "WorkflowPattern" ;
    compat:sourceFile "src/law.rs" ;
    skos:definition "ConstParamTy enum covering 17 of 20 canonical workflow patterns (WP-1 through WP-17). PatternNet<{WorkflowPattern::ParallelSplit}> is a distinct type from PatternNet<{WorkflowPattern::ExclusiveChoice}>." ;
    rdfs:comment "A const-generic type family where each workflow pattern variant produces a different, incompatible type. Prevents pattern-kind confusion at the type level." ;
    domain:coverageCount 17 ;
    domain:coverageOf "Workflow Patterns: The Definitive Guide (Russell, van der Aalst and ter Hofstede, 2016)" .

domain:WorkflowPatternWrongKindLaw
    a compat:CompileFailLaw ;
    rdfs:label "WorkflowPatternWrongKind Law" ;
    compat:lawName "WorkflowPatternWrongKind" ;
    compat:errorCode "E0308" ;
    compat:fixtureFile "tests/ui/compile_fail/workflow_pattern_wrong_kind.rs" ;
    compat:stderrFile "tests/ui/compile_fail/workflow_pattern_wrong_kind.stderr" ;
    skos:definition "A PatternNet<{WorkflowPattern::ParallelSplit}> cannot be used as a PatternNet<{WorkflowPattern::ExclusiveChoice}>. Pattern kind is a sealed type-level law." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Enforces that workflow pattern types are distinct and incompatible, preventing accidental pattern-kind misuse." .

# ============================================================================
# CONSTRAINT FAMILY: Soundness Tokens (WF-Net)
# ============================================================================

domain:SoundnessTokenConstraint
    a domain:CompileTimeConstant ;
    rdfs:label "WF-Net Soundness Token" ;
    compat:sourceFile "src/law.rs" ;
    rdfs:comment "The WfNetConst<SOUNDNESS> type parameter gates the soundness state of a workflow net." .

domain:SoundnessUnknownToken
    a domain:SoundnessTokenConstraint ;
    rdfs:label "SoundnessUnknown" ;
    compat:rustType "SoundnessUnknown" ;
    skos:definition "WF-net soundness token: soundness not yet claimed. Default for newly constructed WfNetConst." ;
    rdfs:comment "Initial soundness state. The WF-net has not been claimed or proven sound." .

domain:SoundnessClaimedToken
    a domain:SoundnessTokenConstraint ;
    rdfs:label "SoundnessClaimed" ;
    compat:rustType "SoundnessClaimed" ;
    skos:definition "WF-net soundness token: soundness asserted by a human/upstream, unproven by this crate." ;
    rdfs:comment "Asserted soundness without proof. Used when soundness is claimed by an external process or domain expert." .

domain:SoundnessWitnessedToken
    a domain:SoundnessTokenConstraint ;
    rdfs:label "SoundnessWitnessed" ;
    compat:rustType "SoundnessWitnessed" ;
    skos:definition "WF-net soundness token: carrying a witness obtained from wasm4pm and re-attached here. Strongest soundness claim representable in this crate." ;
    rdfs:comment "Proven soundness via wasm4pm engine verification. The non-forgeable witness path ensures only wasm4pm can issue this token." .

domain:SoundnessForgedLaw
    a compat:CompileFailLaw ;
    rdfs:label "Soundness Forged Law" ;
    compat:lawName "SoundnessForged" ;
    compat:errorCode "E0277" ;
    compat:sourceFile "src/law.rs" ;
    skos:definition "A SoundnessWitnessed token cannot be forged outside wasm4pm. The non-forgeable witness path on WfNetConst<SOUNDNESS> is enforced structurally." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Ensures that only the wasm4pm engine can issue soundness proofs. Direct construction of SoundnessWitnessed is a compile error." .

# ============================================================================
# UNBREAKABLE LAWS (Compile-Fail Fixtures)
# ============================================================================

domain:UnbreakableLawClass
    a rdfs:Class ;
    rdfs:label "Unbreakable Law" ;
    rdfs:comment "A law backed by a compile-fail fixture (tests/ui/compile_fail/). Violating the law is a compile error." ;
    owl:equivalentClass compat:CompileFailLaw .

domain:WitnessDiscriminationLaw
    a domain:UnbreakableLawClass ;
    rdfs:label "Witness Discrimination Law" ;
    compat:lawName "WitnessDiscrimination" ;
    compat:errorCode "E0308" ;
    skos:definition "Admission<T, W1> cannot be used as Admission<T, W2>. An Ocel20-admitted value is not an Xes1849-admitted value at the type level." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Witnesses are type-level discriminators. Evidence admitted under one witness cannot be coerced to satisfy a different witness." .

domain:RawExportedAsAdmittedLaw
    a domain:UnbreakableLawClass ;
    rdfs:label "Raw Exported As Admitted Law" ;
    compat:lawName "RawEvidenceExportedAsAdmitted" ;
    compat:errorCode "E0308" ;
    skos:definition "Evidence<T, Raw, W> cannot be used where Evidence<T, Admitted, W> is required. The one-way door is enforced by the type system." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Untrusted raw evidence cannot be exported as admitted evidence. The lifecycle state is part of the type signature." .

domain:MissingFinalMarkingLaw
    a domain:UnbreakableLawClass ;
    rdfs:label "Missing Final Marking Law" ;
    compat:lawName "MissingFinalMarking" ;
    compat:errorCode "E0277" ;
    skos:definition "Refusal reason for a WF-net that lacks a proper final marking. Named law must appear in the Refusal<MissingFinalMarking, W> type; bare InvalidInput is forbidden." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Every WF-net refusal must name a specific structural reason. MissingFinalMarking is one canonical reason." .

domain:DanglingEventObjectLinkLaw
    a domain:UnbreakableLawClass ;
    rdfs:label "Dangling Event-Object Link Law" ;
    compat:lawName "DanglingEventObjectLink" ;
    compat:errorCode "E0277" ;
    skos:definition "OCEL event references an object that does not exist in the log. Named refusal law for the OCEL admission boundary." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "OCEL structural law: every event-to-object link must reference an object declared in the log. Missing objects trigger named refusal." .

domain:SealedEvidenceStateLaw
    a domain:UnbreakableLawClass ;
    rdfs:label "Sealed EvidenceState Law" ;
    compat:lawName "SealedEvidenceState" ;
    compat:errorCode "E0277" ;
    skos:definition "A downstream crate cannot implement EvidenceState for a foreign type. The sealed trait enforces that only the seven canonical stages are valid State arguments for Evidence<T, State, W>." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "The lifecycle state trait is sealed. Only the canonical 7 stages (Raw, Parsed, Admitted, Refused, Projected, Exportable, Receipted) implement it." .

# ============================================================================
# COMPILE-PASS SURFACES (Proof Gates for Lawful Paths)
# ============================================================================

domain:CompilePassSurfaceClass
    a rdfs:Class ;
    rdfs:label "Compile-Pass Surface" ;
    rdfs:comment "A lawful path that must compile successfully, backed by a trybuild compile-pass fixture (tests/ui/compile_pass/). Proof gates for open, legal behavior." ;
    owl:equivalentClass compat:CompilePassSurface .

domain:SeparableWfNetMarkerPass
    a domain:CompilePassSurfaceClass ;
    rdfs:label "Separable WF-Net Marker Pass" ;
    compat:fixtureFile "tests/ui/compile_pass/separable_wfnet_marker.rs" ;
    skos:definition "Proves SeparableWfNet<SOUNDNESS> is constructible. The separability subclass is a lawful structural position." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Demonstrates that WF-nets can be marked as separable and successfully used in type-safe process analysis." .

domain:WfNet2PowlWitnessPass
    a domain:CompilePassSurfaceClass ;
    rdfs:label "WF-Net to POWL Witness Pass" ;
    compat:fixtureFile "tests/ui/compile_pass/wfnet2powl_witness.rs" ;
    skos:definition "Proves WfNet2Powl witness is taggable on evidence. The conversion authority is a lawful witness." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Demonstrates that WF-net to POWL conversion can be witnessed and tracked through the evidence system." .

domain:WorkflowPatternConstParamPass
    a domain:CompilePassSurfaceClass ;
    rdfs:label "Workflow Pattern ConstParam Pass" ;
    compat:fixtureFile "tests/ui/compile_pass/workflow_pattern_const_param.rs" ;
    skos:definition "Proves WorkflowPattern ConstParamTy variants compile as distinct const generic arguments." ;
    domain:proofGateType "ALIVE" ;
    rdfs:comment "Demonstrates that workflow pattern discrimination works correctly at the type level." .

# ============================================================================
# PROOF GATE (ALIVE GATE) PROPERTIES
# ============================================================================

domain:proofGateType
    a rdf:Property ;
    rdfs:label "proof gate type" ;
    rdfs:comment "The certification gate this law/surface belongs to: ALIVE (type-law receipt), DEPRECATED, EXPERIMENTAL, or BASELINE." ;
    rdfs:domain [ owl:unionOf ( domain:UnbreakableLawClass domain:CompilePassSurfaceClass ) ] ;
    rdfs:range xsd:string .

domain:hasCompileFailLaw
    a rdf:Property ;
    rdfs:label "has compile-fail law" ;
    rdfs:comment "A specific unbreakable law backed by a compile-fail fixture." ;
    rdfs:domain domain:TypeConstraint ;
    rdfs:range domain:UnbreakableLawClass .

domain:hasCompilePassSurface
    a rdf:Property ;
    rdfs:label "has compile-pass surface" ;
    rdfs:comment "A lawful path backed by a compile-pass fixture." ;
    rdfs:domain domain:TypeConstraint ;
    rdfs:range domain:CompilePassSurfaceClass .

domain:requiresNightlyFeature
    a rdf:Property ;
    rdfs:label "requires nightly feature" ;
    rdfs:comment "The nightly Rust feature required to enforce this constraint (e.g., 'generic_const_exprs', 'adt_const_params')." ;
    rdfs:domain domain:CompileTimeConstant ;
    rdfs:range xsd:string .

domain:citesLaw
    a rdf:Property ;
    rdfs:label "cites law" ;
    rdfs:comment "A named law or covenant this constraint enforces (e.g., 'Blue River Dam covenant')." ;
    rdfs:domain domain:TypeConstraint ;
    rdfs:range xsd:string .

domain:architecturalImpact
    a rdf:Property ;
    rdfs:label "architectural impact" ;
    rdfs:comment "The severity of violating this constraint: LOW, MEDIUM, HIGH, or CRITICAL." ;
    rdfs:domain domain:TypeConstraint ;
    rdfs:range xsd:string .

domain:coverageCount
    a rdf:Property ;
    rdfs:label "coverage count" ;
    rdfs:comment "The number of entities covered by this constraint family." ;
    rdfs:domain domain:TypeConstraint ;
    rdfs:range xsd:integer .

domain:coverageOf
    a rdf:Property ;
    rdfs:label "coverage of" ;
    rdfs:comment "The paper, standard, or authority this constraint covers." ;
    rdfs:domain domain:TypeConstraint ;
    rdfs:range xsd:string .

# ============================================================================
# NIGHTLY FEATURE DECLARATIONS
# ============================================================================

domain:NightlyFeatureSet
    a rdfs:Class ;
    rdfs:label "Nightly Feature Set" ;
    rdfs:comment "The set of nightly Rust features required by wasm4pm-compat." .

domain:RequiredNightlyFeatures
    a domain:NightlyFeatureSet ;
    rdfs:label "Required Nightly Features" ;
    rdfs:comment "The mandatory nightly features declared unconditionally in src/lib.rs" ;
    skos:definition "generic_const_exprs, adt_const_params, const_trait_impl, min_specialization, portable_simd" ;
    rdf:value
        "generic_const_exprs",
        "adt_const_params",
        "const_trait_impl",
        "min_specialization",
        "portable_simd" .

# ============================================================================
# CLOSED-WORLD STATEMENT
# ============================================================================

<https://wasm4pm-compat.rs/domain/type-constraints>
    skos:note "All compile-time type constraints enumerated here are exhaustive in wasm4pm-compat. No constraint exists outside this ontology that is enforceable at the type level. Each constraint is backed by one or more proof gates (compile-fail or compile-pass fixtures) that serve as the ALIVE certification gate." .

# ============================================================================
# END OF DOMAIN ONTOLOGY: TYPE CONSTRAINTS
# ============================================================================
# ggen-substrate.ttl
# Meta-ontology: the wasm4pm-compat ggen substrate describes itself.
#
# This file declares the generation rules, query files, template files,
# and output artifacts as RDF instances. The substrate is self-documenting:
# the same ontology layer that drives artifact generation also records
# exactly how that generation is wired.
#
# Structure only. This ontology carries no engine logic.

@prefix substrate: <https://wasm4pm-compat.rs/substrate#> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# ONTOLOGY HEADER
# ============================================================================

substrate:GgenSubstrate
    a owl:Ontology ;
    rdfs:label "wasm4pm-compat ggen substrate" ;
    rdfs:comment "Meta-ontology: the ggen generation pipeline described as RDF triples. Every rule wiring a query to a template and an output is an instance of substrate:GenerationRule." ;
    owl:versionInfo "26.6.9" .

# ============================================================================
# CLASSES
# ============================================================================

substrate:GenerationRule
    a rdfs:Class ;
    rdfs:label "GenerationRule" ;
    rdfs:comment "A single rule in the ggen pipeline: one SPARQL query file extracts facts, one Tera template renders artifacts, one output path receives the result." .

substrate:QueryFile
    a rdfs:Class ;
    rdfs:label "QueryFile" ;
    rdfs:comment "A SPARQL SELECT or CONSTRUCT query file (.rq) that extracts structured facts from the type-law ontology." .

substrate:TemplateFile
    a rdfs:Class ;
    rdfs:label "TemplateFile" ;
    rdfs:comment "A Tera template file (.tera) that renders one class of artifact from SPARQL query results." .

substrate:OutputArtifact
    a rdfs:Class ;
    rdfs:label "OutputArtifact" ;
    rdfs:comment "A generated file or directory produced by a GenerationRule. May be a single file or a directory of per-instance files." .

substrate:OntologyFile
    a rdfs:Class ;
    rdfs:label "OntologyFile" ;
    rdfs:comment "An RDF/Turtle ontology file (.ttl) that is part of the substrate graph." .

# ============================================================================
# PROPERTIES
# ============================================================================

substrate:query
    a rdf:Property ;
    rdfs:label "query" ;
    rdfs:comment "Path to the SPARQL query file (.rq) used by this GenerationRule, relative to ggen/." ;
    rdfs:domain substrate:GenerationRule ;
    rdfs:range xsd:string .

substrate:template
    a rdf:Property ;
    rdfs:label "template" ;
    rdfs:comment "Path to the Tera template file (.tera) used by this GenerationRule, relative to ggen/." ;
    rdfs:domain substrate:GenerationRule ;
    rdfs:range xsd:string .

substrate:output
    a rdf:Property ;
    rdfs:label "output" ;
    rdfs:comment "Output path for generated artifacts, relative to the repository root." ;
    rdfs:domain substrate:GenerationRule ;
    rdfs:range xsd:string .

substrate:outputIsDirectory
    a rdf:Property ;
    rdfs:label "outputIsDirectory" ;
    rdfs:comment "True if the output path is a directory (one file per result row); false for a single aggregated file." ;
    rdfs:domain substrate:GenerationRule ;
    rdfs:range xsd:boolean .

substrate:description
    a rdf:Property ;
    rdfs:label "description" ;
    rdfs:comment "Human-readable description of what this rule generates and why." ;
    rdfs:domain substrate:GenerationRule ;
    rdfs:range xsd:string .

substrate:filePath
    a rdf:Property ;
    rdfs:label "filePath" ;
    rdfs:comment "Path to this file, relative to ggen/." ;
    rdfs:range xsd:string .

# ============================================================================
# ONTOLOGY FILE INSTANCES
# ============================================================================

substrate:OntologyFile_wasm4pm_compat
    a substrate:OntologyFile ;
    substrate:filePath "ontology/wasm4pm-compat.ttl" ;
    rdfs:label "wasm4pm-compat type-law ontology" ;
    rdfs:comment "Canonical ontology: WitnessMarker, EvidenceState, ProcessForm, TypeConstraint, CompileFailLaw, SourceModule, PaperCoverage, GraduationBoundary instances." .

substrate:OntologyFile_papers
    a substrate:OntologyFile ;
    substrate:filePath "ontology/papers.ttl" ;
    rdfs:label "papers inventory ontology" ;
    rdfs:comment "Academic paper inventory with witness markers and coverage claims for all papers mapped into wasm4pm-compat." .

substrate:OntologyFile_substrate
    a substrate:OntologyFile ;
    substrate:filePath "ontology/ggen-substrate.ttl" ;
    rdfs:label "ggen substrate meta-ontology" ;
    rdfs:comment "This file. Describes the generation rules, query files, template files, and output artifacts as RDF instances." .

# ============================================================================
# QUERY FILE INSTANCES
# ============================================================================

substrate:QueryFile_extract_witnesses
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-witnesses.rq" ;
    rdfs:label "extract-witnesses" ;
    rdfs:comment "SELECT query: extracts all WitnessMarker instances with rustType, key, title, year, and family." .

substrate:QueryFile_extract_compile_fail_laws
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-compile-fail-laws.rq" ;
    rdfs:label "extract-compile-fail-laws" ;
    rdfs:comment "SELECT query: extracts all CompileFailLaw instances with fixture file path and expected rustc error code." .

substrate:QueryFile_extract_process_forms
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-process-forms.rq" ;
    rdfs:label "extract-process-forms" ;
    rdfs:comment "SELECT query: extracts ProcessForm and CompilePassSurface instances for compile-pass fixture generation." .

substrate:QueryFile_extract_source_modules
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-source-modules.rq" ;
    rdfs:label "extract-source-modules" ;
    rdfs:comment "SELECT query: extracts SourceModule instances with file path, primary types, and graduation status." .

substrate:QueryFile_extract_paper_coverage
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-paper-coverage.rq" ;
    rdfs:label "extract-paper-coverage" ;
    rdfs:comment "SELECT query: extracts PaperCoverage records linking papers to their Rust type surfaces." .

substrate:QueryFile_extract_graduation_candidates
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-graduation-candidates.rq" ;
    rdfs:label "extract-graduation-candidates" ;
    rdfs:comment "SELECT query: extracts GraduationBoundary instances naming where structure ends and wasm4pm engine logic begins." .

substrate:QueryFile_extract_states
    a substrate:QueryFile ;
    substrate:filePath "queries/extract-states.rq" ;
    rdfs:label "extract-states" ;
    rdfs:comment "SELECT query: extracts EvidenceState and StateTransition instances for the lifecycle diagram." .

substrate:QueryFile_construct_alive_gate
    a substrate:QueryFile ;
    substrate:filePath "queries/construct-alive-gate.rq" ;
    rdfs:label "construct-alive-gate" ;
    rdfs:comment "CONSTRUCT query: builds the ALIVE gate subgraph linking CompileFailLaw to CompilePassSurface instances." .

# ============================================================================
# TEMPLATE FILE INSTANCES
# ============================================================================

substrate:TemplateFile_witness_marker
    a substrate:TemplateFile ;
    substrate:filePath "templates/witness-marker.tera" ;
    rdfs:label "witness-marker" ;
    rdfs:comment "Renders src/generated/witnesses.rs: one zero-sized marker enum per WitnessMarker instance." .

substrate:TemplateFile_compile_fail_fixture
    a substrate:TemplateFile ;
    substrate:filePath "templates/compile-fail-fixture.tera" ;
    rdfs:label "compile-fail-fixture" ;
    rdfs:comment "Renders one trybuild compile-fail fixture .rs file per CompileFailLaw instance." .

substrate:TemplateFile_compile_pass_fixture
    a substrate:TemplateFile ;
    substrate:filePath "templates/compile-pass-fixture.tera" ;
    rdfs:label "compile-pass-fixture" ;
    rdfs:comment "Renders one trybuild compile-pass fixture .rs file per ProcessForm / CompilePassSurface instance." .

substrate:TemplateFile_audit_script
    a substrate:TemplateFile ;
    substrate:filePath "templates/audit-script.tera" ;
    rdfs:label "audit-script" ;
    rdfs:comment "Renders one shell audit script per SourceModule instance." .

substrate:TemplateFile_module_docs
    a substrate:TemplateFile ;
    substrate:filePath "templates/module-docs.tera" ;
    rdfs:label "module-docs" ;
    rdfs:comment "Renders one Markdown doc page per SourceModule instance." .

substrate:TemplateFile_paper_ledger_row
    a substrate:TemplateFile ;
    substrate:filePath "templates/paper-ledger-row.tera" ;
    rdfs:label "paper-ledger-row" ;
    rdfs:comment "Renders the aggregated PAPER_COVERAGE_LEDGER_GENERATED.md from all PaperCoverage instances." .

substrate:TemplateFile_graduation_boundary_map
    a substrate:TemplateFile ;
    substrate:filePath "templates/graduation-boundary-map.tera" ;
    rdfs:label "graduation-boundary-map" ;
    rdfs:comment "Renders GRADUATION_BOUNDARIES_GENERATED.md from all GraduationBoundary instances." .

substrate:TemplateFile_gap_register_row
    a substrate:TemplateFile ;
    substrate:filePath "templates/gap-register-row.tera" ;
    rdfs:label "gap-register-row" ;
    rdfs:comment "Renders gap register entries (coverage gaps between ontology instances and implemented Rust types)." .

# ============================================================================
# GENERATION RULE INSTANCES
# ============================================================================

substrate:WitnessGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-witnesses.rq" ;
    substrate:template "templates/witness-marker.tera" ;
    substrate:output "src/generated/witnesses.rs" ;
    substrate:outputIsDirectory false ;
    substrate:description "Generate the witnesses.rs module from all WitnessMarker triples in the ontology." ;
    rdfs:label "witness-markers" .

substrate:CompileFailGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-compile-fail-laws.rq" ;
    substrate:template "templates/compile-fail-fixture.tera" ;
    substrate:output "tests/ui/compile_fail/" ;
    substrate:outputIsDirectory true ;
    substrate:description "Generate one trybuild compile-fail fixture per CompileFailLaw instance." ;
    rdfs:label "compile-fail-fixtures" .

substrate:CompilePassGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-process-forms.rq" ;
    substrate:template "templates/compile-pass-fixture.tera" ;
    substrate:output "tests/ui/compile_pass/" ;
    substrate:outputIsDirectory true ;
    substrate:description "Generate one trybuild compile-pass fixture per ProcessForm and CompilePassSurface instance." ;
    rdfs:label "compile-pass-fixtures" .

substrate:AuditScriptGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-source-modules.rq" ;
    substrate:template "templates/audit-script.tera" ;
    substrate:output "scripts/audit/" ;
    substrate:outputIsDirectory true ;
    substrate:description "Generate one shell audit script per SourceModule that checks invariants (doctest coverage, no unsafe, no engine logic)." ;
    rdfs:label "audit-scripts" .

substrate:ModuleDocsGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-source-modules.rq" ;
    substrate:template "templates/module-docs.tera" ;
    substrate:output "docs/generated/" ;
    substrate:outputIsDirectory true ;
    substrate:description "Generate one Markdown doc page per SourceModule." ;
    rdfs:label "module-docs" .

substrate:PaperLedgerGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-paper-coverage.rq" ;
    substrate:template "templates/paper-ledger-row.tera" ;
    substrate:output "docs/PAPER_COVERAGE_LEDGER_GENERATED.md" ;
    substrate:outputIsDirectory false ;
    substrate:description "Generate the paper coverage ledger aggregating all PaperCoverage records." ;
    rdfs:label "paper-ledger" .

substrate:GraduationMapGenRule
    a substrate:GenerationRule ;
    substrate:query "queries/extract-graduation-candidates.rq" ;
    substrate:template "templates/graduation-boundary-map.tera" ;
    substrate:output "docs/GRADUATION_BOUNDARIES_GENERATED.md" ;
    substrate:outputIsDirectory false ;
    substrate:description "Generate the graduation boundary map from all GraduationBoundary instances." ;
    rdfs:label "graduation-map" .
# wasm4pm-compat paper coverage ledger — RDF/Turtle
# Companion ontology to wasm4pm-compat.ttl.
# Sources: docs/PAPER_COVERAGE_LEDGER.md (81 papers as of 2026-05-31)
#
# Each paper instance links a published work to its Rust type surface
# in wasm4pm-compat via coverage verdicts, canon families, and covering modules.
#
# Coverage verdicts:
#   COVERED_BY_TYPE                — Core formal objects reified as Rust types
#   COVERED_BY_FIXTURE             — Covered by compile-pass/fail UI fixtures
#   COVERED_BY_GRADUATION_BOUNDARY — Structure defined; engine logic graduates to wasm4pm
#   PARTIAL_WITH_REASON            — Partially covered; specific gaps noted
#   MISSING_TYPE_LAW               — Canon family present but no Rust type surface yet
#   OUT_OF_SCOPE_WITH_REASON       — No process-mining type-law relevance
#   DUPLICATE_OR_BACKGROUND        — Redundant with another paper

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix paper:  <https://wasm4pm-compat.rs/paper#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://wasm4pm-compat.rs/paper>
    a owl:Ontology ;
    rdfs:label "wasm4pm-compat paper coverage ontology" ;
    rdfs:comment "Maps published process-mining papers to their Rust type-law surface coverage in wasm4pm-compat. Derived from docs/PAPER_COVERAGE_LEDGER.md." ;
    owl:versionInfo "26.6.9" .

# ============================================================================
# ADDITIONAL PROPERTIES (used only in this file)
# ============================================================================

paper:ledgerIndex
    a rdf:Property ;
    rdfs:label "ledgerIndex" ;
    rdfs:comment "The 1-based index number in docs/PAPER_COVERAGE_LEDGER.md." ;
    rdfs:range xsd:integer .

paper:year
    a rdf:Property ;
    rdfs:label "year" ;
    rdfs:comment "Publication year of the paper." ;
    rdfs:range xsd:integer .

paper:authors
    a rdf:Property ;
    rdfs:label "authors" ;
    rdfs:comment "Author string (abbreviated, as in ledger)." ;
    rdfs:range xsd:string .

paper:canonFamily
    a rdf:Property ;
    rdfs:label "canonFamily" ;
    rdfs:comment "Canon family classification: OCEL_OBJECT_CENTRIC, XES_EVENT_LOG, PETRI_NETS, WF_NET_SOUNDNESS, OBJECT_CENTRIC_PETRI, PROCESS_TREES_INDUCTIVE, POWL, DECLARE_CONSTRAINTS, LOG_SKELETON, DFG_OBJECT_CENTRIC, CONFORMANCE_ALIGNMENT, PREDICTION_DRIFT, OCPQ_QUERYING, WORKFLOW_PATTERNS_BPMN, SYSTEMS_API, OUT_OF_SCOPE." ;
    rdfs:range xsd:string .

paper:title
    a rdf:Property ;
    rdfs:label "title" ;
    rdfs:comment "Full paper title." ;
    rdfs:range xsd:string .

paper:missingWork
    a rdf:Property ;
    rdfs:label "missingWork" ;
    rdfs:comment "Specific remaining work needed to complete coverage." ;
    rdfs:range xsd:string .

