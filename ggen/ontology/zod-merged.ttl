# ============================================================================
# WASM4PM GRADUATION SURFACES
# ============================================================================

compat:mining_authority
    a compat:GraduationSurface ;
    a compat:MiningAuthority ;
    rdfs:label "Mining Authority" ;
    compat:rustType "MiningAuthority" ;
    compat:graduatesTo "wasm4pm::mining" ;
    compat:requiresWitness compat:MiningWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, MiningWitness>" ;
    compat:description "Process discovery graduation surface. Handles inductive mining, heuristic mining, alpha mining, variant analysis, and trace abstraction." .

compat:conformance_authority
    a compat:GraduationSurface ;
    a compat:ConformanceAuthority ;
    rdfs:label "Conformance Authority" ;
    compat:rustType "ConformanceAuthority" ;
    compat:graduatesTo "wasm4pm::conformance" ;
    compat:requiresWitness compat:ConformanceWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, ConformanceWitness>" ;
    compat:description "Conformance checking graduation surface. Handles model-to-log alignment, fitness calculation, precision/recall/generalization metrics, and declarative constraint checking." .

compat:replay_authority
    a compat:GraduationSurface ;
    a compat:ReplayAuthority ;
    rdfs:label "Replay Authority" ;
    compat:rustType "ReplayAuthority" ;
    compat:graduatesTo "wasm4pm::replay" ;
    compat:requiresWitness compat:ReplayWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, ReplayWitness>" ;
    compat:description "Token replay and simulation graduation surface. Handles token-based replay, parallel path execution, path finding, and execution profiling." .

compat:lifecycle_authority
    a compat:GraduationSurface ;
    a compat:LifecycleAuthority ;
    rdfs:label "Lifecycle Authority" ;
    compat:rustType "LifecycleAuthority" ;
    compat:graduatesTo "wasm4pm::lifecycle" ;
    compat:requiresWitness compat:LifecycleWitness ;
    compat:evidenceCarrier "Evidence<T, Admitted|Projected, LifecycleWitness>" ;
    compat:description "Object-centric lifecycle graduation surface. Handles OCEL object tracking, state machine execution, artifact provenance, and object lifecycle states." .

# ============================================================================
# END OF ONTOLOGY
# ============================================================================
@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix zod:    <https://wasm4pm-compat.rs/zod#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# Zod Schema Metadata Ontology

zod:hasField a rdf:Property ;
    rdfs:label "hasField" ;
    rdfs:comment "Links a schema to one of its fields." .

zod:fieldName a rdf:Property ;
    rdfs:label "fieldName" ;
    rdfs:range xsd:string .

zod:fieldType a rdf:Property ;
    rdfs:label "fieldType" ;
    rdfs:range xsd:string .

zod:isOptional a rdf:Property ;
    rdfs:label "isOptional" ;
    rdfs:range xsd:boolean .

zod:isArray a rdf:Property ;
    rdfs:label "isArray" ;
    rdfs:range xsd:boolean .

# --- Helper definitions for inner types ---

zod:Event compat:rustType "Event" .
zod:Trace compat:rustType "Trace" .
zod:OcelEvent compat:rustType "OcelEvent" .
zod:OcelObject compat:rustType "OcelObject" .
zod:OcelType compat:rustType "OcelType" .
zod:OcelTypeAttribute compat:rustType "OcelTypeAttribute" .
zod:OcelEventAttribute compat:rustType "OcelEventAttribute" .
zod:OcelRelationship compat:rustType "OcelRelationship" .
zod:OcelObjectAttribute compat:rustType "OcelObjectAttribute" .
zod:OcelAttributeValue compat:rustType "OcelAttributeValue" .
zod:ObjectTypeCardinality compat:rustType "ObjectTypeCardinality" .
zod:Place compat:rustType "Place" .
zod:Transition compat:rustType "Transition" .
zod:Arc compat:rustType "Arc" .
zod:DFG compat:rustType "DFG" .
zod:DFGNode compat:rustType "DFGNode" .
zod:DFGEdge compat:rustType "DFGEdge" .
zod:DeclareModel compat:rustType "DeclareModel" .
zod:DeclareConstraint compat:rustType "DeclareConstraint" .
zod:TokenReplayResult compat:rustType "TokenReplayResult" .
zod:ConformanceResult compat:rustType "ConformanceResult" .
zod:Receipt compat:rustType "Receipt" .
zod:ConformanceVerdict compat:rustType "ConformanceVerdict" .

