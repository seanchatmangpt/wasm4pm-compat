# ============================================================================
# END OF PAPER COVERAGE ONTOLOGY
# ============================================================================
@prefix pi:      <https://wasm4pm.org/process-intelligence#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ============================================================================
# PROCESS INTELLIGENCE ONTOLOGY
# Unified composition of all domain TTLs for wasm4pm-compat.
# This is the single source ontology consumed by every projection manifest
# (ts.projection.yaml, wasm.projection.yaml, component.projection.yaml).
# ============================================================================

<https://wasm4pm.org/process-intelligence>
    a owl:Ontology ;
    dcterms:title "Process Intelligence Ontology" ;
    dcterms:description "Unified process-intelligence ontology for wasm4pm-compat. Composes all domain TTLs into a single queryable graph: process forms, evidence structure, type constraints, graduation boundaries, paper registry, audit machinery, and the ggen substrate. Serves as the source ontology for all three projection manifests (TypeScript, WASM, Component Model)." ;
    dcterms:created "2026-06-02" ;
    dcterms:creator "wasm4pm-compat nightly-foundry" ;
    owl:versionInfo "1.0.0" ;

    owl:imports <domain-process-forms.ttl> ;
    owl:imports <domain-evidence-structure.ttl> ;
    owl:imports <domain-type-constraints.ttl> ;
    owl:imports <domain-graduation-boundaries.ttl> ;
    owl:imports <ggen-substrate.ttl> ;
    owl:imports <papers.ttl> ;
    owl:imports <audit-machinery.ttl> ;
    owl:imports <wasm4pm-compat.ttl> ;
    owl:imports <wasm4pm-compat-integrated.ttl> .

# ============================================================================
# CORE CLASSES
# ============================================================================

pi:ProcessModel
    a owl:Class ;
    rdfs:label "Process Model" ;
    rdfs:comment "A formal representation of a process as understood by process mining. Covers Petri nets, process trees, DFGs, BPMN, Declare, and POWL variants. Structure-only: no execution, discovery, or replay logic resides here — those graduate to wasm4pm." .

pi:EventLog
    a owl:Class ;
    rdfs:label "Event Log" ;
    rdfs:comment "A collection of traces, each trace being an ordered sequence of events attributed to one case. Conforms to the XES 1849 / classic event-log model. The canonical carrier in wasm4pm-compat is eventlog::EventLog." .

pi:Trace
    a owl:Class ;
    rdfs:label "Trace" ;
    rdfs:comment "An ordered sequence of events belonging to a single case (process instance). A trace is the atomic unit of conformance checking. In wasm4pm-compat: eventlog::Trace." .

pi:Activity
    a owl:Class ;
    rdfs:label "Activity" ;
    rdfs:comment "A named action or step recorded in an event. Activity names appear in event logs and are the nodes of process models (DFG, Petri net transitions, process tree tasks). In wasm4pm-compat: the 'activity' field on eventlog::Event." .

pi:Conformance
    a owl:Class ;
    rdfs:label "Conformance" ;
    rdfs:comment "The degree to which an observed event log aligns with a declared process model. Conformance is computed by wasm4pm (engine layer); wasm4pm-compat holds only the result shapes (ConformanceVerdict, QualityMetric)." .

pi:Fitness
    a owl:Class ;
    rdfs:subClassOf pi:Conformance ;
    rdfs:label "Fitness" ;
    rdfs:comment "The fraction of observed behaviour that can be replayed on the process model without deviation. A Metric<Fitness, NUM, DEN> in wasm4pm-compat enforces the Between01 compile-time bound: NUM <= DEN." .

pi:Precision
    a owl:Class ;
    rdfs:subClassOf pi:Conformance ;
    rdfs:label "Precision" ;
    rdfs:comment "The fraction of model-allowed behaviour that actually appears in the log. Complements fitness: a model allowing everything has perfect fitness but zero precision. Represented as Metric<Precision, NUM, DEN> with Between01 bound." .

pi:TypeLawSurface
    a owl:Class ;
    rdfs:label "Type Law Surface" ;
    rdfs:comment "A compile-time enforcement point expressed as a Rust type in wasm4pm-compat. Examples: Assert<{EXPR}>, IsTrue, Require<{EXPR}>, Between01<NUM, DEN>, ConstParamTy enums. Type law surfaces prevent illegal states at compile time — no runtime check needed." .

pi:EvidenceAdmission
    a owl:Class ;
    rdfs:label "Evidence Admission" ;
    rdfs:comment "The act and result of admitting raw evidence through the Admit::admit() gate. Produces Admission<T, W> on success or Refusal<R, W> on failure. The reason type R must name a specific structural law; bare InvalidInput is forbidden." .

pi:GraduationBridge
    a owl:Class ;
    rdfs:label "Graduation Bridge" ;
    rdfs:comment "A boundary marker indicating that a compat evidence shape is ready to graduate to the wasm4pm execution engine. Represented as GraduateToWasm4pm trait and GraduationCandidate in the wasm4pm Cargo feature. Graduation is a one-way signal — there is no downgrade path." .

pi:OcelLog
    a owl:Class ;
    rdfs:subClassOf pi:EventLog ;
    rdfs:label "OCEL Log" ;
    rdfs:comment "An object-centric event log conforming to OCEL 2.0. Events are linked to multiple objects (E2O links); objects are linked to each other (O2O links); objects carry attribute changes over time. In wasm4pm-compat: ocel::OcelLog." .

pi:WitnessMarker
    a owl:Class ;
    rdfs:label "Witness Marker" ;
    rdfs:comment "A zero-sized Rust type (empty enum) implementing the Witness trait. Each witness names a specific paper, standard, or law (e.g. Ocel20, Xes1849, WfNetSoundnessPaper). Prevents mixing evidence admitted under different authorities at the type level." .

pi:LossReport
    a owl:Class ;
    rdfs:label "Loss Report" ;
    rdfs:comment "An audit record of structure lost during a lossy projection. Required on every non-refusing projection path when LossPolicy is AllowNamedProjection or AllowLossWithReport. Silent structure loss is a defect." .

pi:ProjectionManifest
    a owl:Class ;
    rdfs:label "Projection Manifest" ;
    rdfs:comment "A YAML descriptor that declares a named projection from wasm4pm-compat to a target (TypeScript, WASM, Component Model). Each manifest entry must provide: source ontology, query, template, output path, receipt entry, and checkpoint effect." .

# ============================================================================
# PROPERTIES
# ============================================================================

pi:hasTrace
    a owl:ObjectProperty ;
    rdfs:label "has trace" ;
    rdfs:comment "Relates an EventLog to the Trace instances it contains. Ordered; multiplicity 0..*." ;
    rdfs:domain pi:EventLog ;
    rdfs:range pi:Trace .

pi:hasActivity
    a owl:ObjectProperty ;
    rdfs:label "has activity" ;
    rdfs:comment "Relates a Trace or EventLog to Activity instances observed within it. Derived from the activity field on each event." ;
    rdfs:domain pi:Trace ;
    rdfs:range pi:Activity .

pi:hasFitnessScore
    a owl:ObjectProperty ;
    rdfs:label "has fitness score" ;
    rdfs:comment "Relates a Conformance result to its Fitness measurement. The Fitness instance carries a numerator/denominator pair constrained Between01." ;
    rdfs:domain pi:Conformance ;
    rdfs:range pi:Fitness .

pi:hasPrecisionScore
    a owl:ObjectProperty ;
    rdfs:label "has precision score" ;
    rdfs:comment "Relates a Conformance result to its Precision measurement. The Precision instance carries a numerator/denominator pair constrained Between01." ;
    rdfs:domain pi:Conformance ;
    rdfs:range pi:Precision .

pi:hasWitness
    a owl:ObjectProperty ;
    rdfs:label "has witness" ;
    rdfs:comment "Relates an EvidenceAdmission or admitted evidence carrier to the WitnessMarker under whose authority it was admitted. The witness is encoded as a phantom type parameter W in Rust; as metadata string at runtime boundaries." ;
    rdfs:domain pi:EvidenceAdmission ;
    rdfs:range pi:WitnessMarker .

pi:admitsEvidence
    a owl:ObjectProperty ;
    rdfs:label "admits evidence" ;
    rdfs:comment "Relates a TypeLawSurface or admission gate to the EvidenceAdmission it produces. Represents the Admit::admit() call relationship: given raw evidence, the gate produces an admission result." ;
    rdfs:domain pi:TypeLawSurface ;
    rdfs:range pi:EvidenceAdmission .

pi:graduatesTo
    a owl:ObjectProperty ;
    rdfs:label "graduates to" ;
    rdfs:comment "Relates a GraduationBridge to the wasm4pm execution engine target it points toward. Graduation is a one-way signal: compat evidence that has passed all type-law gates is marked ready for engine consumption." ;
    rdfs:domain pi:GraduationBridge ;
    rdfs:range owl:Thing .

pi:hasTypeState
    a owl:DatatypeProperty ;
    rdfs:label "has type state" ;
    rdfs:comment "The lifecycle state tag of an evidence carrier: one of Raw, Parsed, Admitted, Refused, Projected, Exportable, Receipted. Encoded as a phantom type parameter State in Rust; as a string tag at serialization boundaries." ;
    rdfs:domain pi:EvidenceAdmission ;
    rdfs:range xsd:string .

pi:lossPolicyKind
    a owl:DatatypeProperty ;
    rdfs:label "loss policy kind" ;
    rdfs:comment "The kind of LossPolicy applied to a projection: 'RefuseLoss', 'AllowNamedProjection', or 'AllowLossWithReport'. Determines whether a LossReport is required and whether the projection gate may refuse." ;
    rdfs:domain pi:LossReport ;
    rdfs:range xsd:string .

pi:hasLossReport
    a owl:ObjectProperty ;
    rdfs:label "has loss report" ;
    rdfs:comment "Relates a lossy projection result to its LossReport. Present on every non-refusing path where structure is dropped. Absence of this property on a lossy path is a manufacturing defect." ;
    rdfs:domain pi:EvidenceAdmission ;
    rdfs:range pi:LossReport .

pi:coveredByManifest
    a owl:ObjectProperty ;
    rdfs:label "covered by manifest" ;
    rdfs:comment "Relates a projected artifact to the ProjectionManifest that declared it. Every emitted artifact must trace back to exactly one manifest entry; untracked artifacts are unreceipted manufacturing waste." ;
    rdfs:range pi:ProjectionManifest .
# wasm4pm-compat integrated type-law ontology
# Orchestration file with owl:imports statements linking to open-ontologies standards
# and domain-specific RDF definitions.
#
# Generated from: src/witness.rs, src/state.rs, src/evidence.rs, src/admission.rs
# and all src/*.rs modules, PLUS open-ontologies standards for process mining
# and event data interchange.
#
# This ontology maps the Rust type-law surfaces of wasm4pm-compat to RDF triples,
# integrates process-mining domain ontologies from standard URIs, and provides
# unified interop structures. Structure only — this ontology does NOT run engines,
# compute conformance, or replay tokens. Graduate those concerns to wasm4pm.

# ============================================================================
# PREFIX DECLARATIONS
# ============================================================================

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix paper:  <https://wasm4pm-compat.rs/paper#> .
@prefix domain: <https://wasm4pm-compat.rs/domain#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

# Standard process-mining ontologies (open-ontologies URIs)
@prefix pm:     <http://www.purl.org/pm/ontology/2023/05#> .
@prefix ocel:   <https://ocel-standard.org/ontology#> .
@prefix xes:    <http://www.xes-standard.org/ontology#> .
@prefix bpmn:   <https://www.omg.org/spec/BPMN/20100524/MODEL#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ============================================================================
# MAIN ONTOLOGY DEFINITION WITH IMPORTS
# ============================================================================

<https://wasm4pm-compat.rs/ontology>
    a owl:Ontology ;
    rdfs:label "wasm4pm-compat integrated type-law ontology" ;
    rdfs:comment "Machine-readable index of the Rust type-law surfaces in wasm4pm-compat, integrated with open-ontologies standards for process mining, event logs, and object-centric process analysis." ;
    owl:versionInfo "1.0.0" ;
    dcterms:created "2026-06-01"^^xsd:date ;
    dcterms:modified "2026-06-01"^^xsd:date ;
    dcterms:description "A unified RDF ontology bridging Rust type-law enforcement with W3C and industry-standard process-mining data models. Supports OCEL 2.0, XES 1849-2016, BPMN 2.0, Petri nets, POWL, process trees, Declare, and object-centric process mining." ;

    # OWL imports from canonical standard sources
    owl:imports <http://www.purl.org/pm/ontology/2023/05> ;
    owl:imports <https://ocel-standard.org/ontology> ;
    owl:imports <http://www.xes-standard.org/ontology> ;
    owl:imports <https://www.omg.org/spec/BPMN/20100524/MODEL> ;
    owl:imports <http://www.w3.org/ns/prov> ;
    owl:imports <http://www.w3.org/ns/dcat> ;
    owl:imports <http://purl.org/dc/terms/> ;

    # Internal imports (sibling ontology files)
    owl:imports <https://wasm4pm-compat.rs/domain/evidence-structure> ;
    owl:imports <https://wasm4pm-compat.rs/domain/process-forms> ;
    owl:imports <https://wasm4pm-compat.rs/domain/graduation-boundaries> ;
    owl:imports <https://wasm4pm-compat.rs/domain/type-constraints> ;

    # Metadata
    dcterms:creator "wasm4pm-compat contributors" ;
    dcterms:license <https://opensource.org/licenses/Apache-2.0> ;
    dcterms:subject "process mining", "event logs", "object-centric process analysis", "type-law enforcement", "Rust nightly", "zero-cost abstraction" ;
    skos:note "This ontology is part of wasm4pm-compat, a zero-cost Rust nightly crate that enforces process-mining type laws at compile time and exports type-bearing receipts for runtime verification." .


# ============================================================================
# DOMAIN VOCABULARY EXTENSIONS (new definitions specific to wasm4pm-compat)
# ============================================================================

# Type-law evidence classes
domain:Evidence
    a rdfs:Class ;
    rdfs:label "Evidence" ;
    rdfs:comment "A universal carrier type Evidence<T, State, W> that bundles a value T with a lifecycle State tag and a Witness W. All values flow through Evidence with zero runtime cost. The State parameter enforces the one-way-door lifecycle via PhantomData." ;
    rdfs:seeAlso compat:Evidence ;
    owl:equivalentClass compat:Evidence .

domain:WitnessMarker
    a rdfs:Class ;
    rdfs:label "WitnessMarker" ;
    rdfs:comment "A zero-sized compile-time marker that names which standard, paper, API grammar, Rust law, or internal bridge a piece of evidence is admitted against. Witness markers are discriminators: Evidence<T, Admitted, Ocel20> is not Evidence<T, Admitted, Xes1849> at the type level." ;
    rdfs:seeAlso compat:WitnessMarker ;
    owl:equivalentClass compat:WitnessMarker .

domain:LifecycleStage
    a rdfs:Class ;
    rdfs:label "LifecycleStage" ;
    rdfs:comment "One of seven canonical evidence lifecycle stages (Raw, Parsed, Admitted, Refused, Projected, Exportable, Receipted) that implements the sealed EvidenceState trait. The one-way-door lifecycle is encoded as StateTransition triples." ;
    rdfs:seeAlso compat:EvidenceState ;
    owl:equivalentClass compat:EvidenceState .

domain:Admission
    a rdfs:Class ;
    rdfs:label "Admission" ;
    rdfs:comment "A first-class admission verdict: Admission<T, W> proves at the type level that an Admit impl accepted a value against witness W. Only sanctioned path from Raw → Admitted." ;
    rdfs:seeAlso compat:Admission ;
    owl:equivalentClass compat:Admission ;
    rdfs:subClassOf rdf:Statement .

domain:Refusal
    a rdfs:Class ;
    rdfs:label "Refusal" ;
    rdfs:comment "A first-class refusal verdict: Refusal<R, W> carries a specific named reason R (e.g. DanglingEventObjectLink) and witness W. Bare InvalidInput is forbidden. Each reason is a named law that must be unbreakable." ;
    rdfs:seeAlso compat:Refusal ;
    owl:equivalentClass compat:Refusal ;
    rdfs:subClassOf rdf:Statement .

domain:ProcessForm
    a rdfs:Class ;
    rdfs:label "ProcessForm" ;
    rdfs:comment "A primary process-evidence shape (event log, Petri net, process tree, DFG, OCEL, Declare model, etc.) defined in a src module. All process forms are structure-only carriers — they hold data shapes and never execute discovery, conformance, or replay." ;
    rdfs:seeAlso compat:ProcessForm ;
    owl:equivalentClass compat:ProcessForm .

domain:GraduationBoundary
    a rdfs:Class ;
    rdfs:label "GraduationBoundary" ;
    rdfs:comment "A named boundary where wasm4pm-compat structure ends and the wasm4pm execution engine begins. Corresponds to GraduationReason enum variants: NeedsDiscovery, NeedsConformanceExecution, NeedsReplay, NeedsBenchmarkGating, NeedsObjectCentricQuery, RebuildingProcessMiningLocally." ;
    rdfs:seeAlso compat:GraduationBoundary ;
    owl:equivalentClass compat:GraduationBoundary .

# Interop properties connecting to standard ontologies
domain:correspondToOcelStandard
    a rdf:Property ;
    rdfs:label "corresponds to OCEL standard" ;
    rdfs:comment "Links a wasm4pm-compat type to the corresponding OCEL 2.0 (https://ocel-standard.org/) class or property." ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    rdfs:seeAlso ocel: .

domain:correspondToXesStandard
    a rdf:Property ;
    rdfs:label "corresponds to XES standard" ;
    rdfs:comment "Links a wasm4pm-compat type to the corresponding XES (IEEE 1849-2016) class or property." ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    rdfs:seeAlso xes: .

domain:correspondToBpmnStandard
    a rdf:Property ;
    rdfs:label "corresponds to BPMN standard" ;
    rdfs:comment "Links a wasm4pm-compat type to the corresponding BPMN 2.0 element or attribute." ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    rdfs:seeAlso bpmn: .

domain:correspondToProcessMiningOntology
    a rdf:Property ;
    rdfs:label "corresponds to process mining ontology" ;
    rdfs:comment "Links a wasm4pm-compat type to the corresponding concept in the general process-mining ontology (http://www.purl.org/pm/ontology/)." ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    rdfs:seeAlso pm: .

domain:provenance
    a rdf:Property ;
    rdfs:label "provenance" ;
    rdfs:comment "The provenance chain (W3C PROV provenance) of an evidence value or admission result. Links to prov:Entity, prov:Activity, prov:Agent, etc." ;
    rdfs:domain domain:Evidence ;
    rdfs:range prov:Entity ;
    rdfs:seeAlso prov: .

domain:hasCompileFailLaw
    a rdf:Property ;
    rdfs:label "has compile-fail law" ;
    rdfs:comment "A specific law that must be unbreakable at compile time, backed by a trybuild compile-fail fixture (tests/ui/compile_fail/)." ;
    rdfs:domain owl:Thing ;
    rdfs:range compat:CompileFailLaw .

domain:hasCompilePassSurface
    a rdf:Property ;
    rdfs:label "has compile-pass surface" ;
    rdfs:comment "A lawful path that must compile successfully, backed by a trybuild compile-pass fixture (tests/ui/compile_pass/)." ;
    rdfs:domain owl:Thing ;
    rdfs:range compat:CompilePassSurface .

# ============================================================================
# INTEROP BRIDGES TO STANDARD ONTOLOGIES
# ============================================================================

compat:OcelLog
    domain:correspondToOcelStandard ocel:OcelLog ;
    skos:exactMatch ocel:OcelLog ;
    owl:sameAs ocel:OcelLog ;
    rdfs:comment "Maps to OCEL 2.0 standard: the object-centric event log shape with event-to-object and object-to-object relationships." .

compat:EventLog
    domain:correspondToXesStandard xes:Log ;
    skos:broadMatch xes:Log ;
    rdfs:comment "Corresponds to XES (IEEE 1849-2016) event log structure: a collection of traces, each trace being a sequence of events." .

compat:PetriNet
    domain:correspondToProcessMiningOntology pm:PetriNet ;
    skos:exactMatch pm:PetriNet ;
    rdfs:comment "Maps to the general process-mining ontology Petri net class. Includes places, transitions, arcs, and markings." .

compat:BpmnModel
    domain:correspondToBpmnStandard bpmn:Process ;
    skos:exactMatch bpmn:Process ;
    rdfs:comment "Maps to BPMN 2.0 process model. Encompasses tasks, gateways, events, and control flow." .

compat:DeclareModel
    domain:correspondToProcessMiningOntology pm:DeclareModel ;
    skos:broadMatch pm:DeclareModel ;
    rdfs:comment "Corresponds to the general process-mining Declare constraint model structure." .

compat:Receipt
    prov:wasAttributedTo domain:Evidence ;
    rdfs:comment "A provenance-bearing receipt that records evidence admission, witness, and lifecycle stage. Links to W3C PROV for multi-log correlation and causal ordering chains." .

# ============================================================================
# REFERENCE TO EXTERNAL DOMAIN ONTOLOGY FILES
# ============================================================================

<https://wasm4pm-compat.rs/domain/evidence-structure>
    a owl:Ontology ;
    rdfs:label "Evidence Structure Domain Ontology" ;
    rdfs:comment "Domain-specific RDF definitions for evidence types, witness markers, lifecycle stages, and admission/refusal verdicts." ;
    owl:imports <https://wasm4pm-compat.rs/ontology> ;
    dcat:accessURL <file:///Users/sac/wasm4pm-compat/ggen/ontology/domain-evidence-structure.ttl> .

<https://wasm4pm-compat.rs/domain/process-forms>
    a owl:Ontology ;
    rdfs:label "Process Forms Domain Ontology" ;
    rdfs:comment "Domain-specific RDF definitions for all process forms: event logs, Petri nets, process trees, DFGs, OCEL, Declare, BPMN, OCPQ, etc." ;
    owl:imports <https://wasm4pm-compat.rs/ontology> ;
    dcat:accessURL <file:///Users/sac/wasm4pm-compat/ggen/ontology/domain-process-forms.ttl> .

<https://wasm4pm-compat.rs/domain/graduation-boundaries>
    a owl:Ontology ;
    rdfs:label "Graduation Boundaries Domain Ontology" ;
    rdfs:comment "Domain-specific RDF definitions for graduation boundaries and surfaces where wasm4pm-compat graduates to the wasm4pm execution engine." ;
    owl:imports <https://wasm4pm-compat.rs/ontology> ;
    dcat:accessURL <file:///Users/sac/wasm4pm-compat/ggen/ontology/domain-graduation-boundaries.ttl> .

<https://wasm4pm-compat.rs/domain/type-constraints>
    a owl:Ontology ;
    rdfs:label "Type Constraints Domain Ontology" ;
    rdfs:comment "Domain-specific RDF definitions for compile-time type constraints, unbreakable laws, and the nightly Rust feature law kernel." ;
    owl:imports <https://wasm4pm-compat.rs/ontology> ;
    dcat:accessURL <file:///Users/sac/wasm4pm-compat/ggen/ontology/domain-type-constraints.ttl> .

# ============================================================================
# CLOSED-WORLD ANNOTATION
# ============================================================================

<https://wasm4pm-compat.rs/ontology>
    rdfs:comment "Structure-only ontology. This crate defines shapes and type laws only. Engine logic (process discovery, conformance checking, token replay, lifecycle tracking) does not belong here and must graduate to wasm4pm for execution. Queries against this ontology are guaranteed to find no runtime behavior — only type definitions, witness markers, lifecycle stages, and graduation boundaries." ;
    skos:note "Closed-world assumption applies to the RDF model: if a law is not in this ontology, it is not an enforceable type law in wasm4pm-compat." .

# ============================================================================
# END OF INTEGRATED ONTOLOGY
# ============================================================================
# wasm4pm-compat canonical type-law ontology
# Generated from: src/witness.rs, src/state.rs, src/evidence.rs, src/admission.rs
# and all src/*.rs modules.
#
# This ontology maps the Rust type-law surfaces of wasm4pm-compat to RDF triples.
# It is the machine-readable index of:
#   - WitnessMarker instances (every witness from src/witness.rs)
#   - EvidenceState instances (every lifecycle stage from src/state.rs)
#   - ProcessForm instances (every module's primary type)
#   - TypeConstraint instances (compile-time law shapes from src/law.rs)
#   - CompileFailLaw instances (laws that must be unbreakable, each backed by a trybuild fixture)
#   - SourceModule instances (one per src/*.rs file)
#
# Structure only — this ontology does NOT run engines, compute conformance, or
# replay tokens. Graduate those concerns to wasm4pm.

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix paper:  <https://wasm4pm-compat.rs/paper#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

# ============================================================================
# ONTOLOGY HEADER
# ============================================================================

<https://wasm4pm-compat.rs/ontology>
    a owl:Ontology ;
    rdfs:label "wasm4pm-compat type-law ontology" ;
    rdfs:comment "Machine-readable index of the Rust type-law surfaces in the wasm4pm-compat nightly crate." ;
    owl:versionInfo "26.6.9" .

# ============================================================================
# CLASSES
# ============================================================================

compat:WitnessMarker
    a rdfs:Class ;
    rdfs:label "WitnessMarker" ;
    rdfs:comment "A zero-sized marker type (empty Rust enum) that names which standard, paper, API grammar, Rust law, or internal bridge a piece of evidence is admitted against. Witnesses are compile-time tags only — they carry no data and run nothing." .

compat:WitnessFamily
    a rdfs:Class ;
    rdfs:label "WitnessFamily" ;
    rdfs:comment "The family (provenance kind) a WitnessMarker belongs to: Standard, Paper, ApiGrammar, RustLaw, or InternalBridge." .

compat:EvidenceState
    a rdfs:Class ;
    rdfs:label "EvidenceState" ;
    rdfs:comment "A sealed lifecycle stage token used as a PhantomData tag inside Evidence<T, State, W>. The seven canonical stages are Raw, Parsed, Admitted, Refused, Projected, Exportable, Receipted. Only these stages implement the sealed EvidenceState trait." .

compat:StateTransition
    a rdfs:Class ;
    rdfs:label "StateTransition" ;
    rdfs:comment "A zero-sized struct type-level marker asserting which lifecycle crossing is at hand (e.g. RawToParsed, ParsedToAdmitted). Structure-only — names a transition, does not execute it." .

compat:ProcessForm
    a rdfs:Class ;
    rdfs:label "ProcessForm" ;
    rdfs:comment "A primary process-evidence shape defined in a src module: an event log, OCEL log, Petri net, WF-net, process tree, DFG, OCPQ query, etc. Structure-only carriers — they hold data shapes and never execute discovery, conformance, or replay." .

compat:TypeConstraint
    a rdfs:Class ;
    rdfs:label "TypeConstraint" ;
    rdfs:comment "A compile-time type-level invariant enforced by the nightly law kernel (src/law.rs): Between01, WfNetSoundness tokens, ConditionCell<BITS>, Require<{EXPR}>: IsTrue bounds." .

compat:CompileFailLaw
    a rdfs:Class ;
    rdfs:label "CompileFailLaw" ;
    rdfs:comment "A law that must be unbreakable at compile time, backed by a trybuild compile-fail fixture in tests/ui/compile_fail/. Each instance names the law, the expected rustc error code, and the fixture file." .

compat:CompilePassSurface
    a rdfs:Class ;
    rdfs:label "CompilePassSurface" ;
    rdfs:comment "A lawful path that must compile successfully, backed by a trybuild compile-pass fixture in tests/ui/compile_pass/. Each instance names the law and the fixture file." .

compat:SourceModule
    a rdfs:Class ;
    rdfs:label "SourceModule" ;
    rdfs:comment "A Rust source file in src/*.rs. Each instance records the file path, primary type(s) defined, and whether engine logic graduates to wasm4pm." .

compat:PaperCoverage
    a rdfs:Class ;
    rdfs:label "PaperCoverage" ;
    rdfs:comment "A coverage record linking a published paper to its Rust type surface in this crate. See also ggen/ontology/papers.ttl for the full paper inventory." .

compat:GraduationBoundary
    a rdfs:Class ;
    rdfs:label "GraduationBoundary" ;
    rdfs:comment "A named boundary where wasm4pm-compat structure ends and wasm4pm engine logic begins. Corresponds to GraduationReason enum variants in src/graduation.rs." .

compat:GraduationSurface
    a rdfs:Class ;
    rdfs:label "GraduationSurface" ;
    rdfs:comment "A wasm4pm module surface where compat structure graduates to engine logic. Named graduation surfaces (mining, conformance, replay, lifecycle) render Evidence carriers and witness markers." .

compat:MiningAuthority
    a rdfs:Class ;
    rdfs:label "MiningAuthority" ;
    rdfs:comment "Process discovery graduation surface in wasm4pm. Handles discovery algorithms, variant analysis, and trace abstraction." .

compat:ConformanceAuthority
    a rdfs:Class ;
    rdfs:label "ConformanceAuthority" ;
    rdfs:comment "Conformance checking graduation surface in wasm4pm. Handles fitness calculation, model-to-log alignment, and declarative checking." .

compat:ReplayAuthority
    a rdfs:Class ;
    rdfs:label "ReplayAuthority" ;
    rdfs:comment "Token replay and simulation graduation surface in wasm4pm. Handles step-wise execution, path finding, and execution profiling." .

compat:LifecycleAuthority
    a rdfs:Class ;
    rdfs:label "LifecycleAuthority" ;
    rdfs:comment "Object-centric lifecycle graduation surface in wasm4pm. Handles object lifecycle tracking, state transitions, and artifact provenance." .

# ============================================================================
# PROPERTIES
# ============================================================================

compat:rustType
    a rdf:Property ;
    rdfs:label "rustType" ;
    rdfs:comment "The Rust type name (as a string literal) of this entity in the wasm4pm-compat crate." ;
    rdfs:range xsd:string .

compat:sourceFile
    a rdf:Property ;
    rdfs:label "sourceFile" ;
    rdfs:comment "The src/*.rs file path (relative to crate root) where this entity is defined." ;
    rdfs:range xsd:string .

compat:witnessKey
    a rdf:Property ;
    rdfs:label "witnessKey" ;
    rdfs:comment "The stable lowercase machine-facing KEY const of a WitnessMarker (e.g. 'ocel-2.0')." ;
    rdfs:range xsd:string .

compat:witnessTitle
    a rdf:Property ;
    rdfs:label "witnessTitle" ;
    rdfs:comment "The human-facing TITLE const of a WitnessMarker (e.g. 'OCEL 2.0')." ;
    rdfs:range xsd:string .

compat:witnessYear
    a rdf:Property ;
    rdfs:label "witnessYear" ;
    rdfs:comment "The publication year (YEAR const) of a WitnessMarker, if the authority has a dated edition." ;
    rdfs:range xsd:integer .

compat:witnessFamily
    a rdf:Property ;
    rdfs:label "witnessFamily" ;
    rdfs:comment "The WitnessFamily (FAMILY const) of a WitnessMarker: one of Standard, Paper, ApiGrammar, RustLaw, InternalBridge." ;
    rdfs:range compat:WitnessFamily .

compat:paperReference
    a rdf:Property ;
    rdfs:label "paperReference" ;
    rdfs:comment "Cite key for the originating paper (links into ggen/ontology/papers.ttl paper: namespace)." ;
    rdfs:range xsd:string .

compat:coverageStatus
    a rdf:Property ;
    rdfs:label "coverageStatus" ;
    rdfs:comment "Paper coverage verdict: COVERED_BY_TYPE, COVERED_BY_FIXTURE, COVERED_BY_GRADUATION_BOUNDARY, PARTIAL_WITH_REASON, MISSING_TYPE_LAW, OUT_OF_SCOPE_WITH_REASON, DUPLICATE_OR_BACKGROUND." ;
    rdfs:range xsd:string .

compat:lawName
    a rdf:Property ;
    rdfs:label "lawName" ;
    rdfs:comment "The named law a compile-fail fixture enforces (e.g. DanglingEventObjectLink, MissingFinalMarking, WitnessDiscrimination)." ;
    rdfs:range xsd:string .

compat:errorCode
    a rdf:Property ;
    rdfs:label "errorCode" ;
    rdfs:comment "The expected rustc error code for a compile-fail fixture (e.g. E0308, E0277, E0080)." ;
    rdfs:range xsd:string .

compat:fixtureFile
    a rdf:Property ;
    rdfs:label "fixtureFile" ;
    rdfs:comment "Path to the trybuild fixture file (relative to crate root)." ;
    rdfs:range xsd:string .

compat:stderrFile
    a rdf:Property ;
    rdfs:label "stderrFile" ;
