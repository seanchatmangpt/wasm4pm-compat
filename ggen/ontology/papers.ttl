# wasm4pm-compat paper coverage ledger — RDF/Turtle
# Companion ontology to wasm4pm-compat.ttl.
# Sources: docs/PAPER_COVERAGE_LEDGER.md (81 papers as of 2026-05-31)
#
# Each paper instance links a published work to its Rust type surface
# in wasm4pm-compat via coverage verdicts, canon families, and covering modules.
#
# Coverage verdicts:
#   COVERED_BY_TYPE                — Core formal objects reified as Rust types
#   COVERED_BY_FIXTURE             — Covered by compile-pass/fail UI fixtures
#   COVERED_BY_GRADUATION_BOUNDARY — Structure defined; engine logic graduates to wasm4pm
#   PARTIAL_WITH_REASON            — Partially covered; specific gaps noted
#   MISSING_TYPE_LAW               — Canon family present but no Rust type surface yet
#   OUT_OF_SCOPE_WITH_REASON       — No process-mining type-law relevance
#   DUPLICATE_OR_BACKGROUND        — Redundant with another paper

@prefix compat: <https://wasm4pm-compat.rs/ontology#> .
@prefix paper:  <https://wasm4pm-compat.rs/paper#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://wasm4pm-compat.rs/paper>
    a owl:Ontology ;
    rdfs:label "wasm4pm-compat paper coverage ontology" ;
    rdfs:comment "Maps published process-mining papers to their Rust type-law surface coverage in wasm4pm-compat. Derived from docs/PAPER_COVERAGE_LEDGER.md." ;
    owl:versionInfo "26.6.9" .

# ============================================================================
# ADDITIONAL PROPERTIES (used only in this file)
# ============================================================================

paper:ledgerIndex
    a rdf:Property ;
    rdfs:label "ledgerIndex" ;
    rdfs:comment "The 1-based index number in docs/PAPER_COVERAGE_LEDGER.md." ;
    rdfs:range xsd:integer .

paper:year
    a rdf:Property ;
    rdfs:label "year" ;
    rdfs:comment "Publication year of the paper." ;
    rdfs:range xsd:integer .

paper:authors
    a rdf:Property ;
    rdfs:label "authors" ;
    rdfs:comment "Author string (abbreviated, as in ledger)." ;
    rdfs:range xsd:string .

paper:canonFamily
    a rdf:Property ;
    rdfs:label "canonFamily" ;
    rdfs:comment "Canon family classification: OCEL_OBJECT_CENTRIC, XES_EVENT_LOG, PETRI_NETS, WF_NET_SOUNDNESS, OBJECT_CENTRIC_PETRI, PROCESS_TREES_INDUCTIVE, POWL, DECLARE_CONSTRAINTS, LOG_SKELETON, DFG_OBJECT_CENTRIC, CONFORMANCE_ALIGNMENT, PREDICTION_DRIFT, OCPQ_QUERYING, WORKFLOW_PATTERNS_BPMN, SYSTEMS_API, OUT_OF_SCOPE." ;
    rdfs:range xsd:string .

paper:title
    a rdf:Property ;
    rdfs:label "title" ;
    rdfs:comment "Full paper title." ;
    rdfs:range xsd:string .

paper:missingWork
    a rdf:Property ;
    rdfs:label "missingWork" ;
    rdfs:comment "Specific remaining work needed to complete coverage." ;
    rdfs:range xsd:string .

# ============================================================================
# PAPER INSTANCES (selected 30 from the 81-paper ledger)
