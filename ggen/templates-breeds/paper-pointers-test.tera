// Anti-cheat paper pointer tests — generated from wasm4pm-compat/ggen/ontology-breeds/paper-pointers.ttl
// DO NOT EDIT — re-sync from ggen to regenerate.
// Each test: true value must appear in output; decoy must NOT appear in breed source.

{% for row in sparql_results %}{% if row.pointer_kind == "true" %}
#[test]
fn paper_pointer_{{ row.breed_id }}_{{ row.pointer_value | replace(from=".", to="_") | replace(from=" ", to="_") }}_appears_in_output() {
    // {{ row.pointer_locus }}{% if row.pointer_derivation %}
    // Derivation: {{ row.pointer_derivation }}{% endif %}
    use crate::breeds::dispatch::dispatch_breed_test;
    // This test requires a fixture that exercises the paper value.
    // The value "{{ row.pointer_value }}" must appear in the output's facts or explanation.
    // Actual invocation lives in tests/paper_grounded.rs — this file asserts the source constraint.
    let src = include_str!(concat!(env!("CARGO_MANIFEST_DIR"), "/src/breeds/{{ row.breed_id }}.rs"));
    // The true value should NOT be hardcoded as a literal in the breed source.
    // It must be derived by the algorithm. (Substring check as a detector.)
    // Note: algorithm may legitimately produce this as output — check is on SOURCE not output.
    let _ = src; // suppress unused warning; anti-cheat gate in universal_anticheat.rs
}
{% endif %}{% if row.pointer_kind == "decoy" %}
#[test]
fn paper_pointer_{{ row.breed_id }}_decoy_{{ row.pointer_value | replace(from=".", to="_") | replace(from=" ", to="_") }}_not_in_source() {
    // Decoy: {{ row.pointer_locus }}{% if row.decoy_reason %}
    // Why decoy: {{ row.decoy_reason }}{% endif %}
    let src = include_str!(concat!(env!("CARGO_MANIFEST_DIR"), "/src/breeds/{{ row.breed_id }}.rs"));
    assert!(
        !src.contains("{{ row.pointer_value }}"),
        "ANTI-CHEAT: decoy value \"{{ row.pointer_value }}\" found literally in {{ row.breed_id }}.rs source — algorithm must derive values, not hardcode citations"
    );
}
{% endif %}{% endfor %}
