# ── Morphological Analysis — paper pointers ─────────────────────────────────

compat:PP_morph_true_576 a compat:PaperPointer ;
  compat:forBreed compat:Breed_morphological ;
  compat:pointerKind "true" ;
  compat:pointerValue "576" ;
  compat:pointerLocus "Ritchey 2011, Fig 2.1 (Springer)" ;
  compat:pointerDerivation "4×4×3×3×2×2 = 576 field configurations" ;
  compat:outputJsonPath "/facts/morphological:solution_space" .

compat:PP_morph_decoy_36864 a compat:PaperPointer ;
  compat:forBreed compat:Breed_morphological ;
  compat:pointerKind "decoy" ;
  compat:pointerValue "36864" ;
  compat:pointerLocus "Zwicky 1951 (miscited early edition)" ;
  compat:decoyReason "Plausible 2^15 variant a naive agent might cite from a secondary source." .

compat:PP_morph_true_186624 a compat:PaperPointer ;
  compat:forBreed compat:Breed_morphological ;
