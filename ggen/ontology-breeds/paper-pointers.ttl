# ── MYCIN Production Rules — paper pointers ──────────────────────────────────

compat:PP_mycin_true_cf a compat:PaperPointer ;
  compat:forBreed compat:Breed_mycin ;
  compat:pointerKind "true" ;
  compat:pointerValue "0.63" ;
  compat:pointerLocus "Buchanan & Shortliffe 1984, MYCIN CF chain example" ;
  compat:pointerDerivation "rule.certainty(0.9) × min(premise CFs: 0.7) = 0.63" ;
  compat:outputJsonPath "/output/certainty_factor" .

compat:PP_mycin_decoy_09 a compat:PaperPointer ;
  compat:forBreed compat:Breed_mycin ;
  compat:pointerKind "decoy" ;
  compat:pointerValue "0.9" ;
  compat:pointerLocus "Miscited as final CF (it is the rule certainty, not the chain result)" ;
  compat:decoyReason "Naive agents return the rule certainty directly, skipping the min-premise propagation." .
