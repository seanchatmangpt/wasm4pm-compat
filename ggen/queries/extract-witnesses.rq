# SPARQL Query: Extract Witness Markers from wasm4pm-compat ontology
# Purpose: Enumerate all witness marker types with their Rust identifiers, keys, and paper references
# Usage: ggen query extract-witnesses.rq --format json

PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX compat: <https://wasm4pm-compat.rs/ontology#>

SELECT ?marker ?rustType ?key ?paper
WHERE {
  ?marker a compat:WitnessMarker ;
          compat:rustType      ?rustType ;
          compat:witnessKey    ?key .

  OPTIONAL { ?marker compat:paperReference ?paper . }
}
ORDER BY ?rustType
