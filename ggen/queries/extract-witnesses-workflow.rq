PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX compat: <https://wasm4pm-compat.rs/ontology#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>

SELECT ?rustType ?witnessKey ?witnessTitle ?witnessYear ?witnessFamily ?description
       ?categoryId ?categoryLabel ?sourceTtl
WHERE {
  ?marker a compat:WitnessMarker ;
          compat:paperCategory "workflow" ;
          compat:rustType     ?rustType ;
          compat:witnessKey   ?witnessKey ;
          compat:witnessTitle ?witnessTitle .

  OPTIONAL { ?marker compat:witnessYear   ?witnessYear }
  OPTIONAL { ?marker compat:witnessFamily ?witnessFamily }
  OPTIONAL { ?marker compat:description  ?description }

  BIND("workflow" AS ?categoryId)
  BIND("Process Mining/Workflow" AS ?categoryLabel)
  BIND("ontology/witnesses-workflow.ttl" AS ?sourceTtl)
}
ORDER BY ?rustType
