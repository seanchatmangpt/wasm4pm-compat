# SPARQL Query: Select Gap Instances for Ledger Assembly
# Purpose: Extract all Gap instances with their core properties for structured gap facts ledger
# Output: id, name (via category/law), closure condition, status, related commits
# Usage: ggen query select-gap-ledger.rq --format json

PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX audit:  <https://wasm4pm-compat.rs/audit#>
PREFIX compat: <https://wasm4pm-compat.rs/ontology#>
PREFIX prov:   <http://www.w3.org/ns/prov#>

SELECT
  ?gapId
  (SAMPLE(?category) AS ?gapCategory)
  (SAMPLE(?severity) AS ?gapSeverity)
  (SAMPLE(?lawLabel) AS ?relatedLawName)
  (SAMPLE(?remediationText) AS ?remediationPlan)
  (SAMPLE(?openedDate) AS ?gapOpenedDate)
  (GROUP_CONCAT(DISTINCT ?closingCommitHash ; SEPARATOR=", ") AS ?closingCommits)
  (SAMPLE(?closureMethodValue) AS ?closureMethod)
  (SAMPLE(?closureTs) AS ?closureTimestamp)
  (COUNT(DISTINCT ?cc) AS ?relatedCommitCount)
WHERE {
  # Core Gap instance selection
  ?gap a audit:Gap ;
       audit:gapId ?gapId .

  # Gap properties (all optional; may not exist for all gaps)
  OPTIONAL { ?gap audit:gapCategory ?category . }
  OPTIONAL { ?gap audit:gapSeverity ?severity . }
  OPTIONAL { ?gap audit:remediationPlan ?remediationText . }
  OPTIONAL { ?gap audit:gapOpenedDate ?openedDate . }

  # Related law (links to CompileFailLaw, GraduationBoundary, AuditSpec)
  OPTIONAL {
    ?gap audit:relatedLaw ?relatedLaw .
    ?relatedLaw rdfs:label ?lawLabel .
  }

  # Closure claims: link gap to closing commits and closure method
  OPTIONAL {
    ?closureClaim a audit:ClosureClaim ;
                  audit:closesGap ?gap ;
                  audit:closingCommit ?closingCommitHash ;
                  audit:closureMethod ?closureMethodValue ;
                  audit:closureTimestamp ?closureTs .
  }

  # Related commit evidence via closure claims
  OPTIONAL {
    ?closureClaim a audit:ClosureClaim ;
                  audit:closesGap ?gap ;
                  audit:closingCommit ?closingCommitHash .
    ?cc a audit:CommitEvidence ;
        audit:commitHash ?closingCommitHash .
  }
}
GROUP BY ?gapId
ORDER BY ?gapSeverity ?gapId
