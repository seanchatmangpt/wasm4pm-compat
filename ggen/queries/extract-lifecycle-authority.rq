# SPARQL Query: Extract Lifecycle Authority Definitions from wasm4pm-compat ontology
# Purpose: Identify all lifecycle process forms and constraints that graduate to wasm4pm
# engine for object lifecycle tracking, state transitions, and artifact provenance
# Usage: ggen query extract-lifecycle-authority.rq --format json

PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX compat: <https://wasm4pm-compat.rs/ontology#>

SELECT ?authority ?rustType ?sourceFile ?description
WHERE {
  ?authority a compat:ProcessForm ;
             compat:rustType ?rustType ;
             compat:sourceFile ?sourceFile ;
             compat:graduatesToWasm4pm true ;
             rdfs:comment ?description .

  FILTER (
    CONTAINS(?description, "lifecycle") ||
    CONTAINS(?description, "state") ||
    CONTAINS(?description, "transition") ||
    CONTAINS(?description, "artifact") ||
    CONTAINS(?description, "object") ||
    CONTAINS(?description, "provenance") ||
    CONTAINS(?description, "receipt")
  )
}
ORDER BY ?rustType
