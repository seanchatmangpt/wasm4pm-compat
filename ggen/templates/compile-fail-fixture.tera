{# compile-fail-fixture.tera: Renders a compile-fail trybuild fixture for a CompileFailLaw ontology instance. #}
{# Constitutional Equation: tests/ui/compile_fail/<lawName>.rs = mu(wasm4pm-compat.ttl, CompileFailLaw) #}
{# Input variables: #}
{#   lawName         — UpperCamelCase law name, e.g. "CrossWitnessAdmission" #}
{#   errorCode       — rustc error code or pattern, e.g. "E0308" or "[mismatched_types]" #}
{#   witnessA        — first witness type name, e.g. "Ocel20" #}
{#   witnessB        — second witness type name (the wrong one), e.g. "Xes1849" #}
{#   processFormType — optional process form involved, e.g. "OcelLog" #}
{#   description     — one-line description of which law this fixture enforces #}
{#   rustType        — the Rust type whose construction is being attempted #}
//! Law: {{ lawName }} --- {{ description }}
//! Expected: {{ errorCode }}
//!
//! This is a compile-fail trybuild fixture for the ALIVE gate.
//! It MUST fail to compile. If it compiles, the type law is broken.
//!
//! Regenerate with: ggen sync --template compile-fail-fixture.tera
//! Run with: cargo test --test ui_tests -- --ignored

// Auto-generated by ggen from wasm4pm-compat.ttl --- DO NOT EDIT
// Source: wasm4pm-compat.ttl  (CompileFailLaw: {{ lawName }})

{% if processFormType %}
use wasm4pm_compat::{{ processFormType | lower }};
{% endif %}
use wasm4pm_compat::admission::{Admit, Admission};
use wasm4pm_compat::witness::{{ witnessA }};
{% if witnessB and witnessB != witnessA %}
use wasm4pm_compat::witness::{{ witnessB }};
{% endif %}
use wasm4pm_compat::evidence::Evidence;
use wasm4pm_compat::state::Raw;

fn main() {
    // Attempt to violate {{ lawName }}:
    // {{ description }}
    //
    // This combination must NOT compile. The type system enforces
    // that {{ witnessA }} cannot be confused with {% if witnessB %}{{ witnessB }}{% else %}a different authority{% endif %}.

    {% if processFormType and witnessA and witnessB and witnessB != witnessA %}
    // Construct lawful evidence under {{ witnessA }}…
    let raw: Evidence<{{ rustType }}, Raw, {{ witnessA }}> = Evidence::raw(
        {{ rustType }}::default(),
    );
    let admitted: Admission<{{ rustType }}, {{ witnessA }}> =
        {{ rustType }}::admit(raw).expect("lawful admission");

    // Attempt to treat {{ witnessA }}-admitted evidence as {{ witnessB }} — must fail.
    let _wrong: Admission<{{ rustType }}, {{ witnessB }}> = admitted; //~ {{ errorCode }}
    {% else %}
    // Law violation: {{ description }}
    let _: () = enforce_{{ lawName | lower | replace(from="-", to="_") }}(); //~ {{ errorCode }}
    {% endif %}
}
