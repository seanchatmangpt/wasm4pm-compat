#!/usr/bin/env bash
# audit-script.tera: Renders a bash audit script for a SourceModule ontology instance.
# Constitutional Equation: audit/<moduleName>.sh = mu(wasm4pm-compat.ttl, SourceModule)
#
# Input variables:
#   moduleName           — snake_case module name, e.g. "ocel"
#   sourceFile           — relative path, e.g. "src/ocel.rs"
#   rustType             — primary Rust type name, e.g. "OcelLog"
#   graduatesToWasm4pm   — boolean, true if this module graduates
#   laws                 — array of law names this module must satisfy
#
# Auto-generated by ggen from wasm4pm-compat.ttl --- DO NOT EDIT
# Source: wasm4pm-compat.ttl  (SourceModule: {{ moduleName }})
# Regenerate with: ggen sync --template audit-script.tera

{%- set rustType = rustType | default(value=moduleName) -%}
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PASS_COUNT=0
FAIL_COUNT=0

pass() { echo "PASS  $1"; (( PASS_COUNT += 1 )); }
fail() { echo "FAIL  $1"; (( FAIL_COUNT += 1 )); }

echo "=== Audit: {{ moduleName }} ({{ rustType }}) ==="
echo "    Source: {{ sourceFile }}"
echo ""

# -------------------------------------------------------------------------
# CHECK 1: Source module exists
# -------------------------------------------------------------------------
if [[ -f "${REPO_ROOT}/{{ sourceFile }}" ]]; then
    pass "module-exists: {{ sourceFile }} is present"
else
    fail "module-exists: {{ sourceFile }} is MISSING"
fi

# -------------------------------------------------------------------------
# CHECK 2: Module is declared in src/lib.rs (or appropriate root)
# -------------------------------------------------------------------------
if grep -q "mod {{ moduleName }}" "${REPO_ROOT}/src/lib.rs" 2>/dev/null; then
    pass "module-declared: '{{ moduleName }}' found in src/lib.rs"
else
    fail "module-declared: '{{ moduleName }}' NOT found in src/lib.rs"
fi

# -------------------------------------------------------------------------
# CHECK 3: At least one compile-pass fixture covers this module
# -------------------------------------------------------------------------
PASS_FIXTURES=$(find "${REPO_ROOT}/tests/ui/compile_pass" -name "*.rs" \
    -exec grep -l "{{ rustType }}\|{{ moduleName }}" {} \; 2>/dev/null | wc -l | tr -d ' ')
if [[ "${PASS_FIXTURES}" -ge 1 ]]; then
    pass "pass-fixture-exists: ${PASS_FIXTURES} compile-pass fixture(s) cover {{ rustType }}"
else
    fail "pass-fixture-exists: no compile-pass fixture found for {{ rustType }}"
fi

# -------------------------------------------------------------------------
# CHECK 4: At least one compile-fail fixture per declared law
# -------------------------------------------------------------------------
{% set law_list = laws | default(value="") | trim %}
{% if law_list == "" %}
echo "INFO  no laws declared for {{ moduleName }} — skipping per-law fixture check"
{% else %}
{% for law in law_list | split(pat=",") %}
FAIL_FIXTURES_{{ loop.index }}=$(find "${REPO_ROOT}/tests/ui/compile_fail" -name "*.rs" \
    -exec grep -l "{{ law }}" {} \; 2>/dev/null | wc -l | tr -d ' ')
if [[ "${FAIL_FIXTURES_{{ loop.index }}}" -ge 1 ]]; then
    pass "fail-fixture-{{ law }}: ${FAIL_FIXTURES_{{ loop.index }}} fixture(s) found for law {{ law }}"
else
    fail "fail-fixture-{{ law }}: no compile-fail fixture found for law {{ law }}"
fi
{% endfor %}
{% endif %}

# -------------------------------------------------------------------------
# CHECK 5: Rustdoc present (module-level //! comment)
# -------------------------------------------------------------------------
if grep -q "^//!" "${REPO_ROOT}/{{ sourceFile }}" 2>/dev/null; then
    pass "rustdoc-present: //! comment found in {{ sourceFile }}"
else
    fail "rustdoc-present: no //! module-level doc in {{ sourceFile }}"
fi

# -------------------------------------------------------------------------
# CHECK 6: Graduation marker (if graduatesToWasm4pm)
# -------------------------------------------------------------------------
{% if graduatesToWasm4pm %}
if grep -q "GraduateToWasm4pm\|graduation\|wasm4pm" "${REPO_ROOT}/{{ sourceFile }}" 2>/dev/null; then
    pass "graduation-marker: {{ rustType }} references graduation surface in {{ sourceFile }}"
else
    fail "graduation-marker: {{ rustType }} claims graduation but no graduation surface found in {{ sourceFile }}"
fi
{% else %}
echo "INFO  {{ moduleName }} does not graduate to wasm4pm — skipping graduation check"
{% endif %}

# -------------------------------------------------------------------------
# CHECK 7: No forbidden patterns
# -------------------------------------------------------------------------
if grep -qE "unsafe\s*\{" "${REPO_ROOT}/{{ sourceFile }}" 2>/dev/null; then
    fail "no-unsafe: unsafe block found in {{ sourceFile }} — violates #![forbid(unsafe_code)]"
else
    pass "no-unsafe: no unsafe blocks in {{ sourceFile }}"
fi

if grep -q "InvalidInput" "${REPO_ROOT}/{{ sourceFile }}" 2>/dev/null; then
    fail "no-bare-refusal: 'InvalidInput' found in {{ sourceFile }} — refusals must carry named laws"
else
    pass "no-bare-refusal: no bare InvalidInput in {{ sourceFile }}"
fi

# -------------------------------------------------------------------------
# SUMMARY
# -------------------------------------------------------------------------
echo ""
echo "=== {{ moduleName }} audit complete: ${PASS_COUNT} PASS, ${FAIL_COUNT} FAIL ==="

if [[ "${FAIL_COUNT}" -gt 0 ]]; then
    exit 1
fi
