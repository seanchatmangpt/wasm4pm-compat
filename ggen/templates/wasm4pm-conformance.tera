//! Process Conformance Authority Module
//!
//! This module is the wasm4pm graduation surface for model-to-log alignment,
//! fitness calculation, and declarative constraint checking. It wraps the
//! structure-only witness markers from `wasm4pm_compat` with actual conformance
//! checking implementations.
//!
//! # What this IS
//!
//! - A container for conformance checking algorithms (fitness calculation, alignment, etc.)
//! - Token carrier for [`crate::evidence::Evidence<T, State, ConformanceWitness>`]
//! - The graduation boundary where conformance logic executes
//! - A zero-unsafe-code zone (forbid unsafe)
//!
//! # What this is NOT
//!
//! - Not a type-only namespace (actual conformance logic lives here)
//! - Not a witness marker (those stay in wasm4pm-compat)
//! - Not a discovery engine (mining logic goes to mining module)
//!
//! # Graduation Condition
//!
//! A process form graduates to this module when:
//! 1. Its wasm4pm-compat witness is structurally valid
//! 2. A concrete conformance algorithm is ready to implement
//! 3. The algorithm can work with [`Evidence`] carriers and return fitness metrics

use crate::evidence::{Evidence, Admitted, Projected};
use wasm4pm_compat::witness::{Witness, ConformanceWitness};
use std::marker::PhantomData;

/// Conformance authority marker — carries conformance checking semantics.
///
/// All conformance operations are keyed to a [`ConformanceWitness`], which names
/// the conformance algorithm family and its foundational paper.
#[derive(Debug, Clone, Copy)]
pub struct ConformanceAuthority<W: Witness = ConformanceWitness> {
    _witness: PhantomData<W>,
}

impl<W: Witness> ConformanceAuthority<W> {
    /// Create a conformance authority bound to witness `W`.
    pub const fn new() -> Self {
        ConformanceAuthority {
            _witness: PhantomData,
        }
    }

    /// The witness this authority is bound to.
    pub const fn witness_key() -> &'static str {
        W::KEY
    }
}

impl Default for ConformanceAuthority {
    fn default() -> Self {
        Self::new()
    }
}

/// Conformance checking engine trait.
///
/// Implement this trait for each concrete conformance algorithm.
/// The algorithm operates on [`Evidence`] carriers admitted against
/// a conformance witness authority.
pub trait ConformanceEngine<T, M, W: Witness = ConformanceWitness> {
    /// Check conformance between a process model and event log.
    ///
    /// # Arguments
    ///
    /// - `model_evidence`: model evidence admitted against witness `W`
    /// - `log_evidence`: event log evidence admitted against witness `W`
    ///
    /// # Returns
    ///
    /// Fitness and alignment metrics in a projected evidence carrier.
    fn check_conformance(
        &self,
        model_evidence: &Evidence<M, Admitted, W>,
        log_evidence: &Evidence<T, Admitted, W>,
    ) -> Evidence<ConformanceVerdict, Projected, W>;
}

/// Conformance checking verdict.
///
/// Holds the results of a conformance check, including fitness metrics,
/// alignment information, and diagnostic data.
#[derive(Debug, Clone)]
pub struct ConformanceVerdict {
    /// Fitness score (0.0 to 1.0, where 1.0 is perfect conformance)
    pub fitness: f64,
    /// Precision score (0.0 to 1.0)
    pub precision: f64,
    /// Generalization score (0.0 to 1.0)
    pub generalization: f64,
    /// Simplicity score (0.0 to 1.0)
    pub simplicity: f64,
    /// Number of deviations found
    pub deviation_count: usize,
    /// Diagnostic message
    pub message: String,
}

impl ConformanceVerdict {
    /// Create a new conformance verdict.
    pub fn new(
        fitness: f64,
        precision: f64,
        generalization: f64,
        simplicity: f64,
        deviation_count: usize,
    ) -> Self {
        ConformanceVerdict {
            fitness,
            precision,
            generalization,
            simplicity,
            deviation_count,
            message: format!(
                "Fitness: {:.2}, Precision: {:.2}, Generalization: {:.2}, Simplicity: {:.2}",
                fitness, precision, generalization, simplicity
            ),
        }
    }

    /// Check if conformance is satisfactory (fitness >= 0.8).
    pub fn is_satisfactory(&self) -> bool {
        self.fitness >= 0.8
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn conformance_authority_construction() {
        let auth = ConformanceAuthority::<ConformanceWitness>::new();
        assert_eq!(auth.witness_key(), ConformanceWitness::KEY);
    }

    #[test]
    fn conformance_verdict_creation() {
        let verdict = ConformanceVerdict::new(0.85, 0.90, 0.88, 0.92, 5);
        assert!(verdict.is_satisfactory());
        assert_eq!(verdict.deviation_count, 5);
    }

    #[test]
    fn conformance_verdict_unsatisfactory() {
        let verdict = ConformanceVerdict::new(0.70, 0.75, 0.72, 0.80, 15);
        assert!(!verdict.is_satisfactory());
    }
}
