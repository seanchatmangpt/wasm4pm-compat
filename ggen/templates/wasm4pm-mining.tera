//! Process Mining Authority Module
//!
//! This module is the wasm4pm graduation surface for process discovery, variant
//! analysis, and trace abstraction. It wraps the structure-only witness markers
//! from `wasm4pm_compat` with actual mining engine implementations.
//!
//! # What this IS
//!
//! - A container for process discovery engines (inductive miner, heuristic miner, etc.)
//! - Token carrier for [`crate::evidence::Evidence<T, State, MiningWitness>`]
//! - The graduation boundary where mining algorithm logic executes
//! - A zero-unsafe-code zone (forbid unsafe)
//!
//! # What this is NOT
//!
//! - Not a type-only namespace (actual discovery logic lives here)
//! - Not a witness marker (those stay in wasm4pm-compat)
//! - Not a proof gate (fitness/conformance checks go to conformance module)
//!
//! # Graduation Condition
//!
//! A process form graduates to this module when:
//! 1. Its wasm4pm-compat witness is structurally valid
//! 2. A concrete discovery algorithm is ready to implement
//! 3. The algorithm can work with [`Evidence`] carriers

use crate::evidence::{Evidence, Admitted, Projected};
use wasm4pm_compat::witness::{Witness, MiningWitness};
use std::marker::PhantomData;

/// Mining authority marker — carries process discovery semantics.
///
/// All mining operations are keyed to a [`MiningWitness`], which names
/// the discovery algorithm family (inductive, heuristic, alpha, etc.)
/// and its paper reference.
#[derive(Debug, Clone, Copy)]
pub struct MiningAuthority<W: Witness = MiningWitness> {
    _witness: PhantomData<W>,
}

impl<W: Witness> MiningAuthority<W> {
    /// Create a mining authority bound to witness `W`.
    pub const fn new() -> Self {
        MiningAuthority {
            _witness: PhantomData,
        }
    }

    /// The witness this authority is bound to.
    pub const fn witness_key() -> &'static str {
        W::KEY
    }
}

impl Default for MiningAuthority {
    fn default() -> Self {
        Self::new()
    }
}

/// Mining discovery engine trait.
///
/// Implement this trait for each concrete discovery algorithm.
/// The algorithm operates on [`Evidence`] carriers admitted against
/// a mining witness authority.
pub trait DiscoveryEngine<T, W: Witness = MiningWitness> {
    /// Discover a process model from admitted event log evidence.
    ///
    /// # Arguments
    ///
    /// - `evidence`: admitted event log evidence against witness `W`
    ///
    /// # Returns
    ///
    /// A projected evidence carrier holding the discovered process model.
    fn discover(
        &self,
        evidence: &Evidence<T, Admitted, W>,
    ) -> Evidence<ProcessModel, Projected, W>;
}

/// Discovered process model carrier.
///
/// Holds the result of a discovery operation. The actual model type
/// (Petri net, process tree, DFG, etc.) is determined by the witness.
#[derive(Debug, Clone)]
pub struct ProcessModel {
    /// Opaque model representation — shape depends on discovery algorithm
    pub representation: Vec<u8>,
    /// Witness marker for this model's authority
    pub authority: String,
}

impl ProcessModel {
    /// Create a new process model.
    pub fn new(representation: Vec<u8>, authority: String) -> Self {
        ProcessModel {
            representation,
            authority,
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn mining_authority_construction() {
        let auth = MiningAuthority::<MiningWitness>::new();
        assert_eq!(auth.witness_key(), MiningWitness::KEY);
    }

    #[test]
    fn process_model_creation() {
        let model = ProcessModel::new(vec![1, 2, 3], "test-witness".to_string());
        assert_eq!(model.representation.len(), 3);
        assert_eq!(model.authority, "test-witness");
    }
}
