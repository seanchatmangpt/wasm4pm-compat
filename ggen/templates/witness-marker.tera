{# witness-marker.tera — Constitutional Equation: witnesses.rs = mu(wasm4pm-compat.ttl, WitnessMarker*) #}
{# Generates idiomatic witness_marker!() calls — indistinguishable from hand-written code.  #}
{# There is no "generated" folder. This IS the source. The ontology is the spec; this is compiled output. #}
{# #}
{# Input variables (from SPARQL): #}
{#   rustType      — CamelCase Rust name, e.g. "Ocel20"                          #}
{#   witnessKey    — stable lowercase key, e.g. "ocel-2.0"                       #}
{#   witnessTitle  — human-facing title, e.g. "OCEL 2.0"                         #}
{#   witnessYear   — Option<u16>, e.g. "2023" or "" (empty = None)               #}
{#   witnessFamily — URI, e.g. "https://wasm4pm-compat.rs/ontology#Paper"        #}
{#   description   — one-line doc string                                          #}
//! Witness marker declarations — compiled from `wasm4pm-compat.ttl`.
//!
//! Every entry here is derived from a `compat:WitnessMarker` instance in the ontology.
//! To add a witness: declare it in the TTL, run `ggen sync`, this file updates.
//! To change a witness: change the TTL, run `ggen sync`.
//! This file and `witness.rs` are the same kind of source — one happens to be compiled
//! from the ontology, one defines the trait. Neither is second-class.

use crate::witness::WitnessFamily;

{% for row in sparql_results %}
witness_marker!(
    /// {{ row.description }}
    {{ row.rustType }},
    "{{ row.witnessKey }}",
    WitnessFamily::{{ row.witnessFamily | split(pat="#") | last }},
    "{{ row.witnessTitle }}",
    {% if row.witnessYear %}Some({{ row.witnessYear }}){% else %}None{% endif %}
);
{% endfor %}
