/// Metadata for a witness authority.
///
/// Provides human-readable information about a witness (e.g., OCEL 2.0, XES 1.849).
/// Used to populate TypeScript witness registries on the host side.
#[derive(Debug, Clone, Serialize, Deserialize)]
{% if wasm_feature_enabled %}
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), derive(Tsify))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), tsify(into_wasm_abi, from_wasm_abi))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), wasm_bindgen)]
{% endif %}
pub struct WitnessInfoWasm {
    /// Stable machine key (e.g., "ocel-2.0", "xes-1849").
    pub key: String,
    /// Human-readable title (e.g., "OCEL 2.0").
    pub title: String,
    /// Year of publication (if applicable).
    pub year: Option<u16>,
    /// Family of witness (Standard, Paper, ApiGrammar, RustLaw, InternalBridge).
    pub family: String,
}

/// Get witness metadata by key.
///
/// Returns metadata for a named witness authority, or None if unknown.
/// Used to populate TypeScript interfaces for refusal diagnostics.
///
/// # Examples
///
/// ```ignore
/// let ocel_info = get_witness_info("ocel-2.0");
/// assert_eq!(ocel_info.unwrap().title, "OCEL 2.0");
/// ```
#[cfg(all(target_arch = "wasm32", feature = "wasm"))]
#[wasm_bindgen]
pub fn get_witness_info(key: &str) -> Option<WitnessInfoWasm> {
    // Registry of all witnesses. Update this with every new witness marker.
    {%- for witness in witnessGates %}
    if key == "{{ witness.key }}" {
        return Some(WitnessInfoWasm {
            key: "{{ witness.key }}".to_string(),
            title: "{{ witness.title }}".to_string(),
            year: {% if witness.year %}Some({{ witness.year }}){% else %}None{% endif %},
            family: "{{ witness.family }}".to_string(),
        });
    }
    {%- endfor %}
    None
}

