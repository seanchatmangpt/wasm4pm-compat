/// Loss policy at WASM boundary.
///
/// Encodes all valid loss decisions in concrete (non-generic) variants.
/// The policy determines how lossy projections behave:
/// - `RefuseLoss`: Abort if any loss would occur.
/// - `AllowNamed`: Allow loss; project is named in the report.
/// - `AllowWithReport`: Allow loss; detailed LossReport is mandatory.
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
#[serde(tag = "kind", rename_all = "snake_case")]
{% if wasm_feature_enabled %}
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), derive(Tsify))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), tsify(into_wasm_abi, from_wasm_abi))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), wasm_bindgen)]
{% endif %}
pub enum LossPolicyWasm {
    /// Refuse any lossy transformation. Return Err if structure would be lost.
    #[serde(rename = "RefuseLoss")]
    RefuseLoss,

    /// Allow loss under a named projection. The name appears in LossReport.
    #[serde(rename = "AllowNamed")]
    AllowNamed {
        /// Name of the projection (e.g., "ocel_to_xes").
        name: String,
    },

    /// Allow loss with a detailed report. Every lossy operation emits LossReport.
    #[serde(rename = "AllowWithReport")]
    AllowWithReport,
}

impl LossPolicyWasm {
    /// Whether this policy refuses loss outright.
    #[must_use]
    pub fn is_refusing(&self) -> bool {
        matches!(self, LossPolicyWasm::RefuseLoss)
    }

    /// Whether this policy allows named projections.
    #[must_use]
    pub fn is_named(&self) -> bool {
        matches!(self, LossPolicyWasm::AllowNamed { .. })
    }

    /// Whether this policy requires detailed loss reports.
    #[must_use]
    pub fn is_reporting(&self) -> bool {
        matches!(self, LossPolicyWasm::AllowWithReport)
    }
}

