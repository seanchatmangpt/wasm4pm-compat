#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_loss_policy_predicates() {
        let refuse = LossPolicyWasm::RefuseLoss;
        assert!(refuse.is_refusing());
        assert!(!refuse.is_named());
        assert!(!refuse.is_reporting());

        let named = LossPolicyWasm::AllowNamed {
            name: "test".to_string(),
        };
        assert!(!named.is_refusing());
        assert!(named.is_named());
        assert!(!named.is_reporting());

        let report = LossPolicyWasm::AllowWithReport;
        assert!(!report.is_refusing());
        assert!(!report.is_named());
        assert!(report.is_reporting());
    }

    #[test]
    fn test_witness_info_lookup() {
        let info = get_witness_info("ocel-2.0");
        assert!(info.is_some());
        let info = info.unwrap();
        assert_eq!(info.key, "ocel-2.0");
        assert_eq!(info.title, "OCEL 2.0");
    }
}

//! ✅ WASM Boundary Module Complete
//!
//! # Quality Gates Enforced by This Boundary
//!
//! 1. **ABI Safety**: All exports must compile on wasm32-unknown-unknown target
//! 2. **No Generics**: No generic type parameters on #[wasm_bindgen] items
//! 3. **Serialize + Deserialize**: All exported types must implement both
//! 4. **Tsify Derives**: All exported types must derive Tsify for .d.ts generation
//! 5. **No PhantomData**: Zero-sized types not transmitted across ABI
//! 6. **Typed Refusals**: All Result<T, E> errors are RefusalSnapshot, not strings
//! 7. **Loss Accounting**: All lossy operations emit LossReport
//! 8. **No Engine Logic**: No discovery, replay, conformance, alignment, OCPQ, receipts
//! 9. **State Purity**: All functions are pure; no mutable state across calls
//! 10. **Witness Metadata**: All refusals include witness_key: String
//!
//! # Graduation Covenant
//!
//! **Compat carries the evidence. `wasm4pm` adjudicates it.**
//!
//! When a host hits a capability wall:
//! - Needs *discovery* → GraduationCandidate(NeedsDiscovery)
//! - Needs *conformance* → GraduationCandidate(NeedsConformanceExecution)
//! - Needs *replay* → GraduationCandidate(NeedsReplay)
//! - Needs *receipts* → GraduationCandidate(NeedsReceipts)
//! - Needs *OCPQ* → GraduationCandidate(NeedsObjectCentricQueryExecution)
//! - Needs *benchmarking* → GraduationCandidate(NeedsBenchmarkGate)
//!
//! Do NOT add engine logic here. Graduate instead.
