{% if formatConversions %}
/// Project OCEL → XES with mandatory loss accounting.
///
/// Converts object-centric event log to single-perspective XES.
/// Always produces a LossReport documenting structure lost (object-centric
/// dimensions, O2O links, etc.).
///
/// # Loss Behavior
///
/// - `LossPolicyWasm::RefuseLoss`: Returns error if any loss would occur.
/// - `LossPolicyWasm::AllowNamed`: Allows loss; includes in LossReport.
/// - `LossPolicyWasm::AllowWithReport`: Allows loss; detailed items listed.
///
/// # ABI Safety
///
/// - No state mutation; all context passed as arguments
/// - LossReport always present in success case
/// - Refusal is a concrete enum, not a string
///
/// # Examples
///
/// ```ignore
/// let policy = LossPolicyWasm::AllowWithReport;
/// match project_ocel_to_xes(&ocel_log, policy) {
///     Ok(outcome) => {
///         console.log("Items lost:", outcome.loss_report.items_lost);
///     }
///     Err(refusal) => console.error("Projection refused:", refusal.reason),
/// }
/// ```
#[cfg(all(target_arch = "wasm32", feature = "wasm", feature = "formats"))]
#[wasm_bindgen]
pub fn project_ocel_to_xes(
    admitted: &AdmittedOcelLog,
    policy: LossPolicyWasm,
) -> Result<ProjectionOutcome, RefusalSnapshot> {
    if policy.is_refusing() {
        // TODO: Check if projection would cause loss. If so, refuse.
        return Err(RefusalSnapshot {
            reason: "ProjectionWouldCauseLoss".to_string(),
            witness_key: "ocel-2.0".to_string(),
            detail: "Projection to XES would lose object-centric structure; RefuseLoss policy in effect".to_string(),
        });
    }

    // Projection allowed; generate loss report.
    let loss_report = LossReportWasm {
        from_format: "ocel-2.0".to_string(),
        to_format: "xes-1849".to_string(),
        items_lost: vec![
            "event-object links".to_string(),
            "object-object links".to_string(),
            "object changes".to_string(),
            "object types".to_string(),
        ],
        summary: "OCEL → XES: All object-centric dimensions lost; single-perspective trace view only".to_string(),
    };

    // TODO: Implement actual projection.
    Ok(ProjectionOutcome {
        output: "{}".to_string(), // Placeholder serialized XES
        loss_report,
        output_witness: "xes-1849".to_string(),
    })
}
{% endif %}

