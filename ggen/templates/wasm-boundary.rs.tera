/// Admit a raw EventLog to the compat layer.
///
/// Parses, validates, and returns either an admitted log or a refusal
/// with a named law explaining why admission failed.
///
/// # ABI Safety
///
/// - Input: `EventLog` (Serialize + Deserialize + Tsify)
/// - Output: `Result<AdmittedEventLog, RefusalSnapshot>`
/// - No generics, no PhantomData, no state mutations
///
/// # Examples
///
/// ```ignore
/// let raw = EventLog { traces: vec![...], ... };
/// match admit_event_log(&raw) {
///     Ok(admitted) => console.log("Admitted:", admitted.value),
///     Err(refusal) => console.error("Refusal:", refusal.reason),
/// }
/// ```
#[cfg(all(target_arch = "wasm32", feature = "wasm"))]
#[wasm_bindgen]
pub fn admit_event_log(raw: &EventLog) -> Result<AdmittedEventLog, RefusalSnapshot> {
    // Admit the event log.
    match raw.validate() {
        Ok(_) => Ok(AdmittedEventLog {
            value: raw.clone(),
        }),
        Err(refusal_reason) => Err(RefusalSnapshot {
            reason: format!("{:?}", refusal_reason),
            witness_key: "eventlog".to_string(),
            detail: "Event log failed structural validation".to_string(),
        }),
    }
}

/// Admit a raw OCEL log to the compat layer.
///
/// Validates object-centric structure: events, objects, E2O/O2O links.
/// Returns admitted log or refusal with specific structural law name.
///
/// # ABI Safety
///
/// - Input: `OcelLog` (Serialize + Deserialize + Tsify)
/// - Output: `Result<AdmittedOcelLog, RefusalSnapshot>`
/// - Witness always "ocel-2.0"
///
/// # Examples
///
/// ```ignore
/// let ocel = OcelLog { events: vec![...], objects: vec![...], ... };
/// match admit_ocel_log(&ocel) {
///     Ok(admitted) => console.log("OCEL admitted"),
///     Err(refusal) => {
///         if refusal.reason.contains("DanglingEventObjectLink") {
///             console.error("E2O link validation failed");
///         }
///     }
/// }
/// ```
#[cfg(all(target_arch = "wasm32", feature = "wasm"))]
#[wasm_bindgen]
pub fn admit_ocel_log(raw: &OcelLog) -> Result<AdmittedOcelLog, RefusalSnapshot> {
    match raw.validate() {
        Ok(_) => Ok(AdmittedOcelLog {
            value: raw.clone(),
            witness_key: "ocel-2.0".to_string(),
        }),
        Err(refusal_reason) => Err(RefusalSnapshot {
            reason: format!("{:?}", refusal_reason),
            witness_key: "ocel-2.0".to_string(),
            detail: "OCEL structure validation failed".to_string(),
        }),
    }
}

