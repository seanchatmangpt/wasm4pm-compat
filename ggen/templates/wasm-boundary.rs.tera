#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), tsify(into_wasm_abi, from_wasm_abi))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), wasm_bindgen)]
{% endif %}
pub struct LossReportWasm {
    /// Source format (e.g., "ocel-2.0").
    pub from_format: String,
    /// Target format (e.g., "xes-1849").
    pub to_format: String,
    /// Items that were lost (e.g., "event-object links", "object changes").
    pub items_lost: Vec<String>,
    /// Human-readable summary of the loss.
    pub summary: String,
}

/// Result of a lossy projection at WASM boundary.
///
/// Bundles the projected output with mandatory loss accounting.
#[derive(Debug, Clone, Serialize, Deserialize)]
{% if wasm_feature_enabled %}
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), derive(Tsify))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), tsify(into_wasm_abi, from_wasm_abi))]
#[cfg_attr(all(target_arch = "wasm32", feature = "wasm"), wasm_bindgen)]
{% endif %}
pub struct ProjectionOutcome {
    /// The projected log (format converted, structure simplified).
    pub output: String,  // Serialized target format
    /// Mandatory loss report documenting structure changes.
    pub loss_report: LossReportWasm,
    /// Witness tag of the output format.
    pub output_witness: String,
}

