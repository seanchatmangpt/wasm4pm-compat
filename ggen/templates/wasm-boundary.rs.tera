// The following patterns are explicitly FORBIDDEN and will cause compile errors
// if anyone tries to add them. This is enforced via the ggen template.

// FORBID: discovery functions (Alpha, Inductive Miner, etc.)
// Example (DO NOT USE):
//   pub fn discover_petri_net(log: &EventLog) -> PetriNet { }
// Reason: NP-hard algorithmic work; graduate to wasm4pm

// FORBID: token replay / conformance execution
// Example (DO NOT USE):
//   pub fn replay_log_on_model(log: &EventLog, model: &Model) -> ReplayResult { }
// Reason: State-mutating simulation; belongs in wasm4pm

// FORBID: alignment computation
// Example (DO NOT USE):
//   pub fn compute_optimal_alignment(trace: &Trace, model: &Model) -> Alignment { }
// Reason: Exponential complexity; graduate to wasm4pm

// FORBID: OCPQ query execution
// Example (DO NOT USE):
//   pub fn execute_ocpq(log: &OcelLog, query: &OcpqQuery) -> QueryResult { }
// Reason: Algorithmic complexity; graduate to wasm4pm

// FORBID: Receipt minting
// Example (DO NOT USE):
//   pub fn mint_receipt(evidence: &Evidence<_, Admitted, _>, prev: &Receipt) -> Receipt { }
// Reason: Cryptographic commitment; graduate to wasm4pm

// FORBID: Benchmark gate execution
// Example (DO NOT USE):
//   pub fn run_benchmark_gate(candidate: &GraduationCandidate, threshold: u32) -> bool { }
// Reason: Requires measured execution; graduate to wasm4pm

// FORBID: Generic Evidence/Admission/Refusal at boundary
// Example (DO NOT USE):
//   #[wasm_bindgen]
//   pub struct Evidence<T, State, W> { ... }
// Reason: wasm-bindgen forbids generics; use concrete wrappers instead

// FORBID: PhantomData fields in exports
// Example (DO NOT USE):
//   pub struct Exported { phantom: PhantomData<SomeType> }
// Reason: Zero-sized types cannot serialize across ABI

// ============================================================================
// SECTION 8: RECEIPT & QUALITY GATES
// ============================================================================

/// Receipt documenting the WASM boundary manufacturing.
///
/// This struct is metadata-only and does not participate in exports;
/// it is used by CI/CD to verify the boundary meets covenant requirements.
pub struct WasmBoundaryReceipt {
    /// Version of wasm4pm-compat this boundary was built from.
    pub crate_version: String,
    /// Timestamp when the boundary was manufactured.
    pub generated_at: String,
    /// Number of admission gates exported.
    pub num_admission_gates: usize,
    /// Number of lossy projections exported.
    pub num_lossy_projections: usize,
    /// Number of witness metadata entries.
    pub num_witnesses: usize,
    /// Whether graduation signal is enabled (feature: wasm4pm).
    pub graduation_signal_enabled: bool,
    /// Covenant: "Compat carries the evidence. wasm4pm adjudicates it."
    pub covenant: String,
}

impl WasmBoundaryReceipt {
    /// Construct the receipt for this build.
    #[must_use]
    pub const fn new() -> Self {
        Self {
            crate_version: "{{ version }}".to_string(),
            generated_at: "{{ generatedDate }}".to_string(),
            num_admission_gates: 3, // event_log, ocel_log, xes_log
            num_lossy_projections: 1, // ocel_to_xes
            num_witnesses: {{ witnessGates | length }},
            graduation_signal_enabled: {% if graduationSignal.enabled %}true{% else %}false{% endif %},
            covenant: "Compat carries the evidence. wasm4pm adjudicates it.".to_string(),
        }
    }
}

impl Default for WasmBoundaryReceipt {
    fn default() -> Self {
        Self::new()
    }
}

// ============================================================================
