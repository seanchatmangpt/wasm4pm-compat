//! Process Lifecycle Authority Module
//!
//! This module is the wasm4pm graduation surface for object lifecycle tracking,
//! state transitions, and artifact provenance. It wraps the structure-only witness
//! markers from `wasm4pm_compat` with actual lifecycle management implementations.
//!
//! # What this IS
//!
//! - A container for object-centric lifecycle engines (OCEL tracking, state machines, etc.)
//! - Token carrier for [`crate::evidence::Evidence<T, State, LifecycleWitness>`]
//! - The graduation boundary where lifecycle and object state logic executes
//! - A zero-unsafe-code zone (forbid unsafe)
//!
//! # What this is NOT
//!
//! - Not a type-only namespace (actual lifecycle logic lives here)
//! - Not a witness marker (those stay in wasm4pm-compat)
//! - Not a mining or conformance engine (those go to their respective modules)
//!
//! # Graduation Condition
//!
//! A process form graduates to this module when:
//! 1. Its wasm4pm-compat witness is structurally valid
//! 2. A concrete lifecycle tracking algorithm is ready to implement
//! 3. The algorithm can work with [`Evidence`] carriers and object-centric models

use crate::evidence::{Evidence, Admitted, Projected};
use wasm4pm_compat::witness::{Witness, LifecycleWitness};
use std::collections::BTreeMap;
use std::marker::PhantomData;

/// Lifecycle authority marker — carries object-centric lifecycle semantics.
///
/// All lifecycle operations are keyed to a [`LifecycleWitness`], which names
/// the lifecycle model (OCEL, object-centric Petri net) and its standard.
#[derive(Debug, Clone, Copy)]
pub struct LifecycleAuthority<W: Witness = LifecycleWitness> {
    _witness: PhantomData<W>,
}

impl<W: Witness> LifecycleAuthority<W> {
    /// Create a lifecycle authority bound to witness `W`.
    pub const fn new() -> Self {
        LifecycleAuthority {
            _witness: PhantomData,
        }
    }

    /// The witness this authority is bound to.
    pub const fn witness_key() -> &'static str {
        W::KEY
    }
}

impl Default for LifecycleAuthority {
    fn default() -> Self {
        Self::new()
    }
}

/// Lifecycle tracking engine trait.
///
/// Implement this trait for each concrete lifecycle algorithm.
/// The algorithm operates on [`Evidence`] carriers admitted against
/// a lifecycle witness authority.
pub trait LifecycleEngine<T, W: Witness = LifecycleWitness> {
    /// Track object lifecycles in an event log.
    ///
    /// # Arguments
    ///
    /// - `evidence`: event log evidence admitted against witness `W`
    ///
    /// # Returns
    ///
    /// Object lifecycle information in a projected evidence carrier.
    fn track_lifecycles(
        &self,
        evidence: &Evidence<T, Admitted, W>,
    ) -> Evidence<ObjectLifecycles, Projected, W>;
}

/// Object identifier and type.
#[derive(Debug, Clone, PartialEq, Eq, PartialOrd, Ord)]
pub struct ObjectId {
    /// Object type (e.g., "order", "invoice", "package")
    pub obj_type: String,
    /// Unique object identifier
    pub id: String,
}

impl ObjectId {
    /// Create a new object ID.
    pub fn new(obj_type: String, id: String) -> Self {
        ObjectId { obj_type, id }
    }
}

/// State of an object at a point in time.
#[derive(Debug, Clone, PartialEq, Eq)]
pub struct ObjectState {
    /// Current state name
    pub state: String,
    /// Timestamp of state entry
    pub timestamp: u64,
    /// Events that caused this state
    pub causation: Vec<String>,
}

impl ObjectState {
    /// Create a new object state.
    pub fn new(state: String, timestamp: u64) -> Self {
        ObjectState {
            state,
            timestamp,
            causation: Vec::new(),
        }
    }

    /// Add an event to the causation chain.
    pub fn with_causation(mut self, event: String) -> Self {
        self.causation.push(event);
        self
    }
}

/// Complete lifecycle of an object.
#[derive(Debug, Clone)]
pub struct ObjectLifecycle {
    /// Object identifier
    pub id: ObjectId,
    /// Sequence of states
    pub states: Vec<ObjectState>,
    /// Attributes at final state
    pub final_attributes: BTreeMap<String, String>,
    /// Total duration in milliseconds
    pub duration_ms: u64,
}

impl ObjectLifecycle {
    /// Create a new object lifecycle.
    pub fn new(id: ObjectId) -> Self {
        ObjectLifecycle {
            id,
            states: Vec::new(),
            final_attributes: BTreeMap::new(),
            duration_ms: 0,
        }
    }

    /// Add a state to this lifecycle.
    pub fn add_state(&mut self, state: ObjectState) {
        self.states.push(state);
    }

    /// Check if this object reached a terminal state.
    pub fn is_complete(&self) -> bool {
        !self.states.is_empty()
    }
}

/// Collection of object lifecycles.
///
/// Holds the complete object-centric view of a process execution,
/// mapping each object to its lifecycle.
#[derive(Debug, Clone)]
pub struct ObjectLifecycles {
    /// Map of object ID to lifecycle
    pub objects: BTreeMap<ObjectId, ObjectLifecycle>,
    /// Global lifecycle start time
    pub start_time: u64,
    /// Global lifecycle end time
    pub end_time: u64,
}

impl ObjectLifecycles {
    /// Create a new object lifecycles collection.
    pub fn new() -> Self {
        ObjectLifecycles {
            objects: BTreeMap::new(),
            start_time: 0,
            end_time: 0,
        }
    }

    /// Add an object lifecycle.
    pub fn add_object(&mut self, lifecycle: ObjectLifecycle) {
        self.objects.insert(lifecycle.id.clone(), lifecycle);
    }

    /// Get the lifecycle of a specific object.
    pub fn get_object(&self, obj_id: &ObjectId) -> Option<&ObjectLifecycle> {
        self.objects.get(obj_id)
    }

    /// Total number of objects tracked.
    pub fn object_count(&self) -> usize {
        self.objects.len()
    }

    /// Check if all objects reached completion.
    pub fn all_complete(&self) -> bool {
        self.objects.values().all(|oc| oc.is_complete())
    }
}

impl Default for ObjectLifecycles {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn lifecycle_authority_construction() {
        let auth = LifecycleAuthority::<LifecycleWitness>::new();
        assert_eq!(auth.witness_key(), LifecycleWitness::KEY);
    }

    #[test]
    fn object_id_creation() {
        let obj_id = ObjectId::new("order".to_string(), "order-123".to_string());
        assert_eq!(obj_id.obj_type, "order");
        assert_eq!(obj_id.id, "order-123");
    }

    #[test]
    fn object_state_creation() {
        let state = ObjectState::new("submitted".to_string(), 1000);
        assert_eq!(state.state, "submitted");
        assert_eq!(state.timestamp, 1000);
        assert!(state.causation.is_empty());
    }

    #[test]
    fn object_lifecycle_creation() {
        let obj_id = ObjectId::new("order".to_string(), "order-123".to_string());
        let lifecycle = ObjectLifecycle::new(obj_id);
        assert!(!lifecycle.is_complete());
    }

    #[test]
    fn object_lifecycle_with_states() {
        let obj_id = ObjectId::new("order".to_string(), "order-123".to_string());
        let mut lifecycle = ObjectLifecycle::new(obj_id);
        lifecycle.add_state(ObjectState::new("submitted".to_string(), 1000));
        assert!(lifecycle.is_complete());
        assert_eq!(lifecycle.states.len(), 1);
    }

    #[test]
    fn object_lifecycles_collection() {
        let mut lifecycles = ObjectLifecycles::new();
        let obj_id = ObjectId::new("order".to_string(), "order-123".to_string());
        let mut lifecycle = ObjectLifecycle::new(obj_id.clone());
        lifecycle.add_state(ObjectState::new("completed".to_string(), 2000));
        lifecycles.add_object(lifecycle);

        assert_eq!(lifecycles.object_count(), 1);
        assert!(lifecycles.get_object(&obj_id).is_some());
    }
}
