{# compile-pass-fixture.tera: Renders a compile-pass fixture proving a lawful path is open. #}
{# Constitutional Equation: tests/ui/compile_pass/<lawName>.rs = mu(wasm4pm-compat.ttl, CompilePassLaw) #}
{# Input variables: #}
{#   lawName         — UpperCamelCase law name, e.g. "LawfulOcelAdmission" #}
{#   processFormType — the process form type under test, e.g. "OcelLog" #}
{#   witnessType     — the witness type name that authorises this path, e.g. "Ocel20" #}
{#   description     — one-line description of the lawful path this fixture proves is open #}
//! Law: {{ lawName }} --- lawful path is open.
//!
//! {{ description }}
//!
//! This is a compile-pass trybuild fixture for the ALIVE gate.
//! It MUST compile. If it does not compile, the lawful path is broken.
//!
//! Regenerate with: ggen sync --template compile-pass-fixture.tera
//! Run with: cargo test --test ui_tests -- --ignored

// Auto-generated by ggen from wasm4pm-compat.ttl --- DO NOT EDIT
// Source: wasm4pm-compat.ttl  (CompilePassLaw: {{ lawName }})

use wasm4pm_compat::admission::{Admit, Admission};
use wasm4pm_compat::evidence::Evidence;
use wasm4pm_compat::state::Raw;
{% if witnessType %}
use wasm4pm_compat::witness::{{ witnessType }};
{% endif %}
{% if processFormType %}
use wasm4pm_compat::{{ processFormType | lower }}::{{ processFormType }};
{% endif %}

/// Proves the lawful {{ lawName }} path is open at compile time.
///
/// {{ description }}
///
/// If this function body fails to typecheck the law is broken — file a defect.
fn prove_{{ lawName | lower | replace(from="-", to="_") }}() {
    // ARRANGE: raw untrusted input at the entry stage
    let raw: Evidence<{{ processFormType }}, Raw, {{ witnessType }}> =
        Evidence::raw({{ processFormType }}::default());

    // ACT: single lawful admission — the only public Raw → Admitted path
    let result = {{ processFormType }}::admit(raw);

    // ASSERT: either admitted or refused with a named law — never a bare error
    match result {
        Ok(admitted) => {
            // Lawful admission: the structure satisfies {{ witnessType }}::KEY.
            let _ = admitted;
        }
        Err(refused) => {
            // Lawful refusal: a named law was broken, not a catch-all.
            let _ = refused;
        }
    }
}

fn main() {
    prove_{{ lawName | lower | replace(from="-", to="_") }}();
}
