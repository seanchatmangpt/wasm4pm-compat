 *   value (OcelAttributeValue) — polymorphic value
 */
export interface OcelAttribute {
  key: string;
  value: OcelAttributeValue;
}

// --- OcelAttributeValue (ocel module) ---
// Polymorphic value in OCEL 2.0 attributes (supports string, int, float,
// boolean, timestamp, list, and map).
//
// Enum with discriminated union encoding (external tagging in Serde).
// No PhantomData, no const parameters.
// Witness: Ocel20
//
// From ts-projection-law LAW 1, LAW 2:
//   ✅ Enum variants are concrete data, not markers
//   ✅ Recursive: List and Map contain OcelAttributeValue
/**
 * Polymorphic attribute value in OCEL 2.0.
 *
 * Law: OCEL 2.0 attribute value types.
 * PhantomData: NONE
 * Witness: Ocel20
 * Standard: https://doi.org/10.48550/arXiv.2005.08811
 *
 * Variants:
 *   String(string)          — text value
 *   Integer(bigint)         — signed 64-bit integer
 *   Float(number)           — IEEE 754 float
 *   Boolean(boolean)        — true/false
 *   TimestampNs(bigint)     — nanoseconds since epoch
 *   List(OcelAttributeValue[]) — ordered sequence
 *   Map([string, OcelAttributeValue][]) — key-value pairs
 */
export type OcelAttributeValue =
  | { String: string }
  | { Integer: bigint }
  | { Float: number }
  | { Boolean: boolean }
  | { TimestampNs: bigint }
  | { List: OcelAttributeValue[] }
  | { Map: [string, OcelAttributeValue][] };

