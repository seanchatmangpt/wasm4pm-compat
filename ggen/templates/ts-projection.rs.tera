// ============================================================================
// TIER 2: ADMISSION & LOSS ACCOUNTING (WRAPPER TYPES)
// ============================================================================
// These types require wrapper structures because the originals in Rust carry
// PhantomData parameters (State, W) that have no TypeScript equivalent.
// The wrappers extract the data while metadata (witness name, refusal reason)
// becomes a string field.
//
// Law encoding:
//   - Admission<T, W> → AdmissionSnapshot<T> { value: T, witness_key: string }
//   - Refusal<R, W> → RefusalSnapshot { reason: R, witness_key: string }
//   - LossPolicy → concrete enum (RefuseLoss | AllowNamed | AllowWithReport)
//   - LossReport → audit trail of what was lost during projection
//

{% if tier2_types %}
// --- AdmissionSnapshot<T> (admission module wrapper) ---
// Unwrapped Admission<T, W> where W is converted to a metadata string.
//
// Derived from LAW 3 (Branded Generics Become Concrete Wrappers):
//   Admission<T, W> carries a witness W as PhantomData. This wrapper drops W
//   and carries its metadata as a string field instead.
//
// From ts-projection-law:
//   ✅ PhantomData<W> removed
//   ✅ T must be serializable (enforced by Serde)
//   ✅ witness_key is a static string identifying the authority
/**
 * Admission envelope: value that has passed structural checks.
 *
 * Law: admission boundary ceremony (LAW 3).
 * Carries the admitted value and witness metadata (W as string).
 *
 * From Rust: Admission<T, W> where
 *   T: Serialize + Deserialize
 *   W: Witness (witness metadata in witness_key field)
 *
 * Fields:
 *   value       (T) — the admitted data structure
 *   witness_key (string) — e.g., "ocel-2.0", "xes-1.0", authority identifier
 *   witness_title (string | null) — human-readable authority name
 */
export interface AdmissionSnapshot<T> {
  value: T;
  witness_key: string;
  witness_title?: string;
}

// --- RefusalSnapshot (admission module wrapper) ---
// Unwrapped Refusal<R, W> where R is a concrete reason enum and W becomes metadata.
//
// Derived from LAW 3:
//   Refusal<R, W> must have R as a concrete refusal type (EventLogRefusal, etc.)
//   and W as PhantomData that is projected away. Witness becomes a string.
//
// From ts-projection-law:
//   ✅ Reason R is concrete enum (never generic)
//   ✅ Witness W converted to witness_key string
/**
 * Refusal envelope: reasons why admission failed.
 *
 * Law: refusal as first-class defect (LAW 3).
 * Carries the reason (concrete typed enum) and witness metadata.
 *
 * From Rust: Refusal<R, W> where
 *   R: concrete refusal enum
 *   W: Witness (metadata in witness_key)
 *
 * Fields:
 *   reason       (string) — serialized reason enum variant
 *   reason_code  (string) — machine-readable reason identifier
 *   witness_key  (string) — authority under which refusal was issued
 *   context      (Record<string, string> | null) — diagnostic context
 */
export interface RefusalSnapshot {
  reason: string;
  reason_code: string;
  witness_key: string;
  context?: Record<string, string>;
}

// --- LossPolicy (loss module) ---
// Decision on how to handle lossy projections.
//
// Concrete enum with three variants:
//   1. RefuseLoss: forbid any loss, fail the projection
//   2. AllowNamed: allow loss with a projection name
//   3. AllowWithReport: allow loss and require a LossReport
//
// From ts-projection-law LAW 5 (loss accounting):
//   ✅ All variants serializable
//   ✅ No phantom parameters or const generics
/**
 * Policy for handling structural loss in format projections.
 *
 * Law: loss accounting (LAW 5).
 * PhantomData: NONE
 *
 * Variants:
 *   RefuseLoss       — forbid any loss; return error if loss detected
 *   AllowNamed       — allow loss with a named projection identifier
 *   AllowWithReport  — allow loss and require LossReport audit trail
 */
export type LossPolicy =
  | { kind: "RefuseLoss" }
  | { kind: "AllowNamed"; name: string }
  | { kind: "AllowWithReport" };

// --- ProjectionName (loss module) ---
// Identifier for a named projection (e.g., "OCEL_to_XES").
//
// Newtype wrapper over &'static str; projects as a string.
//
// From ts-projection-law:
//   ✅ No PhantomData
/**
 * Name of a lossy projection (e.g., "OCEL_to_XES").
 *
 * Law: loss accounting.
 * Type: string identifier.
 */
export type ProjectionName = string;

// --- LossReport (loss module) ---
// Audit trail documenting structural loss during projection.
//
// Carries metadata about what was lost, why, and count.
// No PhantomData, fully concrete.
// Witness: not embedded (loss is format-agnostic)
//
// From ts-projection-law LAW 5:
//   ✅ All loss must be documented
//   ✅ Report must accompany lossy output
/**
 * Audit trail of structural loss during a projection.
 *
 * Law: loss accounting (LAW 5).
 * PhantomData: NONE
 *
 * Fields:
 *   from_format  (string) — source format (e.g., "OCEL 2.0")
 *   to_format    (string) — target format (e.g., "XES 1.0")
 *   items_lost   (LossItem[]) — individual losses
 *   summary      (string) — human-readable summary of loss
 *   loss_count   (bigint) — total items lost
 *   loss_percent (number) — percentage of total lost [0.0, 1.0]
 */
export interface LossReport {
  from_format: string;
  to_format: string;
  items_lost: LossItem[];
  summary: string;
  loss_count: bigint;
  loss_percent: number;
}

/**
 * Individual loss entry in a LossReport.
 *
 * Law: loss accounting.
 *
 * Fields:
 *   category  (string) — type of structure lost (e.g., "object-centric-links")
 *   count     (bigint) — number of items lost
 *   reason    (string) — why this structure was lost
 */
export interface LossItem {
  category: string;
  count: bigint;
  reason: string;
}

{% endif %}

// ============================================================================
// TIER 3: IDENTIFIERS & TYPE-SAFE WRAPPERS
// ============================================================================
// Branded newtypes for identifiers. These are #[repr(transparent)] in Rust,
// so they project as simple strings in TypeScript.
//
// Law encoding:
//   - EventId → branded string type
//   - ObjectId → branded string type
//   - TraceId / CaseId → branded string type
//   - EventTypeName → simple newtype
//   - ObjectTypeName → simple newtype
//

// --- EventId (ids module) ---
// Zero-cost branded identifier for events.
//
// Rust: #[repr(transparent)] pub struct EventId<K> { raw: u64, _kind: PhantomData<K> }
// TypeScript: string (branded via type alias)
//
// From ts-projection-law:
//   ✅ PhantomData<K> is erased (type-level only)
//   ✅ Projects as string
/**
 * Branded identifier for events.
 *
 * Law: zero-cost ID wrapper.
 * Brand: prevents confusing EventId with ObjectId or CaseId at TS type level.
 */
export type EventId = string & { readonly __brand: "EventId" };

// Helper: create a branded EventId
export function eventId(raw: string): EventId {
  return raw as EventId;
}

// --- ObjectId (ids module) ---
// Zero-cost branded identifier for objects.
//
// Rust: #[repr(transparent)] pub struct ObjectId<K> { raw: u64, _kind: PhantomData<K> }
// TypeScript: string (branded)
//
// From ts-projection-law:
//   ✅ PhantomData<K> erased
//   ✅ Projects as string
/**
 * Branded identifier for objects in OCEL logs.
 *
 * Law: zero-cost ID wrapper.
 * Brand: prevents confusing ObjectId with EventId.
 */
export type ObjectId = string & { readonly __brand: "ObjectId" };

export function objectId(raw: string): ObjectId {
  return raw as ObjectId;
}

// --- TraceId / CaseId (ids module) ---
// Zero-cost branded identifier for cases/traces.
//
// Rust: #[repr(transparent)]
// TypeScript: string (branded)
//
// From ts-projection-law:
//   ✅ PhantomData erased
/**
 * Branded identifier for cases/traces.
 *
 * Law: zero-cost ID wrapper.
 */
export type TraceId = string & { readonly __brand: "TraceId" };

export function traceId(raw: string): TraceId {
  return raw as TraceId;
}

// --- EventTypeName (ids module) ---
// Newtype for activity type names.
//
// Rust: pub struct EventTypeName(String)
// TypeScript: string
//
// From ts-projection-law:
//   ✅ Simple newtype, no PhantomData
/**
 * Activity type name (e.g., "Receive", "Invoice").
 *
 * Law: semantic type wrapper.
 */
export type EventTypeName = string & { readonly __brand: "EventTypeName" };

// --- ObjectTypeName (ids module) ---
// Newtype for object type names.
//
// Rust: pub struct ObjectTypeName(String)
// TypeScript: string
//
// From ts-projection-law:
//   ✅ Simple newtype
/**
 * Object type name (e.g., "Order", "Invoice").
 *
 * Law: semantic type wrapper.
 */
export type ObjectTypeName = string & { readonly __brand: "ObjectTypeName" };

// ============================================================================
// TIER 4: REFUSAL REASON ENUMS
// ============================================================================
// Concrete refusal types that name specific structural laws.
// Each variant must carry enough context to diagnose the failure.
//
// Law encoding:
//   - EventLogRefusal → named law per variant
//   - OcelRefusal → named law per variant
//   - Other domain refusals
//
// From ts-projection-law LAW 6 (refusal typing):
//   ✅ Never bare strings; always concrete enums
//   ✅ Each variant names a specific law
//

{% if tier4_refusals %}
{% for refusal in tier4_refusals %}
{% if refusal.name == "EventLogRefusal" %}
/**
 * Reasons why an event log cannot be admitted.
 *
 * Law: eventlog admission law (LAW 6).
 * Each variant names a specific structural law.
 *
 * Witness: applied at admission boundary (Xes1849, EventLogCanon, etc.)
 *
 * Variants:
 *   DanglingEventObjectLink — OCEL link references non-existent event
 *   InvalidEventType — activity type not in schema
 *   MissingTimestamp — event required but missing timestamp
 *   MissingActivity — activity field is empty or null
 *   CyclicTrace — trace contains duplicate case IDs or cycles
 *   DuplicateEventId — two events share the same ID
 */
export type EventLogRefusal =
  | {
      kind: "DanglingEventObjectLink";
      event_id: string;
      object_id: string;
    }
  | { kind: "InvalidEventType"; activity: string }
  | { kind: "MissingTimestamp"; event_index: bigint }
  | { kind: "MissingActivity"; event_index: bigint }
  | { kind: "CyclicTrace"; trace_id: string }
  | { kind: "DuplicateEventId"; event_id: string };

{% endif %}
{% if refusal.name == "OcelRefusal" %}
/**
 * Reasons why an OCEL log cannot be admitted.
 *
 * Law: OCEL 2.0 admission law (LAW 6).
 * Each variant names a specific OCEL structural law.
 *
 * Witness: Ocel20 (https://doi.org/10.48550/arXiv.2005.08811)
 *
 * Variants:
 *   DanglingEventObjectLink — e2o link references non-existent event or object
 *   InvalidObjectType — object type not declared
 *   MissingEventType — event activity not in schema
 *   InvalidAttributeValue — attribute violates type constraint
 *   DanglingObjectObjectLink — o2o link references non-existent objects
 *   InvalidQualifier — qualifier on link not in whitelist
 *   ObjectNotInUniverse — object is not in the object universe
 */
export type OcelRefusal =
  | {
      kind: "DanglingEventObjectLink";
      event_id: bigint;
      object_id: bigint;
      object_type: string;
    }
  | { kind: "InvalidObjectType"; object_type: string }
  | { kind: "MissingEventType"; activity: string }
  | {
      kind: "InvalidAttributeValue";
      key: string;
      expected_type: string;
    }
  | {
      kind: "DanglingObjectObjectLink";
      source_id: bigint;
      target_id: bigint;
    }
  | { kind: "InvalidQualifier"; qualifier: string }
  | { kind: "ObjectNotInUniverse"; object_id: bigint };

{% endif %}
{% endfor %}
{% endif %}

// ============================================================================
// WITNESS METADATA & REGISTRY
// ============================================================================
// Witness markers in Rust are empty enums (zero-sized types). They carry
// metadata as associated consts (KEY, TITLE, FAMILY, YEAR).
// This export provides that metadata in a structured form.
//
// Law encoding:
//   - WitnessFamily → enumerated family (Standard, Paper, ApiGrammar, RustLaw, InternalBridge)
//   - WitnessMetadata → {key: string, family: WitnessFamily, title: string, year?: number}
//   - WITNESSES → registry mapping key → metadata
//

/**
 * Category of witness authority.
 *
 * Law: witness family classification.
 * PhantomData: NONE
 *
 * Variants:
 *   Standard — published standard (OCEL 2.0, XES 1.0, BPMN 2.0)
 *   Paper — research publication (van der Aalst, etc.)
 *   ApiGrammar — internal grammar/DSL specification
 *   RustLaw — Rust type-law enforcement (const bounds, generics)
 *   InternalBridge — internal covenant or bridge
 */
export type WitnessFamily =
  | "Standard"
  | "Paper"
  | "ApiGrammar"
  | "RustLaw"
  | "InternalBridge";

/**
 * Metadata for a witness authority.
 *
 * Law: witness authority registration.
 * PhantomData: NONE
 *
 * Fields:
 *   key    (string) — stable machine identifier (e.g., "ocel-2.0")
 *   family (WitnessFamily) — authority category
 *   title  (string) — human-readable authority name (e.g., "OCEL 2.0")
 *   year   (number | null) — publication year if applicable
 *   doi    (string | null) — Digital Object Identifier if applicable
 */
export interface WitnessMetadata {
  key: string;
  family: WitnessFamily;
  title: string;
  year?: number;
  doi?: string;
}

/**
 * Registry of all witness authorities in wasm4pm-compat.
 *
 * Law: witness authority registration and discovery.
 *
 * Maps witness key (e.g., "ocel-2.0") to metadata.
 * Use to look up witness title, family, and year at runtime.
 *
 * Example:
 *   const ocel = WITNESSES["ocel-2.0"];
 *   console.log(ocel.title); // "OCEL 2.0"
 *   console.log(ocel.year);  // 2020
 */
export const WITNESSES: Record<string, WitnessMetadata> = {
  "ocel-2.0": {
    key: "ocel-2.0",
    family: "Standard",
    title: "OCEL 2.0",
    year: 2020,
    doi: "10.48550/arXiv.2005.08811",
  },
  "xes-1.0": {
    key: "xes-1.0",
    family: "Standard",
    title: "XES 1.0",
    year: 2010,
  },
  "bpmn-2.0": {
    key: "bpmn-2.0",
    family: "Standard",
    title: "BPMN 2.0",
    year: 2011,
  },
  "eventlog-canon": {
    key: "eventlog-canon",
    family: "RustLaw",
    title: "Event Log Canon",
  },
};

/**
 * Look up witness metadata by key.
 *
 * Helper function to safely retrieve witness information.
 *
 * @param key — witness key (e.g., "ocel-2.0")
 * @returns metadata if found; null otherwise
 */
export function witnessMetadata(key: string): WitnessMetadata | null {
  return WITNESSES[key] ?? null;
}

// ============================================================================
// RECEIPT & QUALITY METRICS
// ============================================================================
// Receipts document the history of data transformations.
// Quality metrics (fitness, precision, F1, generalization) quantify log
// quality.
//
// Law encoding:
//   - Receipt → cryptographic proof of transformation
//   - ReceiptFormat → format of the receipt (JSON, etc.)
//   - QualityMetric → metric value bounded in [0, 1]
//   - MetricKind → fitness, precision, f1, generalization
//

/**
 * Format of a receipt (encoding).
 *
 * Law: receipt serialization.
 * PhantomData: NONE
 *
 * Variants:
 *   JSON — JSON-serialized receipt
 *   CBOR — CBOR binary format
 *   Hex  — hexadecimal string
 */
export type ReceiptFormat = "JSON" | "CBOR" | "Hex";

/**
 * Cryptographic proof of a transformation.
 *
 * Law: receipt as provenance (ALIVE gate).
 * PhantomData: NONE
 *
 * Documents:
 *   - What was transformed (from_type, to_type)
 *   - How (transformation_name)
 *   - When (timestamp)
 *   - By whom (witness authority)
 *   - Proof (hash or signature)
 *
 * Fields:
 *   id                (string) — unique receipt identifier
 *   timestamp_ns      (bigint) — creation timestamp
 *   witness_key       (string) — authority that issued the receipt
 *   from_type         (string) — source type name
 *   to_type           (string) — target type name
 *   transformation    (string) — name of transformation
 *   proof             (string) — hash or cryptographic signature
 *   format            (ReceiptFormat) — encoding of the proof
 */
export interface Receipt {
  id: string;
  timestamp_ns: bigint;
  witness_key: string;
  from_type: string;
  to_type: string;
  transformation: string;
  proof: string;
  format: ReceiptFormat;
}

/**
 * Category of quality metric.
 *
 * Law: quality metrics for conformance measurement (LAW 3).
 * PhantomData: NONE
 *
 * Variants:
 *   Fitness — proportion of log behavior explained by model [0, 1]
 *   Precision — proportion of model behavior seen in log [0, 1]
 *   F1 — harmonic mean of fitness and precision [0, 1]
 *   Generalization — extent model captures process variants [0, 1]
 *   SimplifiedFitness — token-replay fitness (faster, less accurate)
 */
export type MetricKind =
  | "Fitness"
  | "Precision"
  | "F1"
  | "Generalization"
  | "SimplifiedFitness";

/**
 * Quality metric value with kind and bounds [0, 1].
 *
 * Law: quality metrics (LAW 3).
 * PhantomData: NONE
 *
 * From Rust: Metric<KIND, NUM, DEN> where
 *   KIND: QualityMetricKind (const)
 *   NUM, DEN: const u64 enforcing 0 ≤ NUM ≤ DEN
 *
 * Projection: const generics → runtime values (num, den)
 *
 * Fields:
 *   kind (MetricKind) — metric type
 *   num  (bigint) — numerator [0, DEN]
 *   den  (bigint) — denominator [> 0]
 */
export interface QualityMetric {
  kind: MetricKind;
  num: bigint;
  den: bigint;
}

/**
 * Helper: compute metric as float.
 *
 * @param metric — the metric
 * @returns value in [0.0, 1.0]
 */
export function metricAsFloat(metric: QualityMetric): number {
  return Number(metric.num) / Number(metric.den);
}

// ============================================================================
// CONFORMANCE VERDICT
// ============================================================================
// Verdict is the result of a conformance check (not the computation itself,
// which belongs in wasm4pm).
//
// Exports the *shape* of a verdict, not the checking logic.
// Witness: authority under which the verdict is issued.
//

/**
 * Conformance checking verdict.
 *
 * Law: conformance verdict shape (structure-only; computation in wasm4pm).
 * PhantomData: NONE
 * Witness: not embedded (verdict inherits witness from the log being checked)
 *
 * Indicates:
 *   - Whether the log conforms to the process model
 *   - Conformance metrics (fitness, precision, F1)
 *   - Non-conforming traces (if any)
 *
 * Fields:
 *   is_conforming (boolean) — log conforms to model
 *   fitness (QualityMetric) — proportion of log explained by model
 *   precision (QualityMetric) — proportion of model seen in log
 *   non_conforming_traces (bigint) — count of non-conforming traces
 *   timestamp_ns (bigint) — verdict issue timestamp
 */
export interface ConformanceVerdict {
  is_conforming: boolean;
  fitness: QualityMetric;
  precision: QualityMetric;
  non_conforming_traces: bigint;
  timestamp_ns: bigint;
}

