{# ts-projection.rs.ggen: TypeScript projection generator for wasm4pm-compat public API #}
{# Constitutional Equation: generated/wasm4pm-compat.ts = mu(ts.projection.yaml + specta-capability-map) #}
{# #}
{# INPUT VARIABLES: #}
{#   projectionMetadata  — projection manifest metadata (name, version, source_lang, target_lang) #}
{#   tier1Types          — list of immediately exportable types (Event, Trace, EventLog, OcelEvent, ...) #}
{#   tier2Types          — list of types requiring wrapper or constraint handling (Admission<T, W>, LossReport, ...) #}
{#   tier4Refusals       — list of refusal reason enums (EventLogRefusal, OcelRefusal, ...) #}
{#   witnessFamily       — witness family enum (Standard, Paper, ApiGrammar, RustLaw, InternalBridge) #}
{#   exportFeature       — feature gate name (ts, wasm, wasm4pm) #}
{#   generatedTimestamp  — ISO 8601 timestamp for generation metadata #}
{# #}
{# OUTPUT: #}
{#   Single .ts file containing: #}
{#     • All Tier 1 type definitions (direct export) #}
{#     • All Tier 2 wrapper definitions #}
{#     • All Tier 4 refusal enums #}
{#     • Witness metadata and registry #}
{#     • Helper functions (eventId, objectId, metric, witnessMetadata) #}
{#     • Audit checklist comments #}
{#     • Loss report and receipt types #}
{#     • Law encoding documentation per type #}
{# #}
// ============================================================================
// AUTO-GENERATED: TypeScript Projection for wasm4pm-compat
// ============================================================================
//
// Generator: ggen ts-projection.rs.ggen
// Authority: ts.projection.yaml + specta-capability-map.md
// Timestamp: {{ generatedTimestamp }}
// Feature gate: {{ exportFeature }}
// Stability: STABLE
//
// DO NOT EDIT MANUALLY. Regenerate with:
//   ggen sync --template ts-projection.rs.ggen
//
// ============================================================================
// TYPE LAW DOCTRINE
// ============================================================================
//
// This file encodes three canonical laws for TypeScript projection:
//
//   LAW 1: No PhantomData at the boundary.
//     Witness markers (W) and State tokens (State) are zero-sized compile-time
//     tags in Rust. They MUST NOT appear in TypeScript. This projection
//     eliminates them by exporting metadata separately.
//
//   LAW 2: All Domain Shapes Are Serializable.
//     Every exported type implements Serde (Serialize + Deserialize).
//     Specta walks the tree to generate type definitions; zero-sized types
//     are automatically skipped.
//
//   LAW 3: Branded Generics Become Concrete Wrappers.
//     Evidence<T, State, W> is branded by two phantom parameters.
//     Projection creates concrete newtypes: RawEvidence<T>, AdmittedEvidence<T>, etc.
//
// ============================================================================
// TIER 1: CORE DOMAIN TYPES (IMMEDIATELY EXPORTABLE)
// ============================================================================
// These types carry no PhantomData, no const parameters, and no lifecycle
// markers. They represent the fundamental shapes of event logs and OCEL.
//
// Law encoding:
//   - Event         → eventlog canon, fundamental unit
//   - Trace         → case-centric container (classical BPM)
//   - EventLog      → root container for traces
//   - OcelEvent     → object-centric individual event
//   - OcelObject    → first-class object with attributes and identity
//   - OcelAttribute → key-value metadata on events/objects
//   - OcelAttributeValue → polymorphic value type (string, int, float, bool, timestamp, list, map)
//

{% if tier1_types %}
// --- Event (eventlog module) ---
// Fundamental unit of process evidence.
//
// Structure-only type; no PhantomData.
// Serialization: serde(default) for optional fields
// Witness: None (fundamental canon, not witness-specific)
//
// From ts-projection-law LAW 1, LAW 2:
//   ✅ No PhantomData fields
//   ✅ All fields serialize via serde
//   ✅ Timestamps are u64 (serialized as bigint in TS)
//   ✅ Optional fields become T | null in TypeScript
{% for type in tier1_types %}
{% if type.name == "Event" %}
/**
 * Individual activity execution in a process instance.
 *
 * Law: eventlog canon.
 * PhantomData: NONE
 * Witness: NONE (structural unit)
 *
 * Fields:
 *   activity     (string) — unique activity code from the process definition
 *   timestamp_ns (bigint | null) — event timestamp in nanoseconds since epoch
 *   resource     (string | null) — assigned resource/performer
 *   lifecycle    (string | null) — lifecycle transition (XES standard: start, complete, etc.)
 *   attributes   (Record<string, any> | null) — additional attributes
 */
export interface Event {
  activity: string;
  timestamp_ns?: bigint;
  resource?: string;
  lifecycle?: string;
  attributes?: Record<string, unknown>;
}

// --- Trace (eventlog module) ---
// Case-centric sequence of events (classical case-log structure).
//
// Structure-only; ordered sequence of Event objects.
// No PhantomData, no witness markers.
// Serialization: Vec<Event> → bigint in TS
//
// From ts-projection-law LAW 1, LAW 2:
//   ✅ No state tokens, no witness parameters
//   ✅ Vec<Event> projects to Event[]
/**
 * Ordered sequence of events for a single case/process instance.
 *
 * Law: eventlog canon (case-centric).
 * PhantomData: NONE
 * Witness: NONE
 *
 * Fields:
 *   id     (string) — unique case/trace identifier
 *   events (Event[]) — ordered list of activities
 */
export interface Trace {
  id: string;
  events: Event[];
}

// --- EventLog (eventlog module) ---
// Root container for all traces in a log.
//
// Structure-only collection.
// No PhantomData, no witness.
// Serialization: Vec<Trace> → Trace[]
//
// From ts-projection-law LAW 1, LAW 2:
//   ✅ No phantom parameters
//   ✅ Nested Vec projects to [][]
/**
 * Complete event log containing all traces.
 *
 * Law: eventlog canon (root container).
 * PhantomData: NONE
 * Witness: NONE
 *
 * Fields:
 *   traces (Trace[]) — ordered list of all traces
 */
export interface EventLog {
  traces: Trace[];
}

{% endif %}
{% if type.name == "OcelEvent" %}
// --- OcelEvent (ocel module) ---
// Object-centric event with OCEL 2.0 semantics.
