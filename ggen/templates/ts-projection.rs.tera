 */
export interface OcelObject {
  id: bigint;
  type_name: string;
  attributes: OcelAttribute[];
}

// --- OcelAttribute (ocel module) ---
// Key-value metadata on events or objects (OCEL 2.0).
//
// Structure-only; polymorphic value type.
